@page "/knowledge-base"
@layout VandaliaCentral.Components.Layout.TopBarLayout

<PageTitle>Knowledge Base</PageTitle>

<div class="container-fluid px-3 px-md-4 px-xl-5 py-4">
    <div class="kb-shell bg-white border rounded shadow-sm overflow-hidden">
        <aside class="kb-sidebar border-end p-3">
            <h5 class="mb-3">Folders</h5>
            <div class="list-group list-group-flush">
                @foreach (var folder in Folders)
                {
                    <button type="button"
                            class="list-group-item list-group-item-action @(SelectedFolder?.Id == folder.Id ? "active" : string.Empty)"
                            @onclick="() => SelectFolder(folder)">
                        @folder.Name
                    </button>
                }
            </div>
        </aside>

        <main class="kb-main p-3 p-md-4">
            @if (SelectedFolder is null)
            {
                <div class="text-center text-muted py-5">
                    <h4 class="mb-2">Knowledge Base</h4>
                    <p class="mb-0">Select a folder on the left to view available articles.</p>
                </div>
            }
            else if (SelectedArticle is null)
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">@SelectedFolder.Name</h4>
                    <span class="text-muted small">@SelectedFolder.Articles.Count article(s)</span>
                </div>

                <div class="row g-3">
                    @foreach (var article in SelectedFolder.Articles)
                    {
                        <div class="col-12 col-md-6 col-xl-4">
                            <button type="button" class="article-tile text-start w-100 h-100" @onclick="() => OpenArticle(article)">
                                <div class="fw-semibold">@article.Title</div>
                                <div class="text-muted small mt-2">Click to open</div>
                            </button>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="BackToTiles">Back</button>
                    <h5 class="mb-0">@SelectedArticle.Title</h5>
                    <span></span>
                </div>

                <iframe src="@SelectedArticle.EmbedUrl"
                        width="100%"
                        height="800"
                        allow="fullscreen"
                        style="border: 0; min-height: 640px"></iframe>
            }
        </main>
    </div>
</div>

<style>
    .kb-shell {
        display: grid;
        grid-template-columns: 260px 1fr;
        min-height: 70vh;
    }

    .kb-sidebar {
        background: #f8f9fa;
    }

    .article-tile {
        border: 1px solid #dee2e6;
        background: #fff;
        border-radius: .5rem;
        padding: 1rem;
        transition: box-shadow .15s ease, transform .15s ease;
    }

        .article-tile:hover {
            box-shadow: 0 .25rem .75rem rgba(0,0,0,.08);
            transform: translateY(-1px);
        }

    @media (max-width: 991.98px) {
        .kb-shell {
            grid-template-columns: 1fr;
        }

        .kb-sidebar {
            border-right: 0 !important;
            border-bottom: 1px solid #dee2e6;
        }
    }
</style>

@code {
    private List<KnowledgeFolder> Folders { get; } = new()
    {
        new KnowledgeFolder(
            "it-support",
            "IT Support",
            new List<KnowledgeArticle>
            {
                new KnowledgeArticle("Create a New User", "https://scribehow.com/page-embed/InTempoMX__Create_a_New_User__KZ420Y0XRHq4S_HfZtb0IA")
            }),
        new KnowledgeFolder(
            "hr-policies",
            "HR & Policies",
            new List<KnowledgeArticle>
            {
                new KnowledgeArticle("Employee Onboarding", "https://scribehow.com/page-embed/InTempoMX__Create_a_New_User__KZ420Y0XRHq4S_HfZtb0IA"),
                new KnowledgeArticle("Time Off Request", "https://scribehow.com/page-embed/InTempoMX__Create_a_New_User__KZ420Y0XRHq4S_HfZtb0IA")
            }),
        new KnowledgeFolder(
            "software-tools",
            "Software Tools",
            new List<KnowledgeArticle>
            {
                new KnowledgeArticle("InTempoMX Basics", "https://scribehow.com/page-embed/InTempoMX__Create_a_New_User__KZ420Y0XRHq4S_HfZtb0IA")
            })
    };

    private KnowledgeFolder? SelectedFolder;
    private KnowledgeArticle? SelectedArticle;

    private void SelectFolder(KnowledgeFolder folder)
    {
        SelectedFolder = folder;
        SelectedArticle = null;
    }

    private void OpenArticle(KnowledgeArticle article)
    {
        SelectedArticle = article;
    }

    private void BackToTiles()
    {
        SelectedArticle = null;
    }

    private sealed record KnowledgeFolder(string Id, string Name, List<KnowledgeArticle> Articles);
    private sealed record KnowledgeArticle(string Title, string EmbedUrl);
}
