@page "/knowledge-base"
@layout VandaliaCentral.Components.Layout.TopBarLayout
@using VandaliaCentral.Models
@using VandaliaCentral.Services
@inject KnowledgeBaseService KnowledgeBaseService

<PageTitle>Knowledge Base</PageTitle>

<div class="container-fluid px-3 px-md-4 px-xl-5 py-4">
    <div class="kb-shell bg-white border rounded shadow-sm overflow-hidden">
        <aside class="kb-sidebar border-end p-3">
            <div class="d-flex justify-content-between align-items-center mb-3 gap-2">
                <h5 class="mb-0">Folders</h5>
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GoHome">Home</button>
            </div>
            @if (Folders.Count == 0)
            {
                <p class="text-muted mb-0">No folders are available yet.</p>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var folder in Folders)
                    {
                        <button type="button"
                                class="list-group-item list-group-item-action @(SelectedFolder?.Id == folder.Id ? "active" : string.Empty)"
                                @onclick="() => SelectFolder(folder)">
                            @folder.Name
                        </button>
                    }
                </div>
            }
        </aside>

        <main class="kb-main p-3 p-md-4">
            @if (SelectedArticle is null)
            {
                <div class="mb-3">
                    <input type="search"
                           class="form-control"
                           placeholder="Search articles..."
                           @bind="ArticleSearchTerm"
                           @bind:event="oninput" />
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(ArticleSearchTerm))
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">Search Results</h4>
                    <span class="text-muted small">@GlobalSearchResults.Count article(s)</span>
                </div>

                @if (GlobalSearchResults.Count == 0)
                {
                    <p class="text-muted">No articles match your search.</p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var result in GlobalSearchResults)
                        {
                            <div class="col-12 col-md-6 col-xl-4">
                                <button type="button" class="article-tile text-start w-100 h-100" @onclick="() => OpenSearchResultAsync(result)">
                                    <div class="fw-semibold">@result.Article.Title</div>
                                    <div class="text-muted small mt-1">@result.Folder.Name</div>
                                    <div class="text-muted small mt-2">Click to open</div>
                                </button>
                            </div>
                        }
                    </div>
                }
            }
            else if (SelectedFolder is null)
            {
                <div class="mb-4">
                    <h4 class="mb-2">Knowledge Base Home</h4>
                    <p class="text-muted mb-0">Browse highlighted articles or select a folder on the left.</p>
                </div>

                <div class="row g-4">
                    <div class="col-12 col-xl-6">
                        <h5 class="mb-3">Recently Added</h5>
                        @if (RecentlyAddedArticles.Count == 0)
                        {
                            <p class="text-muted mb-0">No articles available yet.</p>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-2">
                                @foreach (var article in RecentlyAddedArticles)
                                {
                                    <button type="button" class="article-highlight-tile text-start" @onclick="() => OpenArticle(article)">
                                        <div class="fw-semibold">@article.Article.Title</div>
                                        <div class="text-muted small mt-1">@article.Folder.Name</div>
                                        <div class="text-muted small mt-1">Added @article.Article.CreatedOn.ToLocalTime().ToString("MMM d, yyyy")</div>
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    <div class="col-12 col-xl-6">
                        <h5 class="mb-3">Most Viewed</h5>
                        @if (MostViewedArticles.Count == 0)
                        {
                            <p class="text-muted mb-0">No articles available yet.</p>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-2">
                                @foreach (var article in MostViewedArticles)
                                {
                                    <button type="button" class="article-highlight-tile text-start" @onclick="() => OpenArticle(article)">
                                        <div class="fw-semibold">@article.Article.Title</div>
                                        <div class="text-muted small mt-1">@article.Folder.Name</div>
                                        <div class="text-muted small mt-1">@article.Article.ViewCount view(s)</div>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else if (SelectedArticle is null)
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">@SelectedFolder.Name</h4>
                    <span class="text-muted small">@SelectedFolder.Articles.Count article(s)</span>
                </div>

                @if (SelectedFolder.Articles.Count == 0)
                {
                    <p class="text-muted">No articles have been added to this folder yet.</p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var article in SelectedFolder.Articles.OrderBy(a => a.Title, StringComparer.OrdinalIgnoreCase))
                        {
                            <div class="col-12 col-md-6 col-xl-4">
                                <button type="button" class="article-tile text-start w-100 h-100" @onclick="() => OpenArticle(article)">
                                    <div class="fw-semibold">@article.Title</div>
                                    <div class="text-muted small mt-2">Click to open</div>
                                </button>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="BackToTiles">Back</button>
                    <h5 class="mb-0">@SelectedArticle.Title</h5>
                    <span></span>
                </div>

                <iframe src="@SelectedArticle.EmbedUrl"
                        width="100%"
                        height="800"
                        allow="fullscreen"
                        style="border: 0; min-height: 640px"></iframe>
            }
        </main>
    </div>
</div>

<style>
    .kb-shell {
        display: grid;
        grid-template-columns: 260px 1fr;
        min-height: 70vh;
    }

    .kb-sidebar {
        background: #f8f9fa;
    }

    .article-tile,
    .article-highlight-tile {
        border: 1px solid #dee2e6;
        background: #fff;
        border-radius: .5rem;
        padding: 1rem;
        transition: box-shadow .15s ease, transform .15s ease;
    }

        .article-tile:hover,
        .article-highlight-tile:hover {
            box-shadow: 0 .25rem .75rem rgba(0,0,0,.08);
            transform: translateY(-1px);
        }

    @@media (max-width: 991.98px) {
        .kb-shell {
            grid-template-columns: 1fr;
        }

        .kb-sidebar {
            border-right: 0 !important;
            border-bottom: 1px solid #dee2e6;
        }
    }
</style>

@code {
    private const int HighlightArticleCount = 5;
    private List<KnowledgeBaseFolderItem> Folders { get; set; } = new();
    private KnowledgeBaseFolderItem? SelectedFolder;
    private KnowledgeBaseArticleItem? SelectedArticle;
    private string ArticleSearchTerm { get; set; } = string.Empty;

    private List<KnowledgeBaseSearchResultItem> AllArticles =>
        Folders
            .SelectMany(folder => folder.Articles.Select(article => new KnowledgeBaseSearchResultItem
            {
                Folder = folder,
                Article = article
            }))
            .ToList();

    private List<KnowledgeBaseSearchResultItem> GlobalSearchResults =>
        AllArticles
            .Where(result => result.Article.Title.Contains(ArticleSearchTerm, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private List<KnowledgeBaseSearchResultItem> RecentlyAddedArticles =>
        AllArticles
            .OrderByDescending(result => result.Article.CreatedOn)
            .ThenBy(result => result.Article.Title, StringComparer.OrdinalIgnoreCase)
            .Take(HighlightArticleCount)
            .ToList();

    private List<KnowledgeBaseSearchResultItem> MostViewedArticles =>
        AllArticles
            .OrderByDescending(result => result.Article.ViewCount)
            .ThenBy(result => result.Article.Title, StringComparer.OrdinalIgnoreCase)
            .Take(HighlightArticleCount)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        Folders = await KnowledgeBaseService.LoadFoldersAsync();
    }

    private void SelectFolder(KnowledgeBaseFolderItem folder)
    {
        SelectedFolder = folder;
        SelectedArticle = null;
        ArticleSearchTerm = string.Empty;
    }

    private void GoHome()
    {
        SelectedFolder = null;
        SelectedArticle = null;
        ArticleSearchTerm = string.Empty;
    }

    private async Task OpenArticle(KnowledgeBaseArticleItem article)
    {
        article.ViewCount++;
        SelectedArticle = article;
        await KnowledgeBaseService.SaveFoldersAsync(Folders);
    }

    private Task OpenSearchResultAsync(KnowledgeBaseSearchResultItem result)
    {
        SelectedFolder = result.Folder;
        ArticleSearchTerm = string.Empty;

        return OpenArticle(result.Article);
    }

    private void BackToTiles()
    {
        SelectedArticle = null;
    }

    private sealed class KnowledgeBaseSearchResultItem
    {
        public required KnowledgeBaseFolderItem Folder { get; init; }
        public required KnowledgeBaseArticleItem Article { get; init; }
        public string Title => Article.Title;
        public string EmbedUrl => Article.EmbedUrl;
        public int ViewCount { get; set; }
    }
}
