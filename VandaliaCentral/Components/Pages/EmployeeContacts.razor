@page "/employeecontacts"
@using Microsoft.Graph
@using Microsoft.Identity.Web
@using Microsoft.Identity.Client
@using Microsoft.AspNetCore.Authorization
@using VandaliaCentral.Services
@inject GraphUserService UserService

@attribute [Authorize]
@attribute [AuthorizeForScopes(Scopes = new[] { "User.Read.All", "Mail.Send" })]

<AuthorizeView>
    <Authorized>
        <div class="container-fluid d-flex flex-column border rounded bg-white shadow-sm col-md-12 py-4">
            <h3>Employee Contacts</h3>
            <input type="text" class="form-control w-50 mb-3" placeholder="Search by Name, Email, Job Title, or Employee Number..."
                   @bind="searchTerm" @bind:event="oninput" />
            <div class="d-flex flex-wrap align-items-start gap-2 mb-3">
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        District
                    </button>
                    <ul class="dropdown-menu p-2" style="max-height: 300px; overflow-y: auto; min-width: 220px;">
                        @foreach (var district in DistrictOptions)
                        {
                            <li>
                                <label class="dropdown-item d-flex align-items-center gap-2 mb-0">
                                    <input type="checkbox"
                                           checked="@selectedDistricts.Contains(district)"
                                           @onchange="(e) => ToggleFilter(selectedDistricts, district, e.Value)" />
                                    <span>@district</span>
                                </label>
                            </li>
                        }
                    </ul>
                </div>

                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Office Location
                    </button>
                    <ul class="dropdown-menu p-2" style="max-height: 300px; overflow-y: auto; min-width: 220px;">
                        @foreach (var officeLocation in OfficeLocationOptions)
                        {
                            <li>
                                <label class="dropdown-item d-flex align-items-center gap-2 mb-0">
                                    <input type="checkbox"
                                           checked="@selectedOfficeLocations.Contains(officeLocation)"
                                           @onchange="(e) => ToggleFilter(selectedOfficeLocations, officeLocation, e.Value)" />
                                    <span>@officeLocation</span>
                                </label>
                            </li>
                        }
                    </ul>
                </div>

                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Job Title
                    </button>
                    <ul class="dropdown-menu p-2" style="max-height: 300px; overflow-y: auto; min-width: 260px;">
                        @foreach (var jobTitle in JobTitleOptions)
                        {
                            <li>
                                <label class="dropdown-item d-flex align-items-center gap-2 mb-0">
                                    <input type="checkbox"
                                           checked="@selectedJobTitles.Contains(jobTitle)"
                                           @onchange="(e) => ToggleFilter(selectedJobTitles, jobTitle, e.Value)" />
                                    <span>@jobTitle</span>
                                </label>
                            </li>
                        }
                    </ul>
                </div>

                <button class="btn btn-outline-danger btn-sm" @onclick="ClearFilters" disabled="@(!HasActiveFilters)">
                    Clear Filters
                </button>
            </div>

            <div>
                @if (isLoading)
                {
                    <p>Loading contacts...</p>
                }
                else if (failure)
                {
                    <h4 class="text-danger mt-2">There was an error loading the contacts:</h4>
                    <p>Please refresh the webpage, or contact the intranet administrator for assistance.</p>
                }
                else
                {
                    <table class="table table-striped w-100">
                        <thead>
                            <tr class="w-100">
                                
                                <th class="text-truncate" style="overflow: hidden; white-space: nowrap;" width="5%">
                                    <button type="button" class="btn btn-link p-0 text-decoration-none text-dark fw-semibold"
                                            @onclick="() => ToggleSort(SortField.District)">
                                        District @GetSortIndicator(SortField.District)
                                    </button>
                                </th>
                                
                                <th class="text-truncate" style="overflow: hidden; white-space: nowrap;" width="15%">Name</th>
                                <th class="text-truncate" style="overflow: hidden; white-space: nowrap;" width="12%">
                                    <button type="button" class="btn btn-link p-0 text-decoration-none text-dark fw-semibold"
                                            @onclick="() => ToggleSort(SortField.OfficeLocation)">
                                        Office Location @GetSortIndicator(SortField.OfficeLocation)
                                    </button>
                                </th>
                                <th class="d-none d-md-table-cell" width="15%">Job Title</th>
                                <th class="d-none d-lg-table-cell" width="20%">Email</th>
                                <th class="d-none d-xl-table-cell" width="15%">Mobile Phone</th>
                                <th class="d-none d-xl-table-cell" width="15%">
                                    <button type="button" class="btn btn-link p-0 text-decoration-none text-dark fw-semibold"
                                            @onclick="() => ToggleSort(SortField.OfficeLocation)">
                                        Office Number @GetSortIndicator(SortField.OfficeLocation)
                                    </button>
                                </th>
                                
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in FilteredEmployees)
                            {
                                <tr>
                                    
                                    <td class="d-none d-xl-table-cell">@user.OnPremisesExtensionAttributes.ExtensionAttribute1</td>
                                    
                                    <td>
                                        <NavLink href="@($"/employeecontacts/{user.Id}")" class="text-decoration-none">
                                            @user.DisplayName
                                        </NavLink>
                                    </td>
                                    <td class="d-none d-xl-table-cell">@user.OfficeLocation</td>
                                    <td class="d-none d-md-table-cell">@user.JobTitle</td>
                                    
                                    <td>
                                        <NavLink href="@($"mailto:{user.Mail}")" class="text-decoration-none">
                                            @user.Mail
                                        </NavLink>
                                    </td>
                                    <td class="d-none d-xl-table-cell">@user.MobilePhone</td>
                                    <td class="d-none d-xl-table-cell">@(user.BusinessPhones?.FirstOrDefault() ?? "")</td>
                                    

                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </Authorized>
    <NotAuthorized>

    </NotAuthorized>
</AuthorizeView>

@code {
    private List<User> employees = new();
    private string searchTerm = "";
    private bool isLoading = true;
    private bool failure = false;
    private readonly HashSet<string> selectedDistricts = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> selectedOfficeLocations = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> selectedJobTitles = new(StringComparer.OrdinalIgnoreCase);
    private SortField activeSortField = SortField.None;
    private bool isSortAscending = true;

    private IEnumerable<string> DistrictOptions =>
        BuildFilterOptions(
            EmployeesFilteredBySelections(ignoreDistrictFilter: true),
            GetDistrict,
            selectedDistricts);

    private IEnumerable<string> OfficeLocationOptions =>
        BuildFilterOptions(
            EmployeesFilteredBySelections(ignoreOfficeLocationFilter: true),
            user => user.OfficeLocation ?? string.Empty,
            selectedOfficeLocations);

    private IEnumerable<string> JobTitleOptions =>
        BuildFilterOptions(
            EmployeesFilteredBySelections(ignoreJobTitleFilter: true),
            user => user.JobTitle ?? string.Empty,
            selectedJobTitles);

    private bool HasActiveFilters =>
        selectedDistricts.Count > 0 ||
        selectedOfficeLocations.Count > 0 ||
        selectedJobTitles.Count > 0;

    [Inject] private NavigationManager Navigation { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        // try
        // {
        //     var users = await UserService.GetUsersAsync(); // Updated to pass Navigation
        //     employees = users.ToList();
        // }
        try
        {
            var users = await UserService.GetUsersAsync();
            employees = users.ToList();

            foreach (var user in employees)
            {
                Console.WriteLine("-------- User Info --------");
                
                Console.WriteLine($"Display Name: {user.DisplayName}");
                Console.WriteLine($"Mail: {user.Mail}");
                Console.WriteLine($"UserPrincipalName: {user.UserPrincipalName}");
                Console.WriteLine($"Job Title: {user.JobTitle}");
                Console.WriteLine($"Mobile Phone: {user.MobilePhone}");
                Console.WriteLine($"Business Phones: {string.Join(", ", user.BusinessPhones ?? new List<string>())}");
                Console.WriteLine($"Office Location: {user.OfficeLocation}");
                Console.WriteLine($"Street Address: {user.StreetAddress}");
                Console.WriteLine($"City: {user.City}");
                Console.WriteLine($"State: {user.State}");
                Console.WriteLine($"Postal Code: {user.PostalCode}");
                Console.WriteLine($"Country: {user.Country}");
                Console.WriteLine($"PO Box (ExtAttr): {user.OnPremisesExtensionAttributes?.ExtensionAttribute1}");

                // Dump all extension attributes
                if (user.OnPremisesExtensionAttributes != null)
                {
                    Console.WriteLine("--- Extension Attributes ---");
                    Console.WriteLine($"ext1: {user.OnPremisesExtensionAttributes.ExtensionAttribute1}");
                    Console.WriteLine($"ext2: {user.OnPremisesExtensionAttributes.ExtensionAttribute2}");
                    Console.WriteLine($"ext3: {user.OnPremisesExtensionAttributes.ExtensionAttribute3}");
                    Console.WriteLine($"ext4: {user.OnPremisesExtensionAttributes.ExtensionAttribute4}");
                    Console.WriteLine($"ext5: {user.OnPremisesExtensionAttributes.ExtensionAttribute5}");
                    Console.WriteLine($"ext6: {user.OnPremisesExtensionAttributes.ExtensionAttribute6}");
                    Console.WriteLine($"ext7: {user.OnPremisesExtensionAttributes.ExtensionAttribute7}");
                    Console.WriteLine($"ext8: {user.OnPremisesExtensionAttributes.ExtensionAttribute8}");
                    Console.WriteLine($"ext9: {user.OnPremisesExtensionAttributes.ExtensionAttribute9}");
                    Console.WriteLine($"ext10: {user.OnPremisesExtensionAttributes.ExtensionAttribute10}");
                    Console.WriteLine($"ext11: {user.OnPremisesExtensionAttributes.ExtensionAttribute11}");
                    Console.WriteLine($"ext12: {user.OnPremisesExtensionAttributes.ExtensionAttribute12}");
                    Console.WriteLine($"ext13: {user.OnPremisesExtensionAttributes.ExtensionAttribute13}");
                    Console.WriteLine($"ext14: {user.OnPremisesExtensionAttributes.ExtensionAttribute14}");
                    Console.WriteLine($"ext15: {user.OnPremisesExtensionAttributes.ExtensionAttribute15}");
                }
            }
        }
        catch (ServiceException ex)
        {
            Console.WriteLine($"Error fetching users: {ex.Message}");
            Console.WriteLine($"Error code: {ex.Error.Code}");
            Console.WriteLine($"Error details: {ex.Error.Message}");
            failure = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Unexpected error: {ex.Message}");
            failure = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    //Search functionality 
    private IEnumerable<User> FilteredEmployees =>
        ApplySorting(EmployeesFilteredBySelections().Where(u =>
            string.IsNullOrWhiteSpace(searchTerm) ||
            (u.DisplayName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (u.Mail?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (u.JobTitle?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (GetEmployeeNumber(u).Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        ));

    private IEnumerable<User> EmployeesFilteredBySelections(
        bool ignoreDistrictFilter = false,
        bool ignoreOfficeLocationFilter = false,
        bool ignoreJobTitleFilter = false)
    {
        return employees.Where(user =>
            (ignoreDistrictFilter || selectedDistricts.Count == 0 || selectedDistricts.Contains(GetDistrict(user))) &&
            (ignoreOfficeLocationFilter || selectedOfficeLocations.Count == 0 || selectedOfficeLocations.Contains(user.OfficeLocation ?? string.Empty)) &&
            (ignoreJobTitleFilter || selectedJobTitles.Count == 0 || selectedJobTitles.Contains(user.JobTitle ?? string.Empty))
        );
    }

    private static IEnumerable<string> BuildFilterOptions(
        IEnumerable<User> source,
        Func<User, string> selector,
        IEnumerable<string> selectedValues)
    {
        return source
            .Select(selector)
            .Concat(selectedValues)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(value => value);
    }

    private static string GetDistrict(User user) => user.OnPremisesExtensionAttributes?.ExtensionAttribute1 ?? string.Empty;

    private static string GetEmployeeNumber(User user) => user.OnPremisesExtensionAttributes?.ExtensionAttribute2 ?? string.Empty;
    private static string GetOfficeLocation(User user) => user.OfficeLocation ?? string.Empty;

    private IEnumerable<User> ApplySorting(IEnumerable<User> users)
    {
        return activeSortField switch
        {
            SortField.District when isSortAscending => users.OrderBy(GetDistrict, StringComparer.OrdinalIgnoreCase),
            SortField.District => users.OrderByDescending(GetDistrict, StringComparer.OrdinalIgnoreCase),
            SortField.OfficeLocation when isSortAscending => users.OrderBy(GetOfficeLocation, StringComparer.OrdinalIgnoreCase),
            SortField.OfficeLocation => users.OrderByDescending(GetOfficeLocation, StringComparer.OrdinalIgnoreCase),
            _ => users
        };
    }

    private void ToggleSort(SortField sortField)
    {
        if (activeSortField == sortField)
        {
            isSortAscending = !isSortAscending;
            return;
        }

        activeSortField = sortField;
        isSortAscending = true;
    }

    private string GetSortIndicator(SortField sortField)
    {
        if (activeSortField != sortField)
        {
            return "↕";
        }

        return isSortAscending ? "▲" : "▼";
    }

    private void ToggleFilter(HashSet<string> selectedValues, string value, object? isChecked)
    {
        if (bool.TryParse(isChecked?.ToString(), out var parsed) && parsed)
        {
            selectedValues.Add(value);
            return;
        }

        selectedValues.Remove(value);
    }

    private void ClearFilters()
    {
        selectedDistricts.Clear();
        selectedOfficeLocations.Clear();
        selectedJobTitles.Clear();
    }

    private enum SortField
    {
        None,
        District,
        OfficeLocation
    }
}
