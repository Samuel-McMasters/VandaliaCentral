    private static bool IsDocumentFileName(string fileName)
    {
        var extension = Path.GetExtension(fileName);
        return extension.Equals(".pdf", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".doc", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".docx", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".txt", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".csv", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".ppt", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".pptx", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".xls", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".xlsx", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".mp4", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".mov", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".avi", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".wmv", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".m4v", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".webm", StringComparison.OrdinalIgnoreCase);
    }

    private static string? ReadStringProperty(object source, string propertyName)
        => source.GetType().GetProperty(propertyName)?.GetValue(source)?.ToString();

    private static DateTimeOffset ReadDateTimeOffsetProperty(object source, string propertyName)
    {
        var value = source.GetType().GetProperty(propertyName)?.GetValue(source);
        return value is DateTimeOffset dto ? dto : DateTimeOffset.UtcNow;
    }

    private static DateTimeOffset? ReadNullableDateTimeOffsetProperty(object source, string propertyName)
    {
        var value = source.GetType().GetProperty(propertyName)?.GetValue(source);
        return value is DateTimeOffset dto ? dto : null;
    }

    private void StartExamCreation()
    {
        isCreatingExam = true;
        isEditingExam = false;
        editingExamId = null;
        ResetExamBuilder();
        SetExamStatus(null);
    }

    private void CancelExamCreation()
    {
        isCreatingExam = false;
        isEditingExam = false;
        editingExamId = null;
        ResetExamBuilder();
    }

    private void AddAnswerOption()
    {
        answerOptions.Add(string.Empty);
    }

    private string GetAnswerOptionValue(int index)
    {
        if (index < 0 || index >= answerOptions.Count)
        {
            return string.Empty;
        }

        return answerOptions[index];
    }

    private void UpdateAnswerOption(int index, string value)
    {
        if (index < 0 || index >= answerOptions.Count)
        {
            return;
        }

        answerOptions[index] = value;
    }

    private void RemoveAnswerOption(int index)
    {
        if (answerOptions.Count <= 2)
        {
            return;
        }

        answerOptions.RemoveAt(index);
        correctAnswerIndexes = correctAnswerIndexes
            .Where(i => i != index)
            .Select(i => i > index ? i - 1 : i)
            .ToHashSet();
    }

    private void SetSingleCorrectAnswer(int index)
    {
        correctAnswerIndexes.Clear();
        correctAnswerIndexes.Add(index);
    }

    private void ToggleCorrectAnswer(int index)
    {
        if (!correctAnswerIndexes.Add(index))
        {
            correctAnswerIndexes.Remove(index);
        }
    }

    private void BeginEditDraftQuestion(int index)
    {
        if (index < 0 || index >= draftQuestions.Count)
        {
            return;
        }

        var question = draftQuestions[index];
        questionType = question.QuestionType;
        questionText = question.QuestionText;
        answerOptions = question.Options.ToList();
        if (answerOptions.Count < 2)
        {
            answerOptions.Add(string.Empty);
        }

        correctAnswerIndexes = question.CorrectOptionIndexes.ToHashSet();
        draftQuestions.RemoveAt(index);
    }

    private void RemoveDraftQuestion(int index)
    {
        if (index < 0 || index >= draftQuestions.Count)
        {
            return;
        }

        draftQuestions.RemoveAt(index);
    }

    private void AddQuestionToDraft()
    {
        var validationError = ValidateCurrentQuestion();
        if (validationError != null)
        {
            SetExamStatus(validationError);
            return;
        }

        draftQuestions.Add(BuildCurrentQuestion());

        questionText = string.Empty;
        answerOptions = new List<string> { string.Empty, string.Empty };
        correctAnswerIndexes.Clear();
        questionType = "multiple-choice";
        SetExamStatus($"Question {draftQuestions.Count} added.");
    }

    private async Task SaveExamAsync()
    {
        if (string.IsNullOrWhiteSpace(examTitle))
        {
            SetExamStatus("Please enter an exam title.");
            return;
        }

        if (passingScorePercent is < 1 or > 100)
        {
            SetExamStatus("Passing score must be between 1 and 100.");
            return;
        }

        var allQuestions = draftQuestions.ToList();

        if (HasStartedCurrentQuestion())
        {
            var validationError = ValidateCurrentQuestion();
            if (validationError != null)
            {
                SetExamStatus(validationError);
                return;
            }

            allQuestions.Add(BuildCurrentQuestion());
        }

        if (!allQuestions.Any())
        {
            SetExamStatus("Add at least one question before saving.");
            return;
        }

        try
        {
            await TrainingDocumentService.SaveExamAsync(new TrainingExam
            {
                Id = editingExamId ?? string.Empty,
                Title = examTitle.Trim(),
                PassingScorePercent = passingScorePercent,
                Questions = allQuestions
            });

            await LoadExamsAsync();
            isCreatingExam = false;
            isEditingExam = false;
            editingExamId = null;
            SetExamStatus("Exam saved successfully.");
            ResetExamBuilder();
        }
        catch (Exception ex)
        {
            SetExamStatus($"Could not save exam: {ex.Message}");
        }
    }

    private bool HasStartedCurrentQuestion() =>
        !string.IsNullOrWhiteSpace(questionText)
        || answerOptions.Any(a => !string.IsNullOrWhiteSpace(a))
        || correctAnswerIndexes.Any();

    private async Task EditExamAsync(string examId)
    {
        var exam = await GetExamForEditAsync(examId);
        if (exam == null)
        {
            SetExamStatus("Could not load exam for editing.");
            return;
        }

        isCreatingExam = true;
        isEditingExam = true;
        editingExamId = exam.Id;

        examTitle = exam.Title;
        passingScorePercent = exam.PassingScorePercent;
        draftQuestions.Clear();
        draftQuestions.AddRange(exam.Questions.Select(q => new TrainingExamQuestion
        {
            QuestionType = q.QuestionType,
            QuestionText = q.QuestionText,
            Options = q.Options.ToList(),
            CorrectOptionIndexes = q.CorrectOptionIndexes.ToList()
        }));

        questionType = "multiple-choice";
        questionText = string.Empty;
        answerOptions = new List<string> { string.Empty, string.Empty };
        correctAnswerIndexes.Clear();
        SetExamStatus($"Editing exam: {exam.Title}");
    }

    private void PromptDeleteExam(string examId, string examTitleValue)
    {
        examPendingDeleteId = examId;
        examPendingDeleteTitle = examTitleValue;
        showDeleteExamModal = true;
    }

    private void CancelDeleteExam()
    {
        showDeleteExamModal = false;
        examPendingDeleteId = null;
        examPendingDeleteTitle = string.Empty;
    }

    private async Task ConfirmDeleteExamAsync()
    {
        if (string.IsNullOrWhiteSpace(examPendingDeleteId))
        {
            CancelDeleteExam();
            return;
        }

        await DeleteExamByIdAsync(examPendingDeleteId);
        await LoadExamsAsync();

        if (isEditingExam && editingExamId == examPendingDeleteId)
        {
            CancelExamCreation();
        }

        SetExamStatus("Exam deleted.");
        CancelDeleteExam();
    }

    private async Task<TrainingExam?> GetExamForEditAsync(string examId)
    {
        var getExamMethod = TrainingDocumentService.GetType().GetMethod("GetExamAsync");
        if (getExamMethod != null)
        {
            var methodTask = (Task<TrainingExam?>?)getExamMethod.Invoke(TrainingDocumentService, new object[] { examId });
            if (methodTask != null)
            {
                return await methodTask;
            }
        }

        SetExamStatus("Exam edit is unavailable until TrainingDocumentService.GetExamAsync is present.");
        return null;
    }

    private async Task DeleteExamByIdAsync(string examId)
    {
        var deleteExamMethod = TrainingDocumentService.GetType().GetMethod("DeleteExamAsync");
        if (deleteExamMethod != null)
        {
            var methodTask = (Task?)deleteExamMethod.Invoke(TrainingDocumentService, new object[] { examId });
            if (methodTask != null)
            {
                await methodTask;
                return;
            }
        }

        throw new InvalidOperationException("TrainingDocumentService.DeleteExamAsync is unavailable.");
    }

    private TrainingExamQuestion BuildCurrentQuestion() => new()
    {
        QuestionType = questionType,
        QuestionText = questionText.Trim(),
        Options = answerOptions.Select(a => a.Trim()).ToList(),
        CorrectOptionIndexes = correctAnswerIndexes.OrderBy(i => i).ToList()
    };

    private string? ValidateCurrentQuestion()
    {
        if (string.IsNullOrWhiteSpace(questionText))
        {
            return "Please enter a question.";
        }

        if (answerOptions.Count < 2 || answerOptions.Any(a => string.IsNullOrWhiteSpace(a)))
        {
            return "Please provide at least two possible answers and fill all answer fields.";
        }

        if (!correctAnswerIndexes.Any())
        {
            return "Please choose at least one correct answer.";
        }

        if (questionType == "multiple-choice" && correctAnswerIndexes.Count != 1)
        {
            return "Multiple choice questions must have exactly one correct answer.";
        }

        if (passingScorePercent is < 1 or > 100)
        {
            return "Passing score must be between 1 and 100.";
        }

        return null;
    }

    private void ResetExamBuilder()
    {
        examTitle = string.Empty;
        passingScorePercent = 80;
        questionType = "multiple-choice";
        questionText = string.Empty;
        answerOptions = new List<string> { string.Empty, string.Empty };
        correctAnswerIndexes.Clear();
        draftQuestions.Clear();
    }

    private void SetUploadStatus(string? message)
    {
        uploadStatus = message;

        uploadStatusCts?.Cancel();
        uploadStatusCts?.Dispose();

        if (string.IsNullOrWhiteSpace(message))
        {
            uploadStatusCts = null;
            return;
        }

        uploadStatusCts = new CancellationTokenSource();
        _ = AutoClearUploadStatusAsync(uploadStatusCts.Token);
    }

    private async Task AutoClearUploadStatusAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(3), token);
            await InvokeAsync(() =>
            {
                uploadStatus = null;
                StateHasChanged();
            });
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void SetExamStatus(string? message)
    {
        examStatusMessage = message;

        examStatusCts?.Cancel();
        examStatusCts?.Dispose();

        if (string.IsNullOrWhiteSpace(message))
        {
            examStatusCts = null;
            return;
        }

        examStatusCts = new CancellationTokenSource();
        _ = AutoClearExamStatusAsync(examStatusCts.Token);
    }

    private async Task AutoClearExamStatusAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(3), token);
            await InvokeAsync(() =>
            {
                examStatusMessage = null;
                StateHasChanged();
            });
        }
        catch (TaskCanceledException)
        {
        }
    }

    public void Dispose()
    {
        uploadStatusCts?.Cancel();
        uploadStatusCts?.Dispose();
        examStatusCts?.Cancel();
        examStatusCts?.Dispose();
        courseStatusCts?.Cancel();
        courseStatusCts?.Dispose();
    }

    private static string FormatFileSize(long? sizeInBytes)
    {
        if (sizeInBytes is null)
        {
            return "Unknown size";
        }

        var size = sizeInBytes.Value;
        if (size < 1024)
        {
            return $"{size} B";
        }

        var kb = size / 1024d;
        if (kb < 1024)
        {
            return $"{kb:F1} KB";
        }

        var mb = kb / 1024d;
        if (mb < 1024)
        {
            return $"{mb:F1} MB";
        }

        var gb = mb / 1024d;
        return $"{gb:F1} GB";
    }
