    private async Task<UserTrainingProfileViewModel> GetUserTrainingProfileDataAsync(string userId)
    {
        var fallback = new UserTrainingProfileViewModel { UserId = userId };

        var getTrainingProfileMethod = TrainingDocumentService.GetType().GetMethod("GetUserTrainingProfileAsync");
        if (getTrainingProfileMethod == null)
        {
            return fallback;
        }

        var methodTask = (Task?)getTrainingProfileMethod.Invoke(TrainingDocumentService, new object[] { userId });
        if (methodTask == null)
        {
            return fallback;
        }

        await methodTask;

        var resultProperty = methodTask.GetType().GetProperty("Result");
        var resultObject = resultProperty?.GetValue(methodTask);
        if (resultObject == null)
        {
            return fallback;
        }

        return MapTrainingProfile(resultObject, userId);
    }

    private static UserTrainingProfileViewModel MapTrainingProfile(object source, string userId)
    {
        var mapped = new UserTrainingProfileViewModel
        {
            UserId = ReadStringProperty(source, "UserId") ?? userId
        };

        mapped.ActiveAssignedLearning = ReadAssignments(source, "ActiveAssignedLearning");
        mapped.LearningHistory = ReadAssignments(source, "LearningHistory");

        return mapped;
    }

    private static List<UserLearningAssignmentViewModel> ReadAssignments(object source, string propertyName)
    {
        var prop = source.GetType().GetProperty(propertyName);
        var value = prop?.GetValue(source);
        if (value is not System.Collections.IEnumerable enumerable)
        {
            return new List<UserLearningAssignmentViewModel>();
        }

        var list = new List<UserLearningAssignmentViewModel>();
        foreach (var item in enumerable)
        {
            if (item == null)
            {
                continue;
            }

            list.Add(new UserLearningAssignmentViewModel
            {
                AssignmentId = ReadStringProperty(item, "AssignmentId") ?? string.Empty,
                Title = ReadStringProperty(item, "Title") ?? string.Empty,
                ItemType = ReadStringProperty(item, "ItemType") ?? string.Empty,
                BlobPath = ReadStringProperty(item, "BlobPath") ?? string.Empty,
                ContentType = ReadStringProperty(item, "ContentType"),
                AssignedAtUtc = ReadDateTimeOffsetProperty(item, "AssignedAtUtc"),
                CompletedAtUtc = ReadNullableDateTimeOffsetProperty(item, "CompletedAtUtc")
            });
        }

        return list;
    }

