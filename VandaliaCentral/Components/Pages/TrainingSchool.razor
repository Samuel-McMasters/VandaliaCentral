    private void AddCourseStep()
    {
        if (editingCourse == null)
        {
            return;
        }

        var newStep = new CourseStep
        {
            Id = Guid.NewGuid().ToString("N"),
            Order = editingCourse.Steps.Count + 1,
            Type = "Document",
            Required = true,
            Content = new CourseContentReference
            {
                BlobPath = courseDocumentBlobs.FirstOrDefault()?.BlobPath ?? string.Empty,
                ContentType = courseDocumentBlobs.FirstOrDefault()?.ContentType
            }
        };

        editingCourse.Steps.Add(newStep);
        NormalizeEditingStepOrder();
    }

    private void RemoveStep(string stepId)
    {
        if (editingCourse == null)
        {
            return;
        }

        editingCourse.Steps.RemoveAll(s => s.Id == stepId);
        NormalizeEditingStepOrder();
    }

    private void MoveStepUp(string stepId)
    {
        MoveStep(stepId, -1);
    }

    private void MoveStepDown(string stepId)
    {
        MoveStep(stepId, 1);
    }

    private void MoveStep(string stepId, int delta)
    {
        if (editingCourse == null)
        {
            return;
        }

        var ordered = editingCourse.Steps.OrderBy(s => s.Order).ToList();
        var index = ordered.FindIndex(s => s.Id == stepId);

        if (index < 0)
        {
            return;
        }

        var targetIndex = index + delta;
        if (targetIndex < 0 || targetIndex >= ordered.Count)
        {
            return;
        }

        (ordered[index], ordered[targetIndex]) = (ordered[targetIndex], ordered[index]);
        editingCourse.Steps = ordered;
        NormalizeEditingStepOrder();
    }

    private void NormalizeEditingStepOrder()
    {
        if (editingCourse == null)
        {
            return;
        }

        var ordered = editingCourse.Steps.OrderBy(s => s.Order).ToList();
        for (var i = 0; i < ordered.Count; i++)
        {
            if (string.IsNullOrWhiteSpace(ordered[i].Id))
            {
                ordered[i].Id = Guid.NewGuid().ToString("N");
            }

            ordered[i].Order = i + 1;
        }

        editingCourse.Steps = ordered;
    }

