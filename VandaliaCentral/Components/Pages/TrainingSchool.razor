@page "/training-school"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Graph
@using Microsoft.JSInterop
@using System.IO
@using System.Linq
@using System.Threading
@using System.Security.Claims
@using VandaliaCentral.Services
@layout VandaliaCentral.Components.Layout.TopBarLayout
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject TrainingDocumentService TrainingDocumentService
@inject CourseStorageService CourseStorageService
@inject GraphUserService GraphUserService
@inject LoggingService Logger
@inject NavigationManager NavigationManager

@attribute [Authorize]
@implements IDisposable

<PageTitle>Training School</PageTitle>

<div class="container-fluid px-3 px-md-4 px-xl-5 py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xxl-11">
            <div class="bg-white border rounded shadow-sm p-4 p-md-5">
                <h3 class="text-center mb-4">Training School</h3>

                @if (launchedAssignment != null)
                {
                    <div class="border rounded p-4 bg-light-subtle">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
                            <h4 class="mb-0">@launchedAssignment.Title</h4>
                            <a class="btn btn-outline-secondary btn-sm" href="/training-school" @onclick="ExitLaunchedAssignment">Back to Training School</a>
                        </div>

                        <div class="text-muted small mb-3">@GetAssignmentTypeLabel(launchedAssignment.ItemType)</div>

                        @if (launchedAssignment.ItemType.Equals("Course", StringComparison.OrdinalIgnoreCase) && launchedCourse != null)
                        {
                            var orderedSteps = launchedCourse.Steps.OrderBy(s => s.Order).ToList();

                            @if (!orderedSteps.Any())
                            {
                                <p class="text-muted mb-0">This course has no steps configured yet.</p>
                            }
                            else
                            {
                                var activeStep = orderedSteps[Math.Clamp(launchedCourseStepIndex, 0, orderedSteps.Count - 1)];

                                <div class="border rounded p-3 mb-3 bg-white">
                                    <div class="small text-muted mb-1">Step @activeStep.Order of @orderedSteps.Count</div>
                                    <h5 class="mb-2">@activeStep.Title</h5>

                                    @if (!string.IsNullOrWhiteSpace(activeStep.BodyText))
                                    {
                                        <p class="mb-2">@activeStep.BodyText</p>
                                    }

                                    <div class="small mb-2"><strong>Type:</strong> @activeStep.Type</div>

                                    @if (!string.IsNullOrWhiteSpace(activeStep.Content.BlobPath))
                                    {
                                        <div class="small mb-2"><strong>Content:</strong> @activeStep.Content.BlobPath</div>

                                        @if (!activeStep.Content.BlobPath.StartsWith("exams/", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <a class="btn btn-primary" href="@GetCourseContentUrl(activeStep.Content.BlobPath)" target="_blank" rel="noopener noreferrer">Open Step Content</a>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary mb-2">Exam step</span>

                                            @if (launchedCourseStepExam != null)
                                            {
                                                <div class="border rounded p-3 bg-light-subtle">
                                                    <h6 class="mb-1">@launchedCourseStepExam.Title</h6>
                                                    <div class="small text-muted mb-2">Passing score: @launchedCourseStepExam.PassingScorePercent% • @launchedCourseStepExam.Questions.Count question(s)</div>

                                                    @for (var examQuestionIndex = 0; examQuestionIndex < launchedCourseStepExam.Questions.Count; examQuestionIndex++)
                                                    {
                                                        var localQuestionIndex = examQuestionIndex;
                                                        var question = launchedCourseStepExam.Questions[localQuestionIndex];

                                                        <div class="border rounded p-2 bg-white mb-2">
                                                            <div class="fw-semibold mb-1">Question @(localQuestionIndex + 1)</div>
                                                            <div class="mb-2">@question.QuestionText</div>

                                                            @if (question.Options.Any())
                                                            {
                                                                @for (var optionIndex = 0; optionIndex < question.Options.Count; optionIndex++)
                                                                {
                                                                    var localOptionIndex = optionIndex;
                                                                    var optionValue = question.Options[localOptionIndex];

                                                                    <div class="form-check mb-1">
                                                                        @if (IsTrainingSchoolExamMultipleSelectQuestionV5(question))
                                                                        {
                                                                            <input class="form-check-input"
                                                                                   type="checkbox"
                                                                                   id="course-step-question-@localQuestionIndex-option-@localOptionIndex"
                                                                                   checked="@IsTrainingSchoolExamOptionSelectedV5(localQuestionIndex, localOptionIndex)"
                                                                                   @onchange="(ChangeEventArgs e) => SetTrainingSchoolExamOptionV5(localQuestionIndex, localOptionIndex, e.Value)" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <input class="form-check-input"
                                                                                   type="radio"
                                                                                   name="course-step-question-@localQuestionIndex"
                                                                                   id="course-step-question-@localQuestionIndex-option-@localOptionIndex"
                                                                                   checked="@IsTrainingSchoolExamOptionSelectedV5(localQuestionIndex, localOptionIndex)"
                                                                                   @onchange="() => SetTrainingSchoolExamSingleAnswerV5(localQuestionIndex, localOptionIndex)" />
                                                                        }
                                                                        <label class="form-check-label" for="course-step-question-@localQuestionIndex-option-@localOptionIndex">@optionValue</label>
                                                                    </div>
                                                                }
                                                            }
                                                        </div>
                                                    }

                                                    <button class="btn btn-primary btn-sm" type="button" @onclick="() => SubmitTrainingSchoolExamAttemptV5(launchedCourseStepExam)">Submit Exam</button>
                                                </div>
                                            }
                                            else
                                            {
                                                <p class="text-muted mb-0">Unable to load this exam step.</p>
                                            }
                                        }
                                    }
                                </div>

                                <div class="d-flex justify-content-between align-items-center gap-2">
                                    <button class="btn btn-outline-secondary" type="button" @onclick="LaunchedCoursePreviousStep" disabled="@(launchedCourseStepIndex <= 0)">Previous</button>
                                    <button class="btn btn-outline-secondary" type="button" @onclick="LaunchedCourseNextStep" disabled="@(launchedCourseStepIndex >= launchedCourse.Steps.Count - 1)">Next</button>
                                </div>
                            }
                        }
                        else if (launchedExam != null)
                        {
                            <div class="border rounded p-3 bg-white">
                                <h5 class="mb-1">@launchedExam.Title</h5>
                                <div class="small text-muted mb-3">Passing score: @launchedExam.PassingScorePercent% • @launchedExam.Questions.Count question(s)</div>

                                @for (var examQuestionIndex = 0; examQuestionIndex < launchedExam.Questions.Count; examQuestionIndex++)
                                {
                                    var localQuestionIndex = examQuestionIndex;
                                    var question = launchedExam.Questions[localQuestionIndex];

                                    <div class="border rounded p-3 mb-3 bg-light-subtle">
                                        <div class="fw-semibold mb-1">Question @(localQuestionIndex + 1)</div>
                                        <div class="mb-2">@question.QuestionText</div>

                                        @if (question.Options.Any())
                                        {
                                            @for (var optionIndex = 0; optionIndex < question.Options.Count; optionIndex++)
                                            {
                                                var localOptionIndex = optionIndex;
                                                var optionValue = question.Options[localOptionIndex];

                                                <div class="form-check mb-1">
                                                    @if (IsTrainingSchoolExamMultipleSelectQuestionV5(question))
                                                    {
                                                        <input class="form-check-input"
                                                               type="checkbox"
                                                               id="assignment-question-@localQuestionIndex-option-@localOptionIndex"
                                                               checked="@IsTrainingSchoolExamOptionSelectedV5(localQuestionIndex, localOptionIndex)"
                                                               @onchange="(ChangeEventArgs e) => SetTrainingSchoolExamOptionV5(localQuestionIndex, localOptionIndex, e.Value)" />
                                                    }
                                                    else
                                                    {
                                                        <input class="form-check-input"
                                                               type="radio"
                                                               name="assignment-question-@localQuestionIndex"
                                                               id="assignment-question-@localQuestionIndex-option-@localOptionIndex"
                                                               checked="@IsTrainingSchoolExamOptionSelectedV5(localQuestionIndex, localOptionIndex)"
                                                               @onchange="() => SetTrainingSchoolExamSingleAnswerV5(localQuestionIndex, localOptionIndex)" />
                                                    }
                                                    <label class="form-check-label" for="assignment-question-@localQuestionIndex-option-@localOptionIndex">@optionValue</label>
                                                </div>
                                            }
                                        }
                                    </div>
                                }

                                <button class="btn btn-primary" type="button" @onclick="() => SubmitTrainingSchoolExamAttemptV5(launchedExam)">Submit Exam</button>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(launchedAssignment.BlobPath) && launchedAssignment.BlobPath.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase))
                        {
                            <video class="w-100 rounded border"
                                   controls
                                   style="max-height: 80vh;">
                                <source src="@GetCourseContentUrl(launchedAssignment.BlobPath)" type="@(launchedAssignment.ContentType ?? "video/mp4")" />
                            </video>

                            <div class="mt-3">
                                <button class="btn btn-success"
                                        type="button"
                                        disabled="@isCompletingLaunchedVideo"
                                        @onclick="MarkLaunchedVideoCompleteAsync">
                                    @(isCompletingLaunchedVideo ? "Completing..." : "Mark Complete")
                                </button>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(launchedAssignment.BlobPath) && launchedAssignment.BlobPath.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                        {
                            <iframe class="w-100 border rounded bg-white" style="height: 80vh;" src="@GetCourseContentUrl(launchedAssignment.BlobPath)"></iframe>
                        }
                        else if (!string.IsNullOrWhiteSpace(launchedAssignment.BlobPath) && !launchedAssignment.BlobPath.StartsWith("exams/", StringComparison.OrdinalIgnoreCase))
                        {
                            <a class="btn btn-primary" href="@GetCourseContentUrl(launchedAssignment.BlobPath)" target="_blank" rel="noopener noreferrer">Open Assigned Item</a>
                        }
                        else
                        {
                            <p class="text-muted mb-0">Exam launch view is coming soon for this assigned item.</p>
                        }
                    </div>

                    @if (showExamResultModal && IsTrainingSchoolExamLaunchContextV5())
                    {
                        <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-hidden="false">
                            <div class="modal-dialog modal-dialog-centered" role="document">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">@examResultModalTitle</h5>
                                        <button type="button" class="btn-close" aria-label="Close" @onclick="() => CloseTrainingSchoolExamResultModalV5()"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p class="mb-0">@examResultModalMessage</p>
                                    </div>
                                    <div class="modal-footer">
                                        @if (!examResultPassed)
                                        {
                                            <button class="btn btn-outline-secondary" type="button" @onclick="() => RetakeTrainingSchoolExamV5Async()">Retake Exam</button>
                                        }
                                        <button class="btn @(examResultPassed ? "btn-success" : "btn-primary")" type="button" @onclick="() => HandleTrainingSchoolExamPrimaryActionV5Async()">OK</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-backdrop fade show"></div>
                    }
                }
                else
                {
                    <ul class="nav nav-pills nav-fill flex-column flex-md-row gap-2 justify-content-center mb-4">
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "my-courses" ? "active" : "")" @onclick='() => SetActiveTab("my-courses")'>My Courses</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "all-courses" ? "active" : "")" @onclick='() => SetActiveTab("all-courses")'>All Courses</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "course-history" ? "active" : "")" @onclick='() => SetActiveTab("course-history")'>Course History</button>
                        </li>
                        @if (IsTrainer)
                        {
                            <li class="nav-item">
                                <button class="nav-link @(activeTab == "trainer-tools" ? "active" : "")" @onclick='() => SetActiveTab("trainer-tools")'>Trainer Tools</button>
                            </li>
                        }
                    </ul>

                    <div class="border rounded p-4 bg-light-subtle">
                        @if (activeTab == "my-courses")
                        {
                            <h5 class="mb-3">My Assigned Learning</h5>

                            @if (myTrainingProfile == null)
                            {
                                <p class="text-muted mb-0">Loading your assigned learning...</p>
                            }
                            else if (!myTrainingProfile.ActiveAssignedLearning.Any())
                            {
                                <p class="text-muted mb-0">You do not have any assigned learning yet.</p>
                            }
                            else
                            {
                                <ul class="list-group" style="max-width: 1000px;">
                                    @foreach (var assignment in myTrainingProfile.ActiveAssignedLearning.OrderByDescending(a => a.AssignedAtUtc))
                                    {
                                        <li class="list-group-item">
                                            <div class="fw-semibold text-break">@assignment.Title</div>
                                            <div class="small text-muted">@GetAssignmentTypeLabel(assignment.ItemType) • Assigned @assignment.AssignedAtUtc.LocalDateTime.ToString("g")</div>
                                            <button class="btn btn-sm btn-primary mt-2" type="button" @onclick='() => BeginAssignment(assignment)'>Begin</button>
                                        </li>
                                    }
                                </ul>
                            }
                        }
                        else if (activeTab == "all-courses")
                        {
                            <p class="mb-0">All Courses content is coming soon.</p>
                        }
                        else if (activeTab == "course-history")
                        {
                            <p class="mb-0">Course History content is coming soon.</p>
                        }
                        else if (activeTab == "trainer-tools" && IsTrainer)
                        {
                            <h5 class="mb-3">Trainer Tools</h5>

                            <ul class="nav nav-tabs mb-4">
                                <li class="nav-item">
                                    <button class='nav-link @(trainerToolTab == "documents" ? "active" : "")' @onclick='() => SetTrainerToolTab("documents")'>Documents</button>
                                </li>
                                <li class="nav-item">
                                    <button class='nav-link @(trainerToolTab == "courses" ? "active" : "")' @onclick='() => SetTrainerToolTab("courses")'>Courses</button>
                                </li>
                                <li class="nav-item">
                                    <button class='nav-link @(trainerToolTab == "exams" ? "active" : "")' @onclick='() => SetTrainerToolTab("exams")'>Exams</button>
                                </li>
                                <li class="nav-item">
                                    <button class='nav-link @(trainerToolTab == "users" ? "active" : "")' @onclick='() => SetTrainerToolTab("users")'>Users</button>
                                </li>
                            </ul>

                            @if (trainerToolTab == "documents")
                            {
                                <div class="d-flex flex-wrap gap-3 align-items-center mb-3">
                                    <label class="btn btn-primary text-nowrap mb-0">
                                        Upload Document or Video
                                        <InputFile OnChange="HandleTrainingFileUpload" accept=".pdf,.mp4" class="d-none" />
                                    </label>
                                    @if (!string.IsNullOrWhiteSpace(uploadStatus))
                                    {
                                        <span class="badge bg-secondary fs-6">@uploadStatus</span>
                                    }
                                </div>

                                <div class="mb-3" style="max-width: 460px;">
                                    <input type="search"
                                           class="form-control"
                                           placeholder="Search training documents..."
                                           @bind="trainingDocumentSearchTerm"
                                           @bind:event="oninput" />
                                </div>

                                @if (trainingDocuments == null)
                                {
                                    <p>Loading training documents...</p>
                                }
                                else if (!FilteredTrainingDocuments.Any())
                                {
                                    if (!string.IsNullOrWhiteSpace(trainingDocumentSearchTerm))
                                    {
                                        <p class="text-muted mb-0">No training documents matched your search.</p>
                                    }
                                    else
                                    {
                                        <p class="text-muted mb-0">No training documents or videos uploaded yet.</p>
                                    }
                                }
                                else
                                {
                                    <ul class="list-group" style="max-width: 1000px;">
                                        @foreach (var doc in FilteredTrainingDocuments)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center gap-3 flex-wrap">
                                                <div>
                                                    <div class="fw-semibold text-break">@doc.FileName</div>
                                                    <div class="text-muted small">@FormatFileSize(doc.SizeInBytes) • @(doc.LastModified?.LocalDateTime.ToString("g") ?? "Unknown")</div>
                                                </div>
                                                <div class="d-flex gap-2 flex-wrap">
                                                    <a class="btn btn-sm btn-outline-primary" href="@doc.Url" target="_blank" rel="noopener noreferrer">View</a>
                                                    <a class="btn btn-sm btn-primary" href="@($"/api/training-documents/download?fileName={Uri.EscapeDataString(doc.FileName)}")">Download</a>
                                                    <button class="btn btn-sm btn-danger" @onclick='() => DeleteTrainingDocument(doc.FileName)'>Delete</button>
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                }
                            }
                            else if (trainerToolTab == "courses")
                            {
                                @if (!string.IsNullOrWhiteSpace(courseStatusMessage))
                                {
                                    <div class="alert alert-info py-2">@courseStatusMessage</div>
                                }

                                <div class="row g-4 align-items-start">
                                    <div class="col-12 col-xl-4">
                                        <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                                            <h6 class="mb-0">Courses</h6>
                                            <button class="btn btn-primary btn-sm" type="button" @onclick="CreateCourseDraft">Create Course</button>
                                        </div>

                                        @if (isLoadingCourses)
                                        {
                                            <p class="text-muted mb-0">Loading courses...</p>
                                        }
                                        else if (!courses.Any())
                                        {
                                            <p class="text-muted mb-0">No courses found. Create your first course.</p>
                                        }
                                        else
                                        {
                                            <ul class="list-group">
                                                @foreach (var course in courses)
                                                {
                                                    <li class='list-group-item @(editingCourse?.Id == course.Id ? "active" : "")'>
                                                        <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                                            <div>
                                                                <div class="fw-semibold text-break">@course.Title</div>
                                                                <div class="small @(editingCourse?.Id == course.Id ? "text-white" : "text-muted")">
                                                                    @(course.IsPublished ? "Published" : "Draft") • @course.UpdatedAtUtc.LocalDateTime.ToString("g")
                                                                </div>
                                                            </div>
                                                            <div class="d-flex gap-1">
                                                                <button class='btn btn-sm @(editingCourse?.Id == course.Id ? "btn-light" : "btn-outline-primary")' type="button" @onclick='async () => await EditCourseAsync(course.Id)'>Edit</button>
                                                                <button class='btn btn-sm @(viewingCourse?.Id == course.Id ? "btn-light" : "btn-outline-secondary")' type="button" @onclick='async () => await ViewCourseAsync(course.Id)'>View</button>
                                                                <button class='btn btn-sm @(editingCourse?.Id == course.Id ? "btn-warning" : "btn-outline-danger")' type="button" @onclick='async () => await DeleteCourseAsync(course.Id)'>Delete</button>
                                                            </div>
                                                        </div>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </div>

                                    <div class="col-12 col-xl-8">
                                        <h6 class="mb-2">Course Editor</h6>
                                        <div class="border rounded bg-white p-3">
                                            @if (viewingCourse != null)
                                            {
                                                <div class="d-flex justify-content-between align-items-start mb-3 gap-2 flex-wrap">
                                                    <div>
                                                        <h5 class="mb-1">@viewingCourse.Title</h5>
                                                        @if (!string.IsNullOrWhiteSpace(viewingCourse.Description))
                                                        {
                                                            <p class="text-muted mb-0">@viewingCourse.Description</p>
                                                        }
                                                    </div>
                                                    <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="CloseCourseView">Close</button>
                                                </div>

                                                @if (!viewingCourse.Steps.Any())
                                                {
                                                    <p class="text-muted mb-0">This course has no steps configured yet.</p>
                                                }
                                                else
                                                {
                                                    var orderedSteps = viewingCourse.Steps.OrderBy(s => s.Order).ToList();
                                                    var activeStep = orderedSteps[Math.Clamp(viewingCourseStepIndex, 0, orderedSteps.Count - 1)];

                                                    <div class="border rounded p-3 mb-3 bg-light-subtle">
                                                        <div class="small text-muted mb-1">Step @activeStep.Order of @orderedSteps.Count</div>
                                                        <h6 class="mb-2">@activeStep.Title</h6>

                                                        @if (!string.IsNullOrWhiteSpace(activeStep.BodyText))
                                                        {
                                                            <p class="mb-2">@activeStep.BodyText</p>
                                                        }

                                                        <div class="small mb-2"><strong>Type:</strong> @activeStep.Type</div>

                                                        @if (!string.IsNullOrWhiteSpace(activeStep.Content.BlobPath))
                                                        {
                                                            <div class="small mb-2"><strong>Content:</strong> @activeStep.Content.BlobPath</div>
                                                            @if (activeStep.Content.BlobPath.StartsWith("exams/", StringComparison.OrdinalIgnoreCase))
                                                            {
                                                                <span class="badge text-bg-secondary">Exam step</span>
                                                            }
                                                            else
                                                            {
                                                                <a class="btn btn-sm btn-outline-primary" href="@GetCourseContentUrl(activeStep.Content.BlobPath)" target="_blank" rel="noopener noreferrer">Open Content</a>
                                                            }
                                                        }
                                                    </div>

                                                    <div class="d-flex justify-content-between align-items-center gap-2">
                                                        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="ViewPreviousCourseStep" disabled="@(viewingCourseStepIndex <= 0)">Previous</button>
                                                        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="ViewNextCourseStep" disabled="@(viewingCourseStepIndex >= orderedSteps.Count - 1)">Next</button>
                                                    </div>
                                                }
                                            }
                                            else if (editingCourse == null)
                                            {
                                                <p class="text-muted mb-0">Select a course to edit or create a new course.</p>
                                            }
                                            else
                                            {
                                                <div class="row g-3 mb-3">
                                                    <div class="col-12">
                                                        <label class="form-label">Title</label>
                                                        <input class="form-control" @bind="editingCourse.Title" />
                                                    </div>
                                                    <div class="col-12">
                                                        <label class="form-label">Description</label>
                                                        <textarea class="form-control" rows="3" @bind="editingCourse.Description"></textarea>
                                                    </div>
                                                    <div class="col-12">
                                                        <div class="form-check form-switch">
                                                            <input class="form-check-input" type="checkbox" role="switch" @bind="editingCourse.IsPublished" />
                                                            <label class="form-check-label">Published</label>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                                                    <h6 class="mb-0">Steps</h6>
                                                    <button class="btn btn-outline-primary btn-sm" type="button" @onclick="AddCourseStep">Add Step</button>
                                                </div>

                                                @if (!editingCourse.Steps.Any())
                                                {
                                                    <p class="text-muted mb-3">No steps yet. Add one to get started.</p>
                                                }
                                                else
                                                {
                                                    <div class="d-flex flex-column gap-3 mb-3">
                                                        @foreach (var step in editingCourse.Steps.OrderBy(s => s.Order))
                                                        {
                                                            var currentStep = step;

                                                            <div class="border rounded p-3 bg-light-subtle">
                                                                <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-2">
                                                                    <div class="fw-semibold">Step @currentStep.Order</div>
                                                                    <div class="d-flex gap-1">
                                                                        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick='() => MoveStepUp(currentStep.Id)'>Up</button>
                                                                        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick='() => MoveStepDown(currentStep.Id)'>Down</button>
                                                                        <button class="btn btn-sm btn-outline-danger" type="button" @onclick='() => RemoveStep(currentStep.Id)'>Delete</button>
                                                                    </div>
                                                                </div>

                                                                <div class="row g-3">
                                                                    <div class="col-12 col-md-6">
                                                                        <label class="form-label">Step Title</label>
                                                                        <input class="form-control" @bind="currentStep.Title" />
                                                                    </div>
                                                                    <div class="col-12 col-md-6">
                                                                        <label class="form-label">Type</label>
                                                                        <select class="form-select" value="@currentStep.Type" @onchange='(e) => OnStepTypeChanged(currentStep, e.Value?.ToString())'>
                                                                            <option value="Document">Document</option>
                                                                            <option value="Video">Video</option>
                                                                            <option value="Exam">Exam</option>
                                                                        </select>
                                                                    </div>
                                                                    <div class="col-12">
                                                                        <label class="form-label">Additional Text</label>
                                                                        <textarea class="form-control" rows="2" @bind="currentStep.BodyText"></textarea>
                                                                    </div>
                                                                    <div class="col-12">
                                                                        <label class="form-label">Content</label>
                                                                        <select class="form-select" value="@currentStep.Content.BlobPath" @onchange='(e) => OnStepContentChanged(currentStep, e.Value?.ToString())'>
                                                                            <option value="">Select content...</option>
                                                                            @foreach (var option in GetStepContentOptions(currentStep.Type))
                                                                            {
                                                                                <option value="@option.BlobPath">@option.DisplayName</option>
                                                                            }
                                                                        </select>
                                                                    </div>
                                                                    <div class="col-12">
                                                                        <div class="form-check">
                                                                            <input class="form-check-input" type="checkbox" @bind="currentStep.Required" />
                                                                            <label class="form-check-label">Required</label>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }

                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-primary" type="button" @onclick="SaveCourseAsync">Save Course</button>
                                                    <button class="btn btn-outline-secondary" type="button" @onclick="CancelCourseEditing">Cancel</button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                            else if (trainerToolTab == "users")
                            {
                                <div class="mb-3" style="max-width: 460px;">
                                    <input type="search"
                                           class="form-control"
                                           placeholder="Search users..."
                                           @bind="userSearchTerm"
                                           @bind:event="oninput" />
                                </div>

                                <div class="row g-4 align-items-start">
                                    <div class="col-12 col-xl-7">
                                        <h6 class="mb-2">All Users</h6>
                                        @if (entraUsers == null)
                                        {
                                            <p>Loading users...</p>
                                        }
                                        else if (!FilteredEntraUsers.Any())
                                        {
                                            if (!string.IsNullOrWhiteSpace(userSearchTerm))
                                            {
                                                <p class="text-muted mb-0">No users matched your search.</p>
                                            }
                                            else
                                            {
                                                <p class="text-muted mb-0">No users were returned from Entra.</p>
                                            }
                                        }
                                        else
                                        {
                                            <ul class="list-group" style="max-width: 1000px;">
                                                @foreach (var user in FilteredEntraUsers)
                                                {
                                                    <li class='list-group-item list-group-item-action @(selectedUserId == user.Id ? "active" : "")'
                                                        style="cursor: pointer;"
                                                        @onclick='async () => await SelectUserAsync(user)'>
                                                        <div class="fw-semibold text-break">@(user.DisplayName ?? "Unknown")</div>
                                                        <div class="small text-muted text-break">@(user.Mail ?? user.UserPrincipalName ?? "No email")</div>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </div>

                                    <div class="col-12 col-xl-5">
                                        <h6 class="mb-2">User Training Profile</h6>
                                        <div class="border rounded bg-white p-3">
                                            @if (isLoadingSelectedUserProfile)
                                            {
                                                <p class="text-muted mb-0">Loading user profile...</p>
                                            }
                                            else if (selectedUserProfile == null)
                                            {
                                                <p class="text-muted mb-0">Select a user from the list to view their training profile.</p>
                                            }
                                            else
                                            {
                                                <div class="d-flex flex-wrap gap-2 mb-3">
                                                    <button class="btn btn-primary btn-sm" type="button" @onclick="OpenAssignLearningWindow">Assign Learning</button>
                                                    <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="CloseSelectedUserProfile">Close</button>
                                                </div>

                                                <div class="mb-3">
                                                    <div><strong>Name:</strong> @(selectedUserProfile.DisplayName ?? "Unknown")</div>
                                                    <div><strong>Email:</strong> @(selectedUserProfile.Mail ?? selectedUserProfile.UserPrincipalName ?? "No email")</div>
                                                    <div><strong>Office Location:</strong> @(selectedUserProfile.OfficeLocation ?? "Not set")</div>
                                                </div>

                                                <div class="mb-3">
                                                    <h6 class="mb-2">Active Assigned Learning</h6>
                                                    @if (selectedUserTrainingProfile == null || !selectedUserTrainingProfile.ActiveAssignedLearning.Any())
                                                    {
                                                        <p class="text-muted mb-0">No active learning assignments.</p>
                                                    }
                                                    else
                                                    {
                                                        <ul class="list-group">
                                                            @foreach (var assignment in selectedUserTrainingProfile.ActiveAssignedLearning)
                                                            {
                                                                <li class="list-group-item">
                                                                    <div class="fw-semibold text-break">@assignment.Title</div>
                                                                    <div class="small text-muted">@GetAssignmentTypeLabel(assignment.ItemType) • Assigned @assignment.AssignedAtUtc.LocalDateTime.ToString("g")</div>
                                                                </li>
                                                            }
                                                        </ul>
                                                    }
                                                </div>

                                                <div>
                                                    <h6 class="mb-2">Learning History</h6>
                                                    @if (selectedUserTrainingProfile == null || !selectedUserTrainingProfile.LearningHistory.Any())
                                                    {
                                                        <p class="text-muted mb-0">No completed learning history.</p>
                                                    }
                                                    else
                                                    {
                                                        <ul class="list-group">
                                                            @foreach (var history in selectedUserTrainingProfile.LearningHistory)
                                                            {
                                                                <li class="list-group-item">
                                                                    <div class="fw-semibold text-break">@history.Title</div>
                                                                    <div class="small text-muted">@GetAssignmentTypeLabel(history.ItemType) • Completed @(history.CompletedAtUtc?.LocalDateTime.ToString("g") ?? "Unknown")</div>
                                                                </li>
                                                            }
                                                        </ul>
                                                    }
                                                </div>
                                            }
                                        </div>

                                        <div class="mt-3">
                                            <h6 class="mb-2">Active Users</h6>
                                            <div class="border rounded bg-white p-3">
                                                <p class="text-muted mb-0">Users with assigned learning will appear here.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="modal fade @(showAssignLearningModal ? "show d-block" : "")"
                                     style="@(showAssignLearningModal ? "display:block;" : "display:none;")"
                                     tabindex="-1"
                                     role="dialog"
                                     aria-modal="true"
                                     aria-hidden="@(!showAssignLearningModal)">
                                    <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Assign Learning</h5>
                                                <button type="button" class="btn-close" aria-label="Close" @onclick="CloseAssignLearningWindow"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p class="text-muted">Select an item from Courses, Documents, or Exams to assign to <strong>@(selectedUserProfile?.DisplayName ?? "selected user")</strong>.</p>

                                                <div class="row g-3">
                                                    <div class="col-12 col-lg-4">
                                                        <h6>Courses</h6>
                                                        <input class="form-control form-control-sm mb-2" type="search" placeholder="Search courses..." @bind="assignCourseSearchTerm" @bind:event="oninput" />
                                                        <ul class="list-group" style="max-height: 300px; overflow-y: auto;">
                                                            @foreach (var item in FilteredAssignableCourses)
                                                            {
                                                                <li class='list-group-item list-group-item-action @(selectedAssignableItem?.BlobPath == item.BlobPath ? "active" : "")' style="cursor:pointer;" @onclick='() => SelectAssignableItem(item)'>
                                                                    <div class="fw-semibold text-break">@item.Title</div>
                                                                </li>
                                                            }
                                                        </ul>
                                                    </div>

                                                    <div class="col-12 col-lg-4">
                                                        <h6>Documents</h6>
                                                        <input class="form-control form-control-sm mb-2" type="search" placeholder="Search documents..." @bind="assignDocumentSearchTerm" @bind:event="oninput" />
                                                        <ul class="list-group" style="max-height: 300px; overflow-y: auto;">
                                                            @foreach (var item in FilteredAssignableDocuments)
                                                            {
                                                                <li class='list-group-item list-group-item-action @(selectedAssignableItem?.BlobPath == item.BlobPath ? "active" : "")' style="cursor:pointer;" @onclick='() => SelectAssignableItem(item)'>
                                                                    <div class="fw-semibold text-break">@item.Title</div>
                                                                </li>
                                                            }
                                                        </ul>
                                                    </div>

                                                    <div class="col-12 col-lg-4">
                                                        <h6>Exams</h6>
                                                        <input class="form-control form-control-sm mb-2" type="search" placeholder="Search exams..." @bind="assignExamSearchTerm" @bind:event="oninput" />
                                                        <ul class="list-group" style="max-height: 300px; overflow-y: auto;">
                                                            @foreach (var item in FilteredAssignableExams)
                                                            {
                                                                <li class='list-group-item list-group-item-action @(selectedAssignableItem?.BlobPath == item.BlobPath ? "active" : "")' style="cursor:pointer;" @onclick='() => SelectAssignableItem(item)'>
                                                                    <div class="fw-semibold text-break">@item.Title</div>
                                                                </li>
                                                            }
                                                        </ul>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button class="btn btn-outline-secondary" type="button" @onclick="CloseAssignLearningWindow">Close</button>
                                                <button class="btn btn-primary" type="button" @onclick="AssignSelectedLearningAsync" disabled="@(selectedAssignableItem == null)">Assign Selected</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-backdrop fade @(showAssignLearningModal ? "show" : "")"
                                     style="@(showAssignLearningModal ? "display:block;" : "display:none;")"></div>
                            }
                            else if (trainerToolTab == "exams")
                            {
                                <div class="d-flex justify-content-start mb-2">
                                    <button class="btn btn-primary" type="button" @onclick="StartExamCreation">Create Exam</button>
                                </div>
                                <h6 class="mb-3">Created Exams</h6>

                                @if (!string.IsNullOrWhiteSpace(examStatusMessage))
                                {
                                    <div class="alert alert-info py-2">@examStatusMessage</div>
                                }

                                @if (isCreatingExam)
                                {
                                    <div class="border rounded bg-white p-3 mb-4">
                                        <h6 class="mb-3">@(isEditingExam ? "Edit Exam" : "Exam Creator")</h6>

                                        <div class="row g-3 mb-3">
                                            <div class="col-12 col-md-8">
                                                <label class="form-label">Exam Title</label>
                                                <input class="form-control" @bind="examTitle" />
                                            </div>
                                            <div class="col-12 col-md-4">
                                                <label class="form-label">Passing Score (%)</label>
                                                <input class="form-control" type="number" min="1" max="100" @bind="passingScorePercent" />
                                            </div>
                                        </div>

                                        <div class="border rounded p-3">
                                            <div class="row g-3 mb-3">
                                                <div class="col-12 col-md-4">
                                                    <label class="form-label">Question Type</label>
                                                    <select class="form-select" @bind="questionType">
                                                        <option value="multiple-choice">Multiple Choice</option>
                                                        <option value="multiple-select">Multiple Select</option>
                                                    </select>
                                                </div>
                                                <div class="col-12 col-md-8">
                                                    <label class="form-label">Question</label>
                                                    <input class="form-control" @bind="questionText" />
                                                </div>
                                            </div>

                                            <label class="form-label">Possible Answers</label>
                                            @for (var i = 0; i < answerOptions.Count; i++)
                                            {
                                                var optionIndex = i;

                                                <div class="d-flex align-items-center gap-2 mb-2" @key="optionIndex">
                                                    @if (questionType == "multiple-choice")
                                                    {
                                                        <input class="form-check-input" type="radio" name="correctAnswer" checked="@(correctAnswerIndexes.Contains(optionIndex))" @onchange="() => SetSingleCorrectAnswer(optionIndex)" />
                                                    }
                                                    else
                                                    {
                                                        <input class="form-check-input" type="checkbox" checked="@(correctAnswerIndexes.Contains(optionIndex))" @onchange="() => ToggleCorrectAnswer(optionIndex)" />
                                                    }
                                                    <input class="form-control"
                                                           value="@GetAnswerOptionValue(optionIndex)"
                                                           @oninput='(ChangeEventArgs e) => UpdateAnswerOption(optionIndex, e.Value?.ToString() ?? string.Empty)' />
                                                    <button class="btn btn-outline-danger btn-sm" type="button" @onclick='() => RemoveAnswerOption(optionIndex)' disabled="@(answerOptions.Count <= 2)">Remove</button>
                                                </div>
                                            }

                                            <button class="btn btn-outline-secondary btn-sm mb-3" type="button" @onclick="AddAnswerOption">Add Possible Answer</button>

                                            <div class="d-flex flex-wrap gap-2">
                                                <button class="btn btn-outline-primary" type="button" @onclick="AddQuestionToDraft">Add Another Question</button>
                                                <button class="btn btn-success" type="button" @onclick="SaveExamAsync">@(isEditingExam ? "Save Changes" : "Save / Finish")</button>
                                                <button class="btn btn-outline-secondary" type="button" @onclick="CancelExamCreation">Cancel</button>
                                            </div>
                                        </div>

                                        @if (draftQuestions.Any())
                                        {
                                            <div class="mt-3">
                                                <strong>Questions Added:</strong> @draftQuestions.Count
                                            </div>

                                            <ul class="list-group mt-2">
                                                @for (var qIndex = 0; qIndex < draftQuestions.Count; qIndex++)
                                                {
                                                    var question = draftQuestions[qIndex];
                                                    var localIndex = qIndex;

                                                    <li class="list-group-item d-flex justify-content-between align-items-center gap-2 flex-wrap" @key="localIndex">
                                                        <div class="text-break">
                                                            <div class="fw-semibold">Question @(localIndex + 1): @question.QuestionText</div>
                                                            <div class="small text-muted">@question.QuestionType • @question.Options.Count option(s)</div>
                                                        </div>
                                                        <div class="d-flex gap-2">
                                                            <button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => BeginEditDraftQuestion(localIndex)">Edit</button>
                                                            <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => RemoveDraftQuestion(localIndex)">Delete</button>
                                                        </div>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                }

                                @if (exams == null)
                                {
                                    <p>Loading exams...</p>
                                }
                                else if (!exams.Any())
                                {
                                    <p class="text-muted mb-0">No exams created yet.</p>
                                }
                                else
                                {
                                    <ul class="list-group" style="max-width: 1000px;">
                                        @foreach (var exam in exams)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center gap-3 flex-wrap">
                                                <div>
                                                    <div class="fw-semibold text-break">@exam.Title</div>
                                                    <div class="small text-muted">
                                                        @exam.QuestionCount question(s) • Passing Score: @exam.PassingScorePercent% • Created @exam.CreatedAtUtc.LocalDateTime.ToString("g")
                                                    </div>
                                                </div>
                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-sm btn-outline-primary" type="button" @onclick='() => EditExamAsync(exam.Id)'>Edit</button>
                                                    <button class="btn btn-sm btn-outline-danger" type="button" @onclick='() => PromptDeleteExam(exam.Id, exam.Title)'>Delete</button>
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                }

                                <div class="modal fade @(showDeleteExamModal ? "show d-block" : "")"
                                     style="@(showDeleteExamModal ? "display:block;" : "display:none;")"
                                     tabindex="-1"
                                     role="dialog"
                                     aria-modal="true"
                                     aria-hidden="@(!showDeleteExamModal)">
                                    <div class="modal-dialog modal-dialog-centered" role="document">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Delete Exam</h5>
                                                <button type="button" class="btn-close" aria-label="Close" @onclick="CancelDeleteExam"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p class="mb-0">You are about to delete <strong>@examPendingDeleteTitle</strong>. This action cannot be undone.</p>
                                            </div>
                                            <div class="modal-footer">
                                                <button class="btn btn-outline-secondary" type="button" @onclick="CancelDeleteExam">Cancel</button>
                                                <button class="btn btn-danger" type="button" @onclick="ConfirmDeleteExamAsync">Delete Exam</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-backdrop fade @(showDeleteExamModal ? "show" : "")"
                                     style="@(showDeleteExamModal ? "display:block;" : "display:none;")"></div>
                            }
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "assignment")]
    public string? AssignmentLaunchId { get; set; }

    private const string TrainerGroupId = "4cdf9c87-afca-460d-a807-edaa90221d84";
    private bool IsTrainer;
    private string activeTab = "my-courses";
    private string trainerToolTab = "documents";
    private string? uploadStatus;
    private CancellationTokenSource? uploadStatusCts;
    private List<TrainingDocumentInfo>? trainingDocuments;
    private string trainingDocumentSearchTerm = string.Empty;
    private List<User>? entraUsers;
    private string userSearchTerm = string.Empty;
    private string? selectedUserId;
    private User? selectedUserProfile;
    private UserTrainingProfileViewModel? selectedUserTrainingProfile;
    private bool isLoadingSelectedUserProfile;
    private UserTrainingProfileViewModel? myTrainingProfile;
    private string? currentUserId;
    private UserLearningAssignmentViewModel? launchedAssignment;
    private Course? launchedCourse;
    private TrainingExam? launchedExam;
    private TrainingExam? launchedCourseStepExam;
    private int launchedCourseStepIndex;
    private Dictionary<int, HashSet<int>> launchedExamResponses = new();
    private string launchedExamResponseContext = string.Empty;
    private bool showExamResultModal;
    private bool examResultPassed;
    private int examResultScorePercent;
    private string examResultModalTitle = string.Empty;
    private string examResultModalMessage = string.Empty;
    private bool showAssignLearningModal;
    private bool isCompletingLaunchedVideo;
    // Legacy watcher fields kept to avoid compile breaks when older merged code paths still reference them.
    private bool launchedVideoWatcherInitialized;
    private IDisposable? launchedVideoWatcherReference;
    private ElementReference launchedVideoElement;
    private string assignCourseSearchTerm = string.Empty;
    private string assignDocumentSearchTerm = string.Empty;
    private string assignExamSearchTerm = string.Empty;
    private AssignableLearningItem? selectedAssignableItem;
    private bool isLoadingCourses;
    private List<CourseSummary> courses = new();
    private Course? editingCourse;
    private Course? viewingCourse;
    private int viewingCourseStepIndex;
    private List<BlobItemInfo> courseDocumentBlobs = new();
    private List<BlobItemInfo> courseVideoBlobs = new();
    private List<CourseExamSummary> courseExamOptions = new();
    private string? courseStatusMessage;
    private CancellationTokenSource? courseStatusCts;
    private List<TrainingExamSummary>? exams;
    private bool isCreatingExam;
    private bool isEditingExam;
    private string? editingExamId;
    private bool showDeleteExamModal;
    private string? examPendingDeleteId;
    private string examPendingDeleteTitle = string.Empty;
    private string examTitle = string.Empty;
    private int passingScorePercent = 80;
    private string questionType = "multiple-choice";
    private string questionText = string.Empty;
    private List<string> answerOptions = new() { string.Empty, string.Empty };
    private HashSet<int> correctAnswerIndexes = new();
    private readonly List<TrainingExamQuestion> draftQuestions = new();
    private string? examStatusMessage;
    private CancellationTokenSource? examStatusCts;

    private class UserTrainingProfileViewModel
    {
        public string UserId { get; set; } = string.Empty;
        public List<UserLearningAssignmentViewModel> ActiveAssignedLearning { get; set; } = new();
        public List<UserLearningAssignmentViewModel> LearningHistory { get; set; } = new();
    }

    private class UserLearningAssignmentViewModel
    {
        public string AssignmentId { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string ItemType { get; set; } = string.Empty;
        public string BlobPath { get; set; } = string.Empty;
        public string? ContentType { get; set; }
        public DateTimeOffset AssignedAtUtc { get; set; } = DateTimeOffset.UtcNow;
        public DateTimeOffset? CompletedAtUtc { get; set; }
    }

    private class AssignableLearningItem
    {
        public string Title { get; set; } = string.Empty;
        public string ItemType { get; set; } = string.Empty;
        public string BlobPath { get; set; } = string.Empty;
        public string? ContentType { get; set; }
    }

    private IEnumerable<TrainingDocumentInfo> FilteredTrainingDocuments =>
        trainingDocuments?
            .Where(doc => string.IsNullOrWhiteSpace(trainingDocumentSearchTerm)
                || doc.FileName.Contains(trainingDocumentSearchTerm, StringComparison.OrdinalIgnoreCase))
            ?? Enumerable.Empty<TrainingDocumentInfo>();

    private IEnumerable<User> FilteredEntraUsers =>
        entraUsers?
            .Where(user => string.IsNullOrWhiteSpace(userSearchTerm)
                || (user.DisplayName?.Contains(userSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                || (user.Mail?.Contains(userSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                || (user.UserPrincipalName?.Contains(userSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
            ?? Enumerable.Empty<User>();

    private IEnumerable<AssignableLearningItem> FilteredAssignableCourses =>
        courses
            .Where(c => string.IsNullOrWhiteSpace(assignCourseSearchTerm)
                || c.Title.Contains(assignCourseSearchTerm, StringComparison.OrdinalIgnoreCase))
            .Select(c => new AssignableLearningItem
            {
                Title = c.Title,
                ItemType = "Course",
                BlobPath = $"courses/{c.Id}.json",
                ContentType = "application/json"
            });

    private IEnumerable<AssignableLearningItem> FilteredAssignableDocuments =>
        (trainingDocuments ?? new List<TrainingDocumentInfo>())
            .Where(d => IsDocumentFileName(d.FileName)
                && (string.IsNullOrWhiteSpace(assignDocumentSearchTerm)
                    || d.FileName.Contains(assignDocumentSearchTerm, StringComparison.OrdinalIgnoreCase)))
            .Select(d => new AssignableLearningItem
            {
                Title = Path.GetFileNameWithoutExtension(d.FileName),
                ItemType = "Document",
                BlobPath = d.FileName,
                ContentType = d.ContentType
            });

    private IEnumerable<AssignableLearningItem> FilteredAssignableExams =>
        courseExamOptions
            .Where(e => string.IsNullOrWhiteSpace(assignExamSearchTerm)
                || e.Title.Contains(assignExamSearchTerm, StringComparison.OrdinalIgnoreCase))
            .Select(e => new AssignableLearningItem
            {
                Title = e.Title,
                ItemType = "Exam",
                BlobPath = e.BlobPath,
                ContentType = "application/json"
            });

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        IsTrainer = user.Claims.Any(c =>
            c.Type == "groups" && c.Value == TrainerGroupId);

        currentUserId = GetCurrentUserId(user);
        if (!string.IsNullOrWhiteSpace(currentUserId))
        {
            myTrainingProfile = await GetUserTrainingProfileDataAsync(currentUserId);
        }
        else
        {
            myTrainingProfile = new UserTrainingProfileViewModel();
        }

        if (IsTrainer)
        {
            await LoadTrainingDocumentsAsync();
            await LoadEntraUsersAsync();
            await LoadExamsAsync();
            await LoadCoursesAsync();
            await LoadCoursePickerDataAsync();
        }

        await TryActivateLaunchFromQueryAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await TryActivateLaunchFromQueryAsync();
    }

    private void SetActiveTab(string tab)
    {
        if (tab == "trainer-tools" && !IsTrainer)
        {
            return;
        }

        activeTab = tab;
    }

    private void SetTrainerToolTab(string tab)
    {
        trainerToolTab = tab;
    }

    private async Task HandleTrainingFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        SetUploadStatus("Uploading...");

        try
        {
            await TrainingDocumentService.UploadDocumentAsync(file);
            await LoadTrainingDocumentsAsync();
            SetUploadStatus("Upload successful!");

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userName = authState.User?.Identity?.Name ?? "anonymous";
            await Logger.LogActivityAsync(userName, $"Uploaded training file: '{file.Name}'");
        }
        catch (Exception ex)
        {
            SetUploadStatus($"Upload failed: {ex.Message}");
        }
    }

    private async Task DeleteTrainingDocument(string fileName)
    {
        await TrainingDocumentService.DeleteDocumentAsync(fileName);
        await LoadTrainingDocumentsAsync();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userName = authState.User?.Identity?.Name ?? "anonymous";
        await Logger.LogActivityAsync(userName, $"Deleted training file: '{fileName}'");
    }

