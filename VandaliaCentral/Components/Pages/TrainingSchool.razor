    private async Task TryActivateLaunchFromQueryAsync()
    {
        ResetLaunchedVideoCompletionState();

        if (string.IsNullOrWhiteSpace(AssignmentLaunchId) || myTrainingProfile == null)
        {
            launchedAssignment = null;
            launchedCourse = null;
            launchedExam = null;
            launchedCourseStepExam = null;
            launchedCourseStepIndex = 0;
            ResetTrainingSchoolExamAttemptV5();
            return;
        }

        var matchingAssignment = myTrainingProfile.ActiveAssignedLearning
            .FirstOrDefault(a => string.Equals(GetAssignmentLaunchId(a), AssignmentLaunchId, StringComparison.OrdinalIgnoreCase));

        launchedAssignment = matchingAssignment;
        launchedCourse = null;
        launchedExam = null;
        launchedCourseStepExam = null;
        launchedCourseStepIndex = 0;
        ResetTrainingSchoolExamAttemptV5();

        if (matchingAssignment == null)
        {
            return;
        }

        if (matchingAssignment.ItemType.Equals("Course", StringComparison.OrdinalIgnoreCase))
        {
            var courseId = Path.GetFileNameWithoutExtension(matchingAssignment.BlobPath);
            if (!string.IsNullOrWhiteSpace(courseId))
            {
                launchedCourse = await CourseStorageService.GetCourseAsync(courseId);
                await LoadTrainingSchoolActiveExamStepV5Async();
            }
        }
        else if (matchingAssignment.ItemType.Equals("Exam", StringComparison.OrdinalIgnoreCase))
        {
            launchedExam = await LoadTrainingSchoolExamForBlobPathV5Async(matchingAssignment.BlobPath);

            if (launchedExam != null)
            {
                InitializeTrainingSchoolExamAttemptV5(launchedExam, $"assignment:{matchingAssignment.AssignmentId}");
            }
        }

        await InvokeAsync(StateHasChanged);
    }

