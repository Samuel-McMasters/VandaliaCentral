    {
        showExamResultModal = false;
    }

    private bool IsTrainingSchoolExamLaunchContextV5()
    {
        if (launchedAssignment == null)
        {
            return false;
        }

        if (launchedAssignment.ItemType.Equals("Exam", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return launchedAssignment.ItemType.Equals("Course", StringComparison.OrdinalIgnoreCase)
            && launchedCourseStepExam != null;
    }

    private static List<int> NormalizeTrainingSchoolExamCorrectIndexesV5(TrainingExamQuestion question, bool usesOneBasedIndexes)
    {
        if (!question.Options.Any())
        {
            return new List<int>();
        }

        var optionCount = question.Options.Count;

        if (usesOneBasedIndexes)
        {
            return question.CorrectOptionIndexes
                .Where(i => i >= 1 && i <= optionCount)
                .Select(i => i - 1)
                .Distinct()
                .OrderBy(i => i)
                .ToList();
        }

        return question.CorrectOptionIndexes
            .Where(i => i >= 0 && i < optionCount)
            .Distinct()
            .OrderBy(i => i)
            .ToList();
    }

    private async Task<TrainingExam?> LoadTrainingSchoolExamForBlobPathV5Async(string blobPath)
    {
        if (string.IsNullOrWhiteSpace(blobPath)
            || !blobPath.StartsWith("exams/", StringComparison.OrdinalIgnoreCase))
