    private async Task LoadTrainingSchoolActiveExamStepV5Async()
    {
        launchedCourseStepExam = null;

        if (launchedCourse == null || !launchedCourse.Steps.Any())
        {
            return;
        }

        var orderedSteps = launchedCourse.Steps.OrderBy(s => s.Order).ToList();
        var currentCourseStep = orderedSteps[Math.Clamp(launchedCourseStepIndex, 0, orderedSteps.Count - 1)];

        if (!currentCourseStep.Content.BlobPath.StartsWith("exams/", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        launchedCourseStepExam = await LoadTrainingSchoolExamForBlobPathV5Async(currentCourseStep.Content.BlobPath);
        if (launchedCourseStepExam != null)
        {
            var examContextKey = $"course:{launchedCourse.Id}:step:{currentCourseStep.Id}";
            InitializeTrainingSchoolExamAttemptV5(launchedCourseStepExam, examContextKey);
        }
    }

    private void InitializeTrainingSchoolExamAttemptV5(TrainingExam exam, string contextKey, bool forceReset = false)
    {
        if (!forceReset && launchedExamResponseContext.Equals(contextKey, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        launchedExamResponseContext = contextKey;
        launchedExamResponses = new Dictionary<int, HashSet<int>>();
        examResultScorePercent = 0;
        examResultPassed = false;
        examResultModalTitle = string.Empty;
        examResultModalMessage = string.Empty;
        showExamResultModal = false;

        for (var i = 0; i < exam.Questions.Count; i++)
        {
            launchedExamResponses[i] = new HashSet<int>();
        }
    }

    private void ResetTrainingSchoolExamAttemptV5()
    {
        launchedExamResponseContext = string.Empty;
        launchedExamResponses = new Dictionary<int, HashSet<int>>();
        examResultScorePercent = 0;
        CloseTrainingSchoolExamResultModalV5();
    }

    private static bool IsTrainingSchoolExamMultipleSelectQuestionV5(TrainingExamQuestion question)
    {
        return string.Equals(question.QuestionType, "multiple-select", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsTrainingSchoolExamOptionSelectedV5(int questionIndex, int optionIndex)
    {
        return launchedExamResponses.TryGetValue(questionIndex, out var selected)
            && selected.Contains(optionIndex);
    }

    private void SetTrainingSchoolExamSingleAnswerV5(int questionIndex, int optionIndex)
    {
        launchedExamResponses[questionIndex] = new HashSet<int> { optionIndex };
    }

    private void SetTrainingSchoolExamOptionV5(int questionIndex, int optionIndex, object? value)
    {
        var isChecked = false;

        if (value is bool boolValue)
        {
            isChecked = boolValue;
        }
        else if (value is string stringValue)
        {
            isChecked = string.Equals(stringValue, "true", StringComparison.OrdinalIgnoreCase)
                || string.Equals(stringValue, "on", StringComparison.OrdinalIgnoreCase);
        }

        if (!launchedExamResponses.TryGetValue(questionIndex, out var selected))
        {
            selected = new HashSet<int>();
            launchedExamResponses[questionIndex] = selected;
        }

        if (isChecked)
        {
            selected.Add(optionIndex);
        }
        else
        {
            selected.Remove(optionIndex);
        }
    }

    private async Task SubmitTrainingSchoolExamAttemptV5(TrainingExam exam)
    {
        if (exam.Questions.Count == 0)
        {
            examResultPassed = false;
            examResultScorePercent = 0;
            examResultModalTitle = "Please Try Again";
            examResultModalMessage = "This exam has no questions configured yet.";
            showExamResultModal = true;
            return;
        }

        var matchedAnswerCount = 0;

        for (var questionIndex = 0; questionIndex < exam.Questions.Count; questionIndex++)
        {
            var question = exam.Questions[questionIndex];
            var selectedAnswers = launchedExamResponses.TryGetValue(questionIndex, out var selectedAnswerIndexes)
                ? selectedAnswerIndexes.OrderBy(i => i).ToList()
                : new List<int>();

            if (IsTrainingSchoolExamQuestionCorrectV5(question, selectedAnswers))
            {
                matchedAnswerCount++;
            }
        }

        var scorePercent = (int)Math.Round((double)matchedAnswerCount / exam.Questions.Count * 100d, MidpointRounding.AwayFromZero);
        examResultScorePercent = scorePercent;
        examResultPassed = scorePercent >= exam.PassingScorePercent;

        if (examResultPassed)
        {
            await CompleteTrainingSchoolAssignmentIfEligibleV5Async();
            examResultModalTitle = "Congratulations!";
            examResultModalMessage = $"Congratulation! You passed. Score: {scorePercent}%.";
        }
        else
        {
            examResultModalTitle = "Please Try Again";
            examResultModalMessage = $"You scored {scorePercent}%. You need at least {exam.PassingScorePercent}% to pass.";
        }

        showExamResultModal = true;
    }

    private bool IsTrainingSchoolExamQuestionCorrectV5(TrainingExamQuestion question, List<int> selectedAnswers)
    {
        var expectedZeroBased = NormalizeTrainingSchoolExamCorrectIndexesV5(question, usesOneBasedIndexes: false);
        if (expectedZeroBased.SequenceEqual(selectedAnswers))
        {
            return true;
        }

        var expectedOneBased = NormalizeTrainingSchoolExamCorrectIndexesV5(question, usesOneBasedIndexes: true);
        return expectedOneBased.SequenceEqual(selectedAnswers);
    }

    private async Task CompleteTrainingSchoolAssignmentIfEligibleV5Async()
    {
        if (launchedAssignment == null
            || !launchedAssignment.ItemType.Equals("Exam", StringComparison.OrdinalIgnoreCase)
            || string.IsNullOrWhiteSpace(currentUserId)
            || string.IsNullOrWhiteSpace(launchedAssignment.AssignmentId))
        {
            return;
        }

        var completed = await TryCompleteTrainingSchoolAssignmentForCurrentUserV5Async(launchedAssignment.AssignmentId);
        if (!completed)
        {
            return;
        }

        myTrainingProfile = await GetUserTrainingProfileDataAsync(currentUserId);
    }


    private async Task<bool> TryCompleteTrainingSchoolAssignmentForCurrentUserV5Async(string assignmentId)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(currentUserId) || string.IsNullOrWhiteSpace(assignmentId))
            {
                return false;
            }

            var completeMethod = TrainingDocumentService.GetType().GetMethod("CompleteAssignmentForUserAsync");
            if (completeMethod != null)
            {
                var taskObj = completeMethod.Invoke(TrainingDocumentService, new object[] { currentUserId, assignmentId });
                if (taskObj is Task<bool> boolTask)
                {
                    return await boolTask;
                }
            }

            var getProfileMethod = TrainingDocumentService.GetType().GetMethod("GetUserTrainingProfileAsync");
            var saveProfileMethod = TrainingDocumentService.GetType().GetMethod("SaveUserTrainingProfileAsync");
            if (getProfileMethod == null || saveProfileMethod == null)
            {
                return false;
            }

            var getTaskObj = getProfileMethod.Invoke(TrainingDocumentService, new object[] { currentUserId });
            if (getTaskObj is not Task getTask)
            {
                return false;
            }

            await getTask;

            var resultProperty = getTask.GetType().GetProperty("Result");
            var profileObj = resultProperty?.GetValue(getTask);
            if (profileObj == null)
            {
                return false;
            }

            var profileType = profileObj.GetType();
            var activeProp = profileType.GetProperty("ActiveAssignedLearning");
            var historyProp = profileType.GetProperty("LearningHistory");
            if (activeProp?.GetValue(profileObj) is not System.Collections.IList activeList
                || historyProp?.GetValue(profileObj) is not System.Collections.IList historyList)
            {
                return false;
            }

            object? matched = null;
            foreach (var item in activeList)
            {
                if (item == null)
                {
                    continue;
                }

                var assignmentIdProp = item.GetType().GetProperty("AssignmentId");
                var candidateId = assignmentIdProp?.GetValue(item)?.ToString();
                if (string.Equals(candidateId, assignmentId, StringComparison.OrdinalIgnoreCase))
                {
                    matched = item;
                    break;
                }
            }

            if (matched == null)
            {
                return false;
            }

            activeList.Remove(matched);

            var completedAtProp = matched.GetType().GetProperty("CompletedAtUtc");
            completedAtProp?.SetValue(matched, DateTimeOffset.UtcNow);
            historyList.Add(matched);

            var saveTaskObj = saveProfileMethod.Invoke(TrainingDocumentService, new object[] { profileObj });
            if (saveTaskObj is not Task saveTask)
            {
                return false;
            }

            await saveTask;
            return true;
        }
        catch
        {
            return false;
        }
    }

    private async Task HandleTrainingSchoolExamPrimaryActionV5Async()
    {
        var shouldReturnToMyCourses = examResultPassed;
        CloseTrainingSchoolExamResultModalV5();

        if (shouldReturnToMyCourses)
        {
            launchedAssignment = null;
            launchedExam = null;
            launchedCourse = null;
            launchedCourseStepExam = null;
            launchedCourseStepIndex = 0;
            ResetTrainingSchoolExamAttemptV5();
            activeTab = "my-courses";
            NavigationManager.NavigateTo("/training-school", forceLoad: false);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RetakeTrainingSchoolExamV5Async()
    {
        showExamResultModal = false;
        examResultPassed = false;
        examResultScorePercent = 0;
        examResultModalTitle = string.Empty;
        examResultModalMessage = string.Empty;

        if (launchedExam != null)
        {
            var assignmentId = launchedAssignment?.AssignmentId ?? string.Empty;
            InitializeTrainingSchoolExamAttemptV5(launchedExam, $"assignment:{assignmentId}", forceReset: true);
        }
        else if (launchedCourseStepExam != null && launchedCourse != null)
        {
            var orderedSteps = launchedCourse.Steps.OrderBy(s => s.Order).ToList();
            if (orderedSteps.Any())
            {
                var retakeStep = orderedSteps[Math.Clamp(launchedCourseStepIndex, 0, orderedSteps.Count - 1)];
                var retakeContextKey = $"course:{launchedCourse.Id}:step:{retakeStep.Id}";
                InitializeTrainingSchoolExamAttemptV5(launchedCourseStepExam, retakeContextKey, forceReset: true);
            }
        }

        await InvokeAsync(StateHasChanged);
    }

