        step.Content.BlobPath = blobPath ?? string.Empty;

        var selectedContent = GetStepContentOptions(step.Type)
            .FirstOrDefault(option => option.BlobPath == step.Content.BlobPath);

        step.Content.ContentType = selectedContent?.ContentType;
    }

    private void SetCourseStatus(string message)
    {
        courseStatusCts?.Cancel();
        courseStatusCts?.Dispose();

        courseStatusMessage = message;

        var cts = new CancellationTokenSource();
        courseStatusCts = cts;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(5), cts.Token);
                if (!cts.Token.IsCancellationRequested)
                {
                    await InvokeAsync(() =>
                    {
                        if (courseStatusCts == cts)
                        {
                            courseStatusMessage = null;
                            StateHasChanged();
                        }
                    });
                }
            }
            catch (TaskCanceledException)
            {
            }
        });
    }

