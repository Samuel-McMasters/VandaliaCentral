    private static List<int> NormalizeTrainingSchoolExamCorrectIndexesV4(TrainingExamQuestion question, bool usesOneBasedIndexes)
    {
        if (!question.Options.Any())
        {
            return new List<int>();
        }

        var optionCount = question.Options.Count;

        if (usesOneBasedIndexes)
        {
            return question.CorrectOptionIndexes
                .Where(i => i >= 1 && i <= optionCount)
                .Select(i => i - 1)
                .Distinct()
                .OrderBy(i => i)
                .ToList();
        }

        return question.CorrectOptionIndexes
            .Where(i => i >= 0 && i < optionCount)
            .Distinct()
            .OrderBy(i => i)
            .ToList();
    }

