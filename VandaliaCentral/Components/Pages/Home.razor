@page "/"
@inject IWebHostEnvironment Env
@inject HttpClient Http
@inject NavigationManager Nav
@using VandaliaCentral.Services
@using VandaliaCentral.Models
@using Microsoft.AspNetCore.Authorization
@inject PdfService PdfService
@inject CalendarService CalendarService
@attribute [Authorize]



<PageTitle>Vandalia Central</PageTitle>
<div class="container-fluid">

    <!-- Bottom Row -->
    <div class="row g-4 pb-4">

        <!-- Left Column w/ fullscreen button -->
        <div class="col-12 col-lg-7 d-flex flex-column monday-minute-column">
            <!-- Monday Minute -->
            <div class="p-4 border rounded bg-white shadow-sm w-100 d-flex flex-column position-relative flex-grow-1 monday-minute-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h5 class="mb-0">@mmPdfName</h5>
                    <div class="d-flex gap-2">
                        @if (showPreviousMondayMinutes)
                        {
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ClosePreviousMondayMinutes">
                                Close
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ShowPreviousMondayMinutes">
                                View Previous Monday Minutes
                            </button>
                        }
                        <a href=@mmPdf target="_blank" class="btn btn-sm btn-outline-secondary">
                            View Fullscreen
                        </a>
                    </div>
                </div>

                <div class="flex-grow-1 w-100 rounded overflow-hidden position-relative monday-minute-content" style="background-color: #e9ecef;">   
                    @if (mmPdf == null)
                    {

                        <p>Loading latest Monday Minute PDF...</p>

                    }
                    else if (!showPreviousMondayMinutes)
                    {
                        <embed src=@mmPdf type="application/pdf" width="100%" height="100%" style="min-height: 100%;"/>
                    }
                    else
                    {
                        <div class="position-absolute top-0 start-0 w-100 h-100 overflow-auto p-3 previous-monday-minutes-list">
                            @if (!previousMondayMinutes.Any())
                            {
                                <p class="text-muted mb-0">No previous Monday Minutes available.</p>
                            }
                            else
                            {
                                <ul class="list-group">
                                    @foreach (var mondayMinute in previousMondayMinutes)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <span class="me-2 text-truncate">@mondayMinute.Name</span>
                                            <a href="@mondayMinute.Url" target="_blank" class="btn btn-sm btn-primary">
                                                View
                                            </a>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    }
                </div>



            </div>
        </div>


        <!-- Right Column -->
        <div class="col-12 col-lg-5 d-flex flex-column gap-4">
            <div class="p-4 border rounded bg-white shadow-sm flex-fill d-flex flex-column" style="min-height: 350px;">
                <h5 class="mb-3">Company Calendar</h5>

                <!-- Scrollable container -->
                <div style="overflow-y: auto; max-height: 250px;">
                    @if (calendarEvents == null)
                    {
                        <p>Loading calendar...</p>
                    }
                    else if (!calendarEvents.Any())
                    {
                        <p class="text-muted">No upcoming events.</p>
                    }
                    else
                    {
                        <ul class="space-y-3">
                            @foreach (var e in calendarEvents)
                            {
                                <li class="d-flex">
                                    <div class="w-2 h-2 mt-2.5 rounded-circle bg-warning me-3"></div>
                                    <div>
                                        <strong>@e.Date.ToString("MMMM d")</strong> – @e.Title
                                        <div class="text-muted small">@e.Type</div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <div class="p-4 border rounded bg-white shadow-sm">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <h5 class="mb-1">Intranet Feedback</h5>
                        <p class="text-muted mb-0">Have an idea or enhancement request? Let us know.</p>
                    </div>
                    <a class="btn btn-primary" href="/feedback">Give Feedback</a>
                </div>
            </div>

            <!-- Bonus Chart -->
            <div class="p-4 border rounded bg-white shadow-sm flex-fill" style="min-height: 500px;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h5 class="mb-0">Bonus Chart</h5>
                    <a href=@bcPdf target="_blank" class="btn btn-sm btn-outline-secondary">
                        View Fullscreen
                    </a>
                </div>
                <div class="w-100 rounded overflow-hidden" style="height: 400px; background-color: #e9ecef;">
                    @if (bcPdf == null)
                    {
                        <p>Loading latest Monday Minute PDF...</p>

                    }
                    else
                    {
                        <embed src=@bcPdf type="application/pdf" width="100%" height="100%" style="min-height: 100%;"/>
                                                    
                    }


                </div>


            </div>

        </div> 

    </div>



</div>



<style>
    .monday-minute-card {
        height: 700px;
        overflow: hidden;
    }

    @@media (min-width: 992px) {
        .monday-minute-card {
            height: 100%;
            min-height: 0;
        }
    }

    .monday-minute-content {
        min-height: 0;
    }

    .previous-monday-minutes-list {
        background-color: #e9ecef;
    }
</style>

@code {
    //variables to hold api endpoints for pdfs
    private string mmPdf;
    private string mmPdfName;
    private string bcPdf;
    private List<CalendarEvent>? calendarEvents;
    private List<PdfInfo> previousMondayMinutes = new();
    private bool showPreviousMondayMinutes;

    protected override async Task OnInitializedAsync()
    {
        mmPdf = await PdfService.GetLatestPdfUrlAsync("mondayminute");

        mmPdfName = await PdfService.GetMmPdfNameAsync("mondayminute");

        var mondayMinutes = await PdfService.GetPdfsAsync("mondayminute");
        previousMondayMinutes = mondayMinutes
            .Where(pdf => !string.Equals(pdf.Name, mmPdfName, StringComparison.OrdinalIgnoreCase))
            .ToList();

        bcPdf = await PdfService.GetLatestPdfUrlAsync("bonuschart");

        calendarEvents = await CalendarService.LoadCalendarAsync();
        
    }

    private void ShowPreviousMondayMinutes()
    {
        showPreviousMondayMinutes = true;
    }

    private void ClosePreviousMondayMinutes()
    {
        showPreviousMondayMinutes = false;
    }

    
  
}
