@page "/"
@inject IWebHostEnvironment Env
@inject HttpClient Http
@inject NavigationManager Nav
@using VandaliaCentral.Services
@using VandaliaCentral.Models
@using Microsoft.AspNetCore.Authorization
@inject PdfService PdfService
@inject CalendarService CalendarService
@attribute [Authorize]



<PageTitle>Vandalia Central</PageTitle>
<div class="container-fluid">

    <!-- Bottom Row -->
    <div class="row g-4 pb-4 align-items-stretch">

        <!-- Left Column w/ fullscreen button -->
        <div class="col-12 col-lg-7 d-flex flex-column">
            <!-- Monday Minute -->
            <div class="p-4 border rounded bg-white shadow-sm h-100 w-100 d-flex flex-column position-relative" style="min-height: 1000px;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h5 class="mb-0">@mmPdfName</h5>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="ToggleMondayMinuteHistory">
                            View Previous Monday Minutes
                        </button>
                        <a href=@mmPdf target="_blank" class="btn btn-sm btn-outline-secondary">
                            View Fullscreen
                        </a>
                    </div>
                </div>

                @if (showMondayMinuteHistory)
                {
                    <div class="flex-grow-1 w-100 rounded border bg-light-subtle d-flex flex-column overflow-hidden" style="min-height: 0;">
                        <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
                            <h6 class="mb-0">Previous Monday Minutes</h6>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CloseMondayMinuteHistory">
                                Close
                            </button>
                        </div>
                        <div class="p-3 overflow-y-auto flex-grow-1" style="min-height: 0; max-height: 100%;">
                            @if (isLoadingMondayMinuteHistory)
                            {
                                <p class="text-muted mb-0">Loading Monday Minutes...</p>
                            }
                            else if (!mondayMinuteHistory.Any())
                            {
                                <p class="text-muted mb-0">No previous Monday Minutes available.</p>
                            }
                            else
                            {
                                <ul class="list-group mb-0">
                                    @foreach (var minute in mondayMinuteHistory)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <span>@minute.Name</span>
                                            <a href="@minute.Url" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-secondary">View</a>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="flex-grow-1 w-100 rounded overflow-hidden" style="background-color: #e9ecef;">   
                        @if (mmPdf == null)
                        {

                            <p>Loading latest Monday Minute PDF...</p>

                        }
                        else
                        {
                            <embed src=@mmPdf type="application/pdf" width="100%" height="100%" style="min-height: 100%;"/>
                        }
                    </div>
                }



            </div>
        </div>


        <!-- Right Column -->
        <div class="col-12 col-lg-5 d-flex flex-column gap-4">
            <div class="p-4 border rounded bg-white shadow-sm flex-fill d-flex flex-column" style="min-height: 350px;">
                <h5 class="mb-3">Company Calendar</h5>

                <!-- Scrollable container -->
                <div style="overflow-y: auto; max-height: 250px;">
                    @if (calendarEvents == null)
                    {
                        <p>Loading calendar...</p>
                    }
                    else if (!calendarEvents.Any())
                    {
                        <p class="text-muted">No upcoming events.</p>
                    }
                    else
                    {
                        <ul class="space-y-3">
                            @foreach (var e in calendarEvents)
                            {
                                <li class="d-flex">
                                    <div class="w-2 h-2 mt-2.5 rounded-circle bg-warning me-3"></div>
                                    <div>
                                        <strong>@e.Date.ToString("MMMM d")</strong> – @e.Title
                                        <div class="text-muted small">@e.Type</div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <div class="p-4 border rounded bg-white shadow-sm">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <h5 class="mb-1">Intranet Feedback</h5>
                        <p class="text-muted mb-0">Have an idea or enhancement request? Let us know.</p>
                    </div>
                    <a class="btn btn-primary" href="/feedback">Give Feedback</a>
                </div>
            </div>

            <!-- Bonus Chart -->
            <div class="p-4 border rounded bg-white shadow-sm flex-fill" style="min-height: 500px;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h5 class="mb-0">Bonus Chart</h5>
                    <a href=@bcPdf target="_blank" class="btn btn-sm btn-outline-secondary">
                        View Fullscreen
                    </a>
                </div>
                <div class="w-100 rounded overflow-hidden" style="height: 400px; background-color: #e9ecef;">
                    @if (bcPdf == null)
                    {
                        <p>Loading latest Monday Minute PDF...</p>

                    }
                    else
                    {
                        <embed src=@bcPdf type="application/pdf" width="100%" height="100%" style="min-height: 100%;"/>
                                                    
                    }


                </div>


            </div>

        </div> 

    </div>



</div>


@code {
    //variables to hold api endpoints for pdfs
    private string mmPdf;
    private string mmPdfName;
    private string bcPdf;
    private List<CalendarEvent>? calendarEvents;
    private bool showMondayMinuteHistory;
    private bool isLoadingMondayMinuteHistory;
    private List<PdfInfo> mondayMinuteHistory = new();

    protected override async Task OnInitializedAsync()
    {
        mmPdf = await PdfService.GetLatestPdfUrlAsync("mondayminute");

        mmPdfName = await PdfService.GetMmPdfNameAsync("mondayminute");

        bcPdf = await PdfService.GetLatestPdfUrlAsync("bonuschart");

        calendarEvents = await CalendarService.LoadCalendarAsync();
        
    }

    private async Task ToggleMondayMinuteHistory()
    {
        showMondayMinuteHistory = !showMondayMinuteHistory;

        if (showMondayMinuteHistory && !mondayMinuteHistory.Any())
        {
            await LoadMondayMinuteHistoryAsync();
        }
    }

    private void CloseMondayMinuteHistory()
    {
        showMondayMinuteHistory = false;
    }

    private async Task LoadMondayMinuteHistoryAsync()
    {
        isLoadingMondayMinuteHistory = true;

        try
        {
            var containerClient = PdfService.GetBlobContainerClient("mondayminute");
            var blobs = await PdfService.ListBlobsAsync("mondayminute");

            mondayMinuteHistory = blobs
                .Where(blob => blob.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(blob => blob.Properties.LastModified ?? DateTimeOffset.MinValue)
                .Select(blob =>
                {
                    var blobClient = containerClient.GetBlobClient(blob.Name);
                    var displayName = Path.GetFileNameWithoutExtension(blob.Name);
                    var modifiedTime = blob.Properties.LastModified?.ToUnixTimeMilliseconds().ToString() ?? DateTimeOffset.UtcNow.ToUnixTimeMilliseconds().ToString();
                    var uriBuilder = new UriBuilder(blobClient.Uri);

                    uriBuilder.Query = string.IsNullOrWhiteSpace(uriBuilder.Query)
                        ? $"v={modifiedTime}"
                        : $"{uriBuilder.Query.TrimStart('?')}&v={modifiedTime}";

                    return new PdfInfo
                        {
                            Name = displayName,
                            Url = uriBuilder.Uri.ToString()
                        };
                })
                .ToList();
        }
        finally
        {
            isLoadingMondayMinuteHistory = false;
        }
    }

    
  
}
