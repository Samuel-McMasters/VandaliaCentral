    private string GetTagSummary(List<Guid>? tagIds)
    {
        if (knowledgeBaseSecurityTags == null || tagIds == null || tagIds.Count == 0)
        {
            return "None";
        }

        var names = knowledgeBaseSecurityTags
            .Where(tag => tagIds.Contains(tag.Id))
            .Select(tag => tag.Name)
            .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        return names.Count == 0 ? "None" : string.Join(", ", names);
    }

    private string GetGroupSummary(List<string>? groupIds)
    {
        if (groupIds == null || groupIds.Count == 0)
        {
            return "None";
        }

        var groupNameById = entraGroups
            .GroupBy(group => group.Id, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.First().DisplayName, StringComparer.OrdinalIgnoreCase);

        var names = groupIds
            .Select(groupId => groupNameById.TryGetValue(groupId, out var displayName) ? displayName : groupId)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        return names.Count == 0 ? "None" : string.Join(", ", names);
    }

    private string GetTagGroupSummary(KnowledgeBaseSecurityTagItem tag) => GetGroupSummary(tag.AllowedGroupIds);

    private async Task SaveKnowledgeBaseAndShowStatus(string message)
    {
        if (knowledgeBaseFolders == null || knowledgeBaseSecurityTags == null)
            return;

        await KnowledgeBaseService.SaveSnapshotAsync(new KnowledgeBaseSnapshot
        {
            Folders = knowledgeBaseFolders,
            SecurityTags = knowledgeBaseSecurityTags
        });
        await LoadKnowledgeBaseStateAsync();

        knowledgeBaseStatusMessage = message;
        StateHasChanged();

        await Task.Delay(2500);
        knowledgeBaseStatusMessage = null;
        StateHasChanged();
    }

    private async Task LoadKnowledgeBaseStateAsync()
    {
        var snapshot = await KnowledgeBaseService.LoadSnapshotAsync();
        knowledgeBaseFolders = snapshot.Folders;
        knowledgeBaseSecurityTags = snapshot.SecurityTags;
    }

    private async Task LoadEntraGroupsAsync()
    {
        isLoadingEntraGroups = true;
        StateHasChanged();

        entraGroups = await GraphUserService.GetGroupsAsync();

        isLoadingEntraGroups = false;
        StateHasChanged();
    }

    private static string? NormalizeScribeEmbedUrl(string? input)
    {
        if (string.IsNullOrWhiteSpace(input))
        {
            return null;
        }

        var trimmed = input.Trim();

        if (trimmed.Contains("<iframe", StringComparison.OrdinalIgnoreCase))
        {
            var srcMatch = System.Text.RegularExpressions.Regex.Match(trimmed, "src\\s*=\\s*\"(?<url>[^\"]+)\"", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            if (srcMatch.Success)
            {
                trimmed = srcMatch.Groups["url"].Value;
            }
        }

        return trimmed;
    }

    private void GeneratePassword()
    {
