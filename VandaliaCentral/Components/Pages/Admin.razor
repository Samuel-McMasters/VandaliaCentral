@page "/admin"
@using VandaliaCentral.Services
@using VandaliaCentral.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Identity.Client
@using Microsoft.Identity.Web
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject CalendarService CalendarService
@inject ItNewsService ItNewsService
@inject LoggingService Logger
@inject GraphUserService GraphUserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ITokenAcquisition TokenAcquisition
@inject MicrosoftIdentityConsentAndConditionalAccessHandler ConsentHandler
@inject IPasswordGeneratorService PasswordGenerator
@inject FlappyLeaderboardService FlappyLeaderboardService
@implements IAsyncDisposable


<div class="container-fluid border rounded bg-white shadow-sm col-md-12 py-4">
    <h3 class="pb-5">Admin Dashboard</h3>

    @if (!isAuthorized)
    {

        <p class="text-danger">Refresh the page, or please wait while we check your authorizations...</p>
    }
    else
    {
        <div class="ms-auto pb-5">
            <NavLink href="https://vandaliarental.targit.cloud/#vfs://global/Service/R%20Status%20Priority.xview" class="btn btn-dark" activeClass="active" target="_blank">

                @(isMobile ? "Targit Dashboard" : "My Targit Dashboard")
            </NavLink>
        </div>

        <!-- Tab Navigation -->
        <ul class="nav nav-tabs mb-4" id="adminTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("logs"))' @onclick='() => SetActiveTab("logs")' type='button'>
                    Logs
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("calendar"))' @onclick='() => SetActiveTab("calendar")' type='button'>
                    Company Calendar
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("itnews"))' @onclick='() => SetActiveTab("itnews")' type='button'>
                    IT News
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("mondayminute"))' @onclick='() => SetActiveTab("mondayminute")' type='button'>
                    Monday Minute
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("passwords"))' @onclick='() => SetActiveTab("passwords")' type='button'>
                    Password Generator
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("flappybird"))' @onclick='() => SetActiveTab("flappybird")' type='button'>
                    Flappy Bird
                </button>
            </li>


        </ul>

        @if (activeTab == "logs")
        {
            <div>
                <h5>Log Viewer</h5>

                @if (logFiles == null)
                {
                    <p>Loading logs...</p>
                }
                else
                {
                    <select @onchange="OnLogSelected" class="form-select w-25 mb-3">
                        <option disabled selected value="">-- Select Log File --</option>
                        @foreach (var file in logFiles)
                        {
                            <option value="@file">@file</option>
                        }
                    </select>

                    @if (!string.IsNullOrEmpty(logContent))
                    {
                        <div style="max-height: 400px; overflow-y: auto;">
                            <pre class="bg-light p-3 border rounded" style="white-space: pre-wrap;">@logContent</pre>
                        </div>
                    }
                }
            </div>
        }

        @if (activeTab == "calendar")
        {
            <div>
                <h5>Company Calendar Manager</h5>

                <div class="mb-3 w-25">
                    <label>Date:</label>
                    <InputDate @bind-Value="newEvent.Date" class="form-control" />

                    <label class="mt-2">Title:</label>
                    <InputText @bind-Value="newEvent.Title" class="form-control" />

                    <label class="mt-2">Type:</label>
                    <InputText @bind-Value="newEvent.Type" class="form-control" />

                    <button class="btn btn-success mt-3" @onclick="AddEvent">Add Event</button>
                </div>

                @if (calendarEvents == null)
                {
                    <p>Loading calendar events...</p>
                }
                else if (!calendarEvents.Any())
                {
                    <p class="text-muted">No events yet.</p>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var ev in calendarEvents)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@ev.Date.ToString("MMMM d")</strong> – @ev.Title
                                    <div class="text-muted small">@ev.Type</div>
                                </div>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteEvent(ev)">Delete</button>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3 mt-3">
                        <button class="btn btn-primary" @onclick="SaveCalendar">Save Changes</button>
                        @if (showSaveSuccess)
                        {
                            <div class="text-success fw-bold">✓ Saved!</div>
                        }
                    </div>
                }
            </div>
        }

        @if (activeTab == "itnews")
        {
            <div>
                <h5>IT News Manager</h5>

                <div class="border rounded p-3 mb-4" style="max-width: 700px;">
                    <h6>Add IT News Item</h6>
                    <label class="mt-2">Title:</label>
                    <InputText @bind-Value="newItNewsTitle" class="form-control" />

                    <label class="mt-2">News Content:</label>
                    <InputTextArea @bind-Value="newItNewsContent" rows="4" class="form-control" />

                    <button class="btn btn-success mt-3" @onclick="AddNewsItem">Add News Item</button>
                </div>

                @if (itNewsItems == null)
                {
                    <p>Loading IT news...</p>
                }
                else if (!itNewsItems.Any())
                {
                    <p class="text-muted">No IT news items yet.</p>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var item in itNewsItems)
                        {
                            <li class="list-group-item">
                                @if (editingItNewsId == item.Id)
                                {
                                    <label>Title:</label>
                                    <InputText @bind-Value="editItNewsTitle" class="form-control mb-2" />

                                    <label>News Content:</label>
                                    <InputTextArea @bind-Value="editItNewsContent" rows="4" class="form-control" />

                                    <div class="d-flex gap-2 mt-3">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveEditedNewsItem">Save</button>
                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditNewsItem">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div>
                                            <strong>@item.Title</strong>
                                            <div class="text-muted small">@item.PostedOn.ToLocalTime().ToString("MMM d, yyyy")</div>
                                            <div style="white-space: pre-wrap;">@item.Content</div>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditNewsItem(item)">Edit</button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteNewsItem(item)">Delete</button>
                                        </div>
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }

                @if (showNewsSaveSuccess)
                {
                    <div class="text-success fw-bold mt-3">✓ IT news saved!</div>
                }
            </div>
        }

        @if (activeTab == "mondayminute")
        {
            <MondayMinuteManager />
        }

        @if (activeTab == "passwords")
        {
            <div>
                <h5>Password Generator</h5>
                <p class="text-muted mb-3">
                    2 words (≤ 5 chars each) + a number + a special character
                </p>

                <div class="d-flex align-items-center gap-2" style="max-width: 520px;">
                    <button class="btn btn-primary" @onclick="GeneratePassword">
                        Generate
                    </button>

                    <input class="form-control" value="@generatedPassword" readonly />

                    <button class="btn btn-outline-secondary"
                            @onclick="CopyPassword"
                            disabled="@string.IsNullOrWhiteSpace(generatedPassword)">
                        Copy
                    </button>
                </div>

                @if (showCopySuccess)
                {
                    <div class="text-success fw-bold mt-2">✓ Copied!</div>
                }
            </div>
        }

        @if (activeTab == "flappybird")
        {
            <div>
                <h5>Flappy Bird Challenge</h5>
                <p class="text-muted mb-3">
                    Press <strong>Space</strong> to flap and fly through the pipe gaps. Tight gaps, one hit ends the run.
                </p>

                <div class="d-flex flex-wrap gap-4 align-items-start">
                    <div>
                        <canvas id="adminFlappyCanvas" width="520" height="600" class="border rounded bg-light"></canvas>
                        <div class="d-flex gap-2 mt-3">
                            <button class="btn btn-primary" @onclick="StartFlappyGame">Start / Restart</button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(flappyStatusMessage))
                        {
                            <div class="mt-2 text-danger small">@flappyStatusMessage</div>
                        }
                        <div class="mt-2 small text-muted">
                            Signed in as: <strong>@currentUserName</strong>
                        </div>
                        @if (lastFlappyScore > 0)
                        {
                            <div class="mt-2 fw-semibold">Last score: @lastFlappyScore</div>
                        }
                    </div>

                    <div class="border rounded p-3" style="min-width: 280px;">
                        <h6>Top 5 Leaderboard</h6>

                        @if (flappyTopScores == null)
                        {
                            <p class="text-muted mb-0">Loading scores...</p>
                        }
                        else if (!flappyTopScores.Any())
                        {
                            <p class="text-muted mb-0">No scores yet. Be the first!</p>
                        }
                        else
                        {
                            <ol class="mb-0 ps-3">
                                @foreach (var score in flappyTopScores)
                                {
                                    <li class="mb-1">
                                        <span class="fw-semibold">@score.UserName</span> — @score.Score
                                    </li>
                                }
                            </ol>
                        }
                    </div>
                </div>
            </div>
        }

    }
</div>

@code {
    private List<string>? logFiles;
    private string? logContent;
    private bool isAuthorized = false;
    private bool showSaveSuccess = false;
    private bool isMobile = false;
    private string activeTab = "logs";
    private string adminGroupId = "1f7897c7-a5b7-437c-9697-626c1e758f04";
    private List<CalendarEvent>? calendarEvents;
    private CalendarEvent newEvent = new();
    private List<ItNewsItem>? itNewsItems;
    private string newItNewsTitle = string.Empty;
    private string newItNewsContent = string.Empty;
    private Guid? editingItNewsId;
    private string editItNewsTitle = string.Empty;
    private string editItNewsContent = string.Empty;
    private bool showNewsSaveSuccess = false;
    private string? generatedPassword;
    private bool showCopySuccess = false;
    private List<FlappyScore>? flappyTopScores;
    private string currentUserName = "anonymous";
    private int lastFlappyScore = 0;
    private DotNetObjectReference<Admin>? flappyDotNetRef;
    private bool flappyInitialized = false;
    private string? flappyStatusMessage;

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
    }

    private string IsActiveTab(string tab) => activeTab == tab ? "active" : "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var token = await TokenAcquisition.GetAccessTokenForUserAsync(new[] { "User.Read.All" });

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            currentUserName = GetLeaderboardDisplayName(user?.Identity?.Name);

            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst("http://schemas.microsoft.com/identity/claims/objectidentifier")?.Value;

                if (!string.IsNullOrEmpty(userId))
                {
                    isAuthorized = await GraphUserService.IsUserInGroupAsync(userId, adminGroupId);
                }
            }

            if (isAuthorized)
            {
                logFiles = await Logger.GetLogFileNamesAsync();
                calendarEvents = await CalendarService.LoadCalendarAsync();
                itNewsItems = await ItNewsService.LoadNewsAsync();
                flappyTopScores = await FlappyLeaderboardService.GetTopScoresAsync(5);
            }
        }
        catch (MsalUiRequiredException ex)
        {
            ConsentHandler.HandleException(ex);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Unexpected error during token acquisition or group check: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var width = await JS.InvokeAsync<int>("blazorGetWindowWidth");
            isMobile = width < 768;
            StateHasChanged();
        }

        if (activeTab == "flappybird" && !flappyInitialized)
        {
            await InitializeFlappyGameAsync();
        }
    }

    private async Task<bool> InitializeFlappyGameAsync(bool force = false)
    {
        if (flappyInitialized && !force)
        {
            return true;
        }

        flappyDotNetRef?.Dispose();
        flappyDotNetRef = DotNetObjectReference.Create(this);
        flappyInitialized = await JS.InvokeAsync<bool>("adminFlappyBird.init", "adminFlappyCanvas", flappyDotNetRef);
        return flappyInitialized;
    }

    private async Task StartFlappyGame()
    {
        flappyStatusMessage = null;

        try
        {
            var initialized = await InitializeFlappyGameAsync();
            if (!initialized)
            {
                await Task.Delay(50);
                initialized = await InitializeFlappyGameAsync(force: true);
            }

            if (!initialized)
            {
                flappyStatusMessage = "Game canvas was not ready. Please try again.";
                return;
            }

            var started = await JS.InvokeAsync<bool>("adminFlappyBird.start");
            if (!started)
            {
                flappyInitialized = false;
                flappyStatusMessage = "Unable to start game. Please click Start again.";
            }
        }
        catch
        {
            flappyInitialized = false;
            flappyStatusMessage = "Unable to start game due to a script error. Please refresh and try again.";
        }
    }

    [JSInvokable]
    public async Task OnFlappyGameOver(int score)
    {
        lastFlappyScore = score;

        if (score > 0)
        {
            var currentTopScore = (await FlappyLeaderboardService.GetTopScoresAsync(1)).FirstOrDefault()?.Score ?? 0;
            var isNewHighScore = score > currentTopScore;

            await FlappyLeaderboardService.AddScoreAsync(currentUserName, score);
            flappyTopScores = await FlappyLeaderboardService.GetTopScoresAsync(5);

            if (isNewHighScore)
            {
                var fullUserName = await GetCurrentUserNameAsync();
                await Logger.LogActivityAsync(fullUserName, $"Set new Flappy Bird high score: {score}");
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnLogSelected(ChangeEventArgs e)
    {
        var selectedFile = e.Value?.ToString();
        if (!string.IsNullOrEmpty(selectedFile))
        {
            logContent = await Logger.ReadLogContentAsync(selectedFile);
        }
    }

    private void AddEvent()
    {
        if (string.IsNullOrWhiteSpace(newEvent.Title))
            return;

        calendarEvents?.Add(new CalendarEvent
            {
                Date = newEvent.Date,
                Title = newEvent.Title,
                Type = newEvent.Type
            });

        newEvent = new CalendarEvent();
    }

    private void DeleteEvent(CalendarEvent ev)
    {
        calendarEvents?.Remove(ev);
    }

    private async Task SaveCalendar()
    {
        try
        {
            if (calendarEvents != null)
            {
                await CalendarService.SaveCalendarAsync(calendarEvents);
                showSaveSuccess = true;
                StateHasChanged();

                await Task.Delay(4000);
                showSaveSuccess = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error saving calendar: " + ex.Message);
        }
    }

    private async Task AddNewsItem()
    {
        if (itNewsItems == null || string.IsNullOrWhiteSpace(newItNewsTitle) || string.IsNullOrWhiteSpace(newItNewsContent))
            return;

        var itemTitle = newItNewsTitle.Trim();

        itNewsItems.Add(new ItNewsItem
        {
            Id = Guid.NewGuid(),
            Title = itemTitle,
            Content = newItNewsContent.Trim(),
            PostedOn = DateTime.UtcNow
        });

        var userName = await GetCurrentUserNameAsync();
        await Logger.LogActivityAsync(userName, $"Added IT News Item {itemTitle}");

        newItNewsTitle = string.Empty;
        newItNewsContent = string.Empty;
        await SaveNewsAndShowStatus();
    }

    private void StartEditNewsItem(ItNewsItem item)
    {
        editingItNewsId = item.Id;
        editItNewsTitle = item.Title;
        editItNewsContent = item.Content;
    }

    private void CancelEditNewsItem()
    {
        editingItNewsId = null;
        editItNewsTitle = string.Empty;
        editItNewsContent = string.Empty;
    }

    private async Task SaveEditedNewsItem()
    {
        if (itNewsItems == null || editingItNewsId == null || string.IsNullOrWhiteSpace(editItNewsTitle) || string.IsNullOrWhiteSpace(editItNewsContent))
            return;

        var item = itNewsItems.FirstOrDefault(x => x.Id == editingItNewsId.Value);
        if (item == null)
            return;

        item.Title = editItNewsTitle.Trim();
        item.Content = editItNewsContent.Trim();

        var userName = await GetCurrentUserNameAsync();
        await Logger.LogActivityAsync(userName, $"Edited IT News Item {item.Title}");

        await SaveNewsAndShowStatus();
        CancelEditNewsItem();
    }

    private async Task DeleteNewsItem(ItNewsItem item)
    {
        if (itNewsItems == null)
            return;

        var itemTitle = item.Title;

        itNewsItems.Remove(item);
        if (editingItNewsId == item.Id)
        {
            CancelEditNewsItem();
        }

        var userName = await GetCurrentUserNameAsync();
        await Logger.LogActivityAsync(userName, $"Deleted IT News Item {itemTitle}");

        await SaveNewsAndShowStatus();
    }

    private async Task SaveNewsAndShowStatus()
    {
        if (itNewsItems == null)
            return;

        await ItNewsService.SaveNewsAsync(itNewsItems);
        itNewsItems = await ItNewsService.LoadNewsAsync();

        showNewsSaveSuccess = true;
        StateHasChanged();

        await Task.Delay(2500);
        showNewsSaveSuccess = false;
        StateHasChanged();
    }


    private async Task<string> GetCurrentUserNameAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        return authState.User?.Identity?.Name ?? "anonymous";
    }


    private static string GetLeaderboardDisplayName(string? identityName)
    {
        if (string.IsNullOrWhiteSpace(identityName))
        {
            return "anonymous";
        }

        var emailLocalPart = identityName.Split('@')[0];
        if (string.IsNullOrWhiteSpace(emailLocalPart))
        {
            return "anonymous";
        }

        var firstName = emailLocalPart.Split('.')[0];
        return string.IsNullOrWhiteSpace(firstName) ? "anonymous" : firstName.Trim().ToLowerInvariant();
    }

    private void GeneratePassword()
    {
        generatedPassword = PasswordGenerator.GeneratePassword();
        showCopySuccess = false;
    }

    private async Task CopyPassword()
    {
        if (string.IsNullOrWhiteSpace(generatedPassword))
            return;

        await JS.InvokeVoidAsync("blazorCopyToClipboard", generatedPassword);

        showCopySuccess = true;
        StateHasChanged();

        await Task.Delay(1500);
        showCopySuccess = false;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("adminFlappyBird.dispose");
        }
        catch
        {
            // ignore dispose JS errors during shutdown
        }

        flappyDotNetRef?.Dispose();
    }
}
