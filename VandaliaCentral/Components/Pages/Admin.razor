    private static string GetLeaderboardDisplayName(string? identityName)
    {
        if (string.IsNullOrWhiteSpace(identityName))
        {
            return "anonymous";
        }

        var emailLocalPart = identityName.Split('@')[0];
        if (string.IsNullOrWhiteSpace(emailLocalPart))
        {
            return "anonymous";
        }

        var firstName = emailLocalPart.Split('.')[0];
        return string.IsNullOrWhiteSpace(firstName) ? "anonymous" : firstName.Trim().ToLowerInvariant();
    }

