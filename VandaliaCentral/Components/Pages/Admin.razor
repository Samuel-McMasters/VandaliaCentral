@page "/admin"
@using VandaliaCentral.Services
@using VandaliaCentral.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Identity.Client
@using Microsoft.Identity.Web
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject ItNewsService ItNewsService
@inject ItProjectTrackerService ItProjectTrackerService
@inject LoggingService Logger
@inject GraphUserService GraphUserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ITokenAcquisition TokenAcquisition
@inject MicrosoftIdentityConsentAndConditionalAccessHandler ConsentHandler
@inject IPasswordGeneratorService PasswordGenerator
@inject FlappyLeaderboardService FlappyLeaderboardService
@inject SowDocumentService SowDocumentService
@inject KnowledgeBaseService KnowledgeBaseService
@implements IAsyncDisposable


<div class="container-fluid border rounded bg-white shadow-sm col-md-12 py-4 admin-dashboard-shell">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 pb-4 border-bottom mb-4">
        <div>
            <h3 class="mb-1">Admin Dashboard</h3>
        </div>

    @if (!isAuthorized)
    {

        <p class="text-danger">Refresh the page, or please wait while we check your authorizations...</p>
    }
    else
    {
        <div class="ms-auto">
            <NavLink href="https://vandaliarental.targit.cloud/#vfs://global/Service/R%20Status%20Priority.xview" class="btn btn-dark" activeClass="active" target="_blank">

                @(isMobile ? "Targit Dashboard" : "My Targit Dashboard")
            </NavLink>
        </div>
    }
    </div>

    @if (isAuthorized)
    {
        <div class="admin-layout">
            <aside class="admin-nav-panel border rounded bg-light-subtle p-3">
                <h6 class="text-uppercase text-muted small mb-3">Admin sections</h6>

                <div class="admin-tab-grid" id="adminTabs" role="tablist">
                    <button class='btn text-start admin-tab-button @(IsActiveTab("logs"))' @onclick='() => SetActiveTab("logs")' type='button'>
                        <span class="fw-semibold d-block">Logs</span>
                        <small class="text-muted">Review system logs quickly</small>
                    </button>
                    <button class='btn text-start admin-tab-button @(IsActiveTab("calendar"))' @onclick='() => SetActiveTab("calendar")' type='button'>
                        <span class="fw-semibold d-block">Company Calendar</span>
                        <small class="text-muted">Publish internal calendar events</small>
                    </button>
                    <button class='btn text-start admin-tab-button @(IsActiveTab("itnews"))' @onclick='() => SetActiveTab("itnews")' type='button'>
                        <span class="fw-semibold d-block">IT News</span>
                        <small class="text-muted">Post and edit IT announcements</small>
                    </button>
                    <button class='btn text-start admin-tab-button @(IsActiveTab("sowdocs"))' @onclick='() => SetActiveTab("sowdocs")' type='button'>
                        <span class="fw-semibold d-block">SOW Documents</span>
                        <small class="text-muted">Upload and curate SOW PDFs</small>
                    </button>
                    <button class='btn text-start admin-tab-button @(IsActiveTab("mondayminute"))' @onclick='() => SetActiveTab("mondayminute")' type='button'>
                        <span class="fw-semibold d-block">Monday Minute</span>
                        <small class="text-muted">Access Monday Minute manager</small>
                    </button>
                    <button class='btn text-start admin-tab-button @(IsActiveTab("passwords"))' @onclick='() => SetActiveTab("passwords")' type='button'>
                        <span class="fw-semibold d-block">Password Generator</span>
                        <small class="text-muted">Generate quick secure passwords</small>
                    </button>
                    <button class='btn text-start admin-tab-button @(IsActiveTab("projecttracker"))' @onclick='() => SetActiveTab("projecttracker")' type='button'>
                        <span class="fw-semibold d-block">IT Project Tracker</span>
                        <small class="text-muted">Track project milestones</small>
                    </button>
                    <button class='btn text-start admin-tab-button @(IsActiveTab("knowledgebase"))' @onclick='() => SetActiveTab("knowledgebase")' type='button'>
                        <span class="fw-semibold d-block">Knowledge Base</span>
                        <small class="text-muted">Manage folders and articles</small>
                    </button>
                    <button class='btn text-start admin-tab-button @(IsActiveTab("flappybird"))' @onclick='() => SetActiveTab("flappybird")' type='button'>
                        <span class="fw-semibold d-block">Flappy Bird</span>
                        <small class="text-muted">Review challenge leaderboards</small>
                    </button>
                </div>
            </aside>

            <section class="admin-content-panel border rounded p-3 p-md-4">
                @if (!string.IsNullOrWhiteSpace(GetTabHeading(activeTab)))
                {
                    <h5 class="mb-4">@GetTabHeading(activeTab)</h5>
                }




        @if (activeTab == "logs")
        {
            <div>
                <h5>Log Viewer</h5>

                @if (logFiles == null)
                {
                    <p>Loading logs...</p>
                }
                else
                {
                    <select @onchange="OnLogSelected" class="form-select w-25 mb-3">
                        <option disabled selected value="">-- Select Log File --</option>
                        @foreach (var file in logFiles)
                        {
                            <option value="@file">@file</option>
                        }
                    </select>

                    @if (!string.IsNullOrEmpty(logContent))
                    {
                        <div style="max-height: 400px; overflow-y: auto;">
                            <pre class="bg-light p-3 border rounded" style="white-space: pre-wrap;">@logContent</pre>
                        </div>
                    }
                }
            </div>
        }

        @if (activeTab == "calendar")
        {
            <CompanyCalendarManager />
        }

        @if (activeTab == "itnews")
        {
            <div>
                        <h5>IT News Manager</h5>
                <div class="border rounded p-3 mb-4" style="max-width: 700px;">
                    
                    <h6>Add IT News Item</h6>
                    <label class="mt-2">Title:</label>
                    <InputText @bind-Value="newItNewsTitle" class="form-control" />

                    <label class="mt-2">News Content:</label>
                    <InputTextArea @bind-Value="newItNewsContent" rows="4" class="form-control" />

                    <label class="mt-2">Expiration Date (optional):</label>
                    <InputDate @bind-Value="newItNewsExpirationDate" TValue="DateTime?" class="form-control" />

                    <div class="form-check form-switch mt-3">
                        <InputCheckbox id="newItNewsArchivable" @bind-Value="newItNewsArchivable" class="form-check-input" />
                        <label class="form-check-label" for="newItNewsArchivable">Archivable: @(newItNewsArchivable ? "Yes" : "No")</label>
                    </div>

                    <button class="btn btn-success mt-3" @onclick="AddNewsItem">Add News Item</button>
                </div>

                @if (itNewsItems == null)
                {
                    <p>Loading IT news...</p>
                }
                else if (!itNewsItems.Any())
                {
                    <p class="text-muted">No IT news items yet.</p>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var item in itNewsItems)
                        {
                            <li class="list-group-item">
                                @if (editingItNewsId == item.Id)
                                {
                                    <label>Title:</label>
                                    <InputText @bind-Value="editItNewsTitle" class="form-control mb-2" />

                                    <label>News Content:</label>
                                    <InputTextArea @bind-Value="editItNewsContent" rows="4" class="form-control" />

                                    <label class="mt-2">Expiration Date (optional):</label>
                                    <InputDate @bind-Value="editItNewsExpirationDate" TValue="DateTime?" class="form-control" />

                                    <div class="form-check form-switch mt-3">
                                        <InputCheckbox id="@($"editItNewsArchivable-{item.Id}")" @bind-Value="editItNewsArchivable" class="form-check-input" />
                                        <label class="form-check-label" for="@($"editItNewsArchivable-{item.Id}")">Archivable: @(editItNewsArchivable ? "Yes" : "No")</label>
                                    </div>

                                    <div class="d-flex gap-2 mt-3">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveEditedNewsItem">Save</button>
                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditNewsItem">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div>
                                            <strong>@item.Title</strong>
                                            <div class="text-muted small">@item.PostedOn.ToLocalTime().ToString("MMM d, yyyy")</div>
                                            @if (item.ExpirationDate.HasValue)
                                            {
                                                <div class="text-muted small">Expires: @item.ExpirationDate.Value.ToString("MMM d, yyyy")</div>
                                            }
                                            <div class="text-muted small">Archivable: @(item.Archivable ? "Yes" : "No")</div>
                                            <div style="white-space: pre-wrap;">@item.Content</div>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditNewsItem(item)">Edit</button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteNewsItem(item)">Delete</button>
                                        </div>
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }

                @if (showNewsSaveSuccess)
                {
                    <div class="text-success fw-bold mt-3">✓ IT news saved!</div>
                }
            </div>
        }

        @if (activeTab == "sowdocs")
        {
            <div>
                <h5>Scope of Work Documents</h5>
                <div class="pt-2 pb-3 d-flex flex-wrap gap-3 align-items-center">
                    <label class="btn btn-primary text-nowrap">
                        Upload SOW PDF
                        <InputFile OnChange="HandleSowFileUpload" accept=".pdf,application/pdf" class="d-none" />
                    </label>

                    @if (!string.IsNullOrWhiteSpace(sowUploadStatus))
                    {
                        <span class="badge bg-secondary fs-6">@sowUploadStatus</span>
                    }
                </div>

                @if (sowDocuments == null)
                {
                    <p>Loading SOW documents...</p>
                }
                else if (!sowDocuments.Any())
                {
                    <p class="text-muted">No SOW documents uploaded yet.</p>
                }
                else
                {
                    <ul class="list-group" style="max-width: 900px;">
                        @foreach (var document in sowDocuments)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center gap-3">
                                <div>
                                    <div class="fw-semibold">@document.Title</div>
                                    <div class="text-muted small">@document.FileName</div>
                                </div>
                                <div class="d-flex gap-2">
                                    <a class="btn btn-sm btn-outline-primary" href="@document.Url" target="_blank" rel="noopener noreferrer">View</a>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteSowDocument(document)">Delete</button>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        }

        @if (activeTab == "mondayminute")
        {
            <MondayMinuteManager />
        }

        @if (activeTab == "passwords")
        {
            <div>
                <h5>Password Generator</h5>
                <p class="text-muted mb-3">
                    2 words (≤ 5 chars each) + a number + a special character
                </p>

                <div class="d-flex align-items-center gap-2" style="max-width: 520px;">
                    <button class="btn btn-primary" @onclick="GeneratePassword">
                        Generate
                    </button>

                    <input class="form-control" value="@generatedPassword" readonly />

                    <button class="btn btn-outline-secondary"
                            @onclick="CopyPassword"
                            disabled="@string.IsNullOrWhiteSpace(generatedPassword)">
                        Copy
                    </button>
                </div>

                @if (showCopySuccess)
                {
                    <div class="text-success fw-bold mt-2">✓ Copied!</div>
                }
            </div>
        }

        @if (activeTab == "projecttracker")
        {
            <div>
                <h5>IT Project Tracker</h5>
                <p class="text-muted">Track your personal IT projects and contributions.</p>

                <div class="border rounded p-3 mb-4" style="max-width: 900px;">
                    <h6>Add Project Contribution</h6>
                    <label class="mt-2">Title:</label>
                    <InputText @bind-Value="newProjectTitle" class="form-control" />

                    <label class="mt-2">Notes:</label>
                    <InputTextArea @bind-Value="newProjectNotes" rows="4" class="form-control" />

                    <label class="mt-2">Completed Date:</label>
                    <InputDate @bind-Value="newProjectCompletedDate" class="form-control" />

                    <button class="btn btn-success mt-3" @onclick="AddProjectItem">Add Project</button>
                </div>

                @if (itProjectItems == null)
                {
                    <p>Loading your project entries...</p>
                }
                else
                {
                    <div class="mb-3">
                        <a class="btn btn-outline-primary"
                           href="/api/it-project-tracker/download"
                           download>
                            Download PDF
                        </a>
                    </div>

                    @if (!itProjectItems.Any())
                    {
                        <p class="text-muted">You do not have any project entries yet.</p>
                    }
                    else
                    {
                        <ul class="list-group" style="max-width: 900px;">
                        @foreach (var item in itProjectItems)
                        {
                            <li class="list-group-item">
                                @if (editingProjectId == item.Id)
                                {
                                    <label>Title:</label>
                                    <InputText @bind-Value="editProjectTitle" class="form-control mb-2" />

                                    <label>Notes:</label>
                                    <InputTextArea @bind-Value="editProjectNotes" rows="4" class="form-control mb-2" />

                                    <label>Completed Date:</label>
                                    <InputDate @bind-Value="editProjectCompletedDate" class="form-control" />

                                    <div class="d-flex gap-2 mt-3">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveEditedProjectItem">Save</button>
                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditProjectItem">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div>
                                            <strong>@item.Title</strong>
                                            <div class="text-muted small">Completed: @(item.CompletedDate.HasValue ? item.CompletedDate.Value.ToString("MMM d, yyyy") : "Not set")</div>
                                            <div style="white-space: pre-wrap;">@item.Notes</div>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditProjectItem(item)">Edit</button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteProjectItem(item)">Delete</button>
                                        </div>
                                    </div>
                                }
                            </li>
                        }
                        </ul>
                    }
                }

                @if (showProjectSaveSuccess)
                {
                    <div class="text-success fw-bold mt-3">✓ Project tracker saved!</div>
                }
            </div>
        }

        @if (activeTab == "knowledgebase")
        {
            <div class="knowledge-base-admin d-flex flex-column gap-4">
                <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
                    <div>
                        <h5 class="mb-1">Knowledge Base Manager</h5>
                        <p class="text-muted mb-0">Manage folders, articles, and Entra security controls in one place.</p>
                    </div>
                    @if (isLoadingEntraGroups)
                    {
                        <span class="badge text-bg-light">Loading Entra groups...</span>
                    }
                    else
                    {
                        <span class="badge text-bg-light">@entraGroups.Count Entra group(s) available</span>
                    }
                </div>

                <div class="kb-admin-grid">
                    <section class="border rounded p-3 kb-admin-card">
                        <h6 class="mb-3">Security Tags</h6>
                        <p class="text-muted small mb-3">Create reusable tags and map Entra groups to each tag.</p>

                        <label class="form-label">Tag Name</label>
                        <InputText @bind-Value="newKnowledgeSecurityTagName" class="form-control" placeholder="e.g. Rental" />
                        <button class="btn btn-success btn-sm mt-2" @onclick="AddKnowledgeSecurityTag">Add Security Tag</button>

                        @if (!string.IsNullOrWhiteSpace(knowledgeBaseSecurityStatusMessage))
                        {
                            <div class="alert alert-info py-2 mt-3 mb-0">@knowledgeBaseSecurityStatusMessage</div>
                        }

                        <div class="mt-3 kb-scroll">
                            @if (knowledgeBaseSecurityTags == null || !knowledgeBaseSecurityTags.Any())
                            {
                                <p class="text-muted mb-0">No security tags yet.</p>
                            }
                            else
                            {
                                @foreach (var tag in knowledgeBaseSecurityTags)
                                {
                                    <div class="border rounded p-2 mb-2">
                                        <div class="d-flex justify-content-between align-items-center gap-2">
                                            <div class="fw-semibold">@tag.Name</div>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteKnowledgeSecurityTag(tag)">Delete</button>
                                        </div>
                                        <div class="text-muted small mt-1">Allowed groups: @GetTagGroupSummary(tag)</div>
                                        <details class="mt-2">
                                            <summary class="small text-primary" style="cursor:pointer;">Edit group access</summary>
                                            <div class="mt-2 kb-scroll-inner">
                                                @if (!entraGroups.Any())
                                                {
                                                    <p class="text-muted mb-0 small">No Entra groups available.</p>
                                                }
                                                else
                                                {
                                                    @foreach (var group in entraGroups)
                                                    {
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox"
                                                                   checked="@IsGroupAssignedToTag(tag, group.Id)"
                                                                   @onchange="args => ToggleTagGroup(tag, group.Id, args.Value)" />
                                                            <label class="form-check-label small">@group.DisplayName</label>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </details>
                                    </div>
                                }
                            }
                        </div>
                    </section>

                    <section class="border rounded p-3 kb-admin-card">
                        <h6 class="mb-3">Folders &amp; Articles</h6>

                        <div class="border rounded p-2 mb-3">
                            <h6 class="mb-2">Add Folder</h6>
                            <InputText @bind-Value="newKnowledgeFolderName" class="form-control" placeholder="Folder name" />
                            <button class="btn btn-success btn-sm mt-2" @onclick="AddKnowledgeFolder">Add Folder</button>
                        </div>

                        <div class="border rounded p-2 mb-3">
                            <h6 class="mb-2">Add Article</h6>
                            <select @bind="selectedFolderForNewArticleId" class="form-select mb-2">
                                <option value="">-- Select Folder --</option>
                                @if (knowledgeBaseFolders != null)
                                {
                                    @foreach (var folder in knowledgeBaseFolders)
                                    {
                                        <option value="@folder.Id.ToString()">@folder.Name</option>
                                    }
                                }
                            </select>
                            <InputText @bind-Value="newKnowledgeArticleTitle" class="form-control mb-2" placeholder="Article title" />
                            <InputText @bind-Value="newKnowledgeArticleEmbedUrl" class="form-control" placeholder="Scribe iframe link" />
                            <button class="btn btn-success btn-sm mt-2" @onclick="AddKnowledgeArticle">Add Article</button>
                        </div>

                        @if (knowledgeBaseFolders == null)
                        {
                            <p>Loading knowledge base...</p>
                        }
                        else if (!knowledgeBaseFolders.Any())
                        {
                            <p class="text-muted mb-0">No folders have been created yet.</p>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-3">
                                @foreach (var folder in knowledgeBaseFolders)
                                {
                                    <div class="border rounded p-3">
                                        @if (editingKnowledgeFolderId == folder.Id)
                                        {
                                            <InputText @bind-Value="editKnowledgeFolderName" class="form-control" />
                                            <div class="d-flex gap-2 mt-2">
                                                <button class="btn btn-sm btn-primary" @onclick="SaveEditedKnowledgeFolder">Save</button>
                                                <button class="btn btn-sm btn-secondary" @onclick="CancelEditKnowledgeFolder">Cancel</button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                                <h6 class="mb-0">@folder.Name</h6>
                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditKnowledgeFolder(folder)">Edit Folder</button>
                                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteKnowledgeFolder(folder)">Delete Folder</button>
                                                </div>
                                            </div>
                                        }

                                        <div class="kb-security-pillbox mb-2">
                                            <div class="small fw-semibold">Folder Security</div>
                                            <div class="small text-muted">Tags: @GetTagSummary(folder.SecurityTagIds)</div>
                                            <div class="small text-muted">Direct groups: @GetGroupSummary(folder.AllowedGroupIds)</div>
                                        </div>
                                        <details>
                                            <summary class="small text-primary" style="cursor:pointer;">Edit folder security</summary>
                                            <div class="mt-2 row g-3">
                                                <div class="col-12 col-lg-6">
                                                    <div class="small fw-semibold mb-1">Security Tags</div>
                                                    @if (knowledgeBaseSecurityTags == null || !knowledgeBaseSecurityTags.Any())
                                                    {
                                                        <div class="text-muted small">No tags created.</div>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var tag in knowledgeBaseSecurityTags)
                                                        {
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox"
                                                                       checked="@folder.SecurityTagIds.Contains(tag.Id)"
                                                                       @onchange="args => ToggleFolderTag(folder, tag.Id, args.Value)" />
                                                                <label class="form-check-label small">@tag.Name</label>
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                                <div class="col-12 col-lg-6">
                                                    <div class="small fw-semibold mb-1">Direct Entra Groups</div>
                                                    @if (!entraGroups.Any())
                                                    {
                                                        <div class="text-muted small">No groups available.</div>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var group in entraGroups)
                                                        {
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox"
                                                                       checked="@folder.AllowedGroupIds.Contains(group.Id, StringComparer.OrdinalIgnoreCase)"
                                                                       @onchange="args => ToggleFolderGroup(folder, group.Id, args.Value)" />
                                                                <label class="form-check-label small">@group.DisplayName</label>
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            </div>
                                        </details>

                                        @if (!folder.Articles.Any())
                                        {
                                            <p class="text-muted mb-0 mt-2">No articles in this folder.</p>
                                        }
                                        else
                                        {
                                            <ul class="list-group mt-2">
                                                @foreach (var article in folder.Articles)
                                                {
                                                    <li class="list-group-item">
                                                        @if (editingKnowledgeArticleId == article.Id)
                                                        {
                                                            <InputText @bind-Value="editKnowledgeArticleTitle" class="form-control mb-2" />
                                                            <InputText @bind-Value="editKnowledgeArticleEmbedUrl" class="form-control mb-2" />
                                                            <select @bind="editKnowledgeArticleFolderId" class="form-select mb-2">
                                                                @if (knowledgeBaseFolders != null)
                                                                {
                                                                    @foreach (var availableFolder in knowledgeBaseFolders)
                                                                    {
                                                                        <option value="@availableFolder.Id.ToString()">@availableFolder.Name</option>
                                                                    }
                                                                }
                                                            </select>
                                                            <div class="kb-security-pillbox mb-2">
                                                                <div class="small text-muted">Tags: @GetTagSummary(editKnowledgeArticleTagIds)</div>
                                                                <div class="small text-muted">Direct groups: @GetGroupSummary(editKnowledgeArticleAllowedGroupIds)</div>
                                                            </div>
                                                            <details>
                                                                <summary class="small text-primary" style="cursor:pointer;">Edit article security</summary>
                                                                <div class="mt-2 row g-3">
                                                                    <div class="col-12 col-lg-6">
                                                                        <div class="small fw-semibold mb-1">Security Tags</div>
                                                                        @if (knowledgeBaseSecurityTags == null || !knowledgeBaseSecurityTags.Any())
                                                                        {
                                                                            <div class="text-muted small">No tags created.</div>
                                                                        }
                                                                        else
                                                                        {
                                                                            @foreach (var tag in knowledgeBaseSecurityTags)
                                                                            {
                                                                                <div class="form-check">
                                                                                    <input class="form-check-input" type="checkbox"
                                                                                           checked="@editKnowledgeArticleTagIds.Contains(tag.Id)"
                                                                                           @onchange="args => ToggleEditingArticleTag(tag.Id, args.Value)" />
                                                                                    <label class="form-check-label small">@tag.Name</label>
                                                                                </div>
                                                                            }
                                                                        }
                                                                    </div>
                                                                    <div class="col-12 col-lg-6">
                                                                        <div class="small fw-semibold mb-1">Direct Entra Groups</div>
                                                                        @if (!entraGroups.Any())
                                                                        {
                                                                            <div class="text-muted small">No groups available.</div>
                                                                        }
                                                                        else
                                                                        {
                                                                            @foreach (var group in entraGroups)
                                                                            {
                                                                                <div class="form-check">
                                                                                    <input class="form-check-input" type="checkbox"
                                                                                           checked="@editKnowledgeArticleAllowedGroupIds.Contains(group.Id, StringComparer.OrdinalIgnoreCase)"
                                                                                           @onchange="args => ToggleEditingArticleGroup(group.Id, args.Value)" />
                                                                                    <label class="form-check-label small">@group.DisplayName</label>
                                                                                </div>
                                                                            }
                                                                        }
                                                                    </div>
                                                                </div>
                                                            </details>
                                                            <div class="d-flex gap-2 mt-2">
                                                                <button class="btn btn-sm btn-primary" @onclick="SaveEditedKnowledgeArticle">Save</button>
                                                                <button class="btn btn-sm btn-secondary" @onclick="CancelEditKnowledgeArticle">Cancel</button>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="d-flex justify-content-between align-items-start gap-2">
                                                                <div>
                                                                    <div class="fw-semibold">@article.Title</div>
                                                                    <div class="text-muted small" style="word-break: break-all;">@article.EmbedUrl</div>
                                                                    <div class="text-muted small mt-1">Tags: @GetTagSummary(article.SecurityTagIds)</div>
                                                                    <div class="text-muted small">Direct groups: @GetGroupSummary(article.AllowedGroupIds)</div>
                                                                </div>
                                                                <div class="d-flex gap-2">
                                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditKnowledgeArticle(folder, article)">Edit</button>
                                                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteKnowledgeArticle(folder, article)">Delete</button>
                                                                </div>
                                                            </div>
                                                        }
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </section>
                </div>

                @if (!string.IsNullOrWhiteSpace(knowledgeBaseStatusMessage))
                {
                    <div class="text-success fw-bold">✓ @knowledgeBaseStatusMessage</div>
                }
            </div>
        }

        @if (activeTab == "flappybird")
        {
            <div>
                <p class="text-muted mb-3">
                    Press <strong>Space</strong> to flap and fly through the pipe gaps. Tight gaps, one hit ends the run.
                </p>

                <div class="d-flex flex-wrap gap-4 align-items-start">
                    <div>
                        <canvas id="adminFlappyCanvas" width="520" height="600" class="border rounded bg-light"></canvas>
                        <div class="d-flex gap-2 mt-3">
                            <button class="btn btn-primary" @onclick="StartFlappyGame">Start / Restart</button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(flappyStatusMessage))
                        {
                            <div class="mt-2 text-danger small">@flappyStatusMessage</div>
                        }
                        <div class="mt-2 small text-muted">
                            Signed in as: <strong>@currentUserName</strong>
                        </div>
                        @if (lastFlappyScore > 0)
                        {
                            <div class="mt-2 fw-semibold">Last score: @lastFlappyScore</div>
                        }
                    </div>

                    <div class="border rounded p-3" style="min-width: 280px;">
                        <h6 class="mb-3">Leaderboards (Top 5)</h6>

                        @if (flappyLeaderboards == null)
                        {
                            <p class="text-muted mb-0">Loading scores...</p>
                        }
                        else
                        {
                            @RenderLeaderboard("Daily Leaderboard", flappyLeaderboards.Daily)
                            @RenderLeaderboard("Weekly Leaderboard", flappyLeaderboards.Weekly)
                            @RenderLeaderboard("Monthly Leaderboard", flappyLeaderboards.Monthly)
                            @RenderLeaderboard("All Time Leaderboard", flappyLeaderboards.AllTime, false)
                        }
                    </div>
                </div>
            </div>
        }
            </section>
        </div>
    }
</div>

