    private async Task AddKnowledgeArticle()
    {
        if (knowledgeBaseFolders == null ||
            string.IsNullOrWhiteSpace(selectedFolderForNewArticleId) ||
            string.IsNullOrWhiteSpace(newKnowledgeArticleTitle) ||
            string.IsNullOrWhiteSpace(newKnowledgeArticleEmbedUrl))
        {
            return;
        }

        if (!Guid.TryParse(selectedFolderForNewArticleId, out var folderId))
            return;

        var folder = knowledgeBaseFolders.FirstOrDefault(x => x.Id == folderId);
        if (folder == null)
            return;

        var articleTitle = newKnowledgeArticleTitle.Trim();
        var embedUrl = NormalizeScribeEmbedUrl(newKnowledgeArticleEmbedUrl);
        if (string.IsNullOrWhiteSpace(embedUrl))
            return;

        folder.Articles.Add(new KnowledgeBaseArticleItem
        {
            Id = Guid.NewGuid(),
            Title = articleTitle,
            EmbedUrl = embedUrl,
            CreatedOn = DateTime.UtcNow,
            SecurityTagIds = new List<Guid>(),
            AllowedGroupIds = new List<string>()
        });

        var userName = await GetCurrentUserNameAsync();
        await Logger.LogActivityAsync(userName, $"Added Knowledge Base article {articleTitle} to folder {folder.Name}");

        newKnowledgeArticleTitle = string.Empty;
        newKnowledgeArticleEmbedUrl = string.Empty;

        await SaveKnowledgeBaseAndShowStatus("Knowledge base saved!");
    }

    private void StartEditKnowledgeArticle(KnowledgeBaseFolderItem folder, KnowledgeBaseArticleItem article)
    {
        editingKnowledgeFolderForArticleId = folder.Id;
        editingKnowledgeArticleId = article.Id;
        editKnowledgeArticleTitle = article.Title;
        editKnowledgeArticleEmbedUrl = article.EmbedUrl;
        editKnowledgeArticleFolderId = folder.Id.ToString();
        editKnowledgeArticleTagIds = article.SecurityTagIds.ToList();
        editKnowledgeArticleAllowedGroupIds = article.AllowedGroupIds.ToList();
    }

    private void CancelEditKnowledgeArticle()
    {
        editingKnowledgeFolderForArticleId = null;
        editingKnowledgeArticleId = null;
        editKnowledgeArticleTitle = string.Empty;
        editKnowledgeArticleEmbedUrl = string.Empty;
        editKnowledgeArticleFolderId = string.Empty;
        editKnowledgeArticleTagIds = new List<Guid>();
        editKnowledgeArticleAllowedGroupIds = new List<string>();
    }

    private async Task SaveEditedKnowledgeArticle()
    {
        if (knowledgeBaseFolders == null || editingKnowledgeFolderForArticleId == null || editingKnowledgeArticleId == null ||
            string.IsNullOrWhiteSpace(editKnowledgeArticleTitle) || string.IsNullOrWhiteSpace(editKnowledgeArticleEmbedUrl) ||
            !Guid.TryParse(editKnowledgeArticleFolderId, out var targetFolderId))
            return;

        var sourceFolder = knowledgeBaseFolders.FirstOrDefault(x => x.Id == editingKnowledgeFolderForArticleId.Value);
        var targetFolder = knowledgeBaseFolders.FirstOrDefault(x => x.Id == targetFolderId);
        var article = sourceFolder?.Articles.FirstOrDefault(x => x.Id == editingKnowledgeArticleId.Value);
        if (article == null || sourceFolder == null || targetFolder == null)
            return;

        article.Title = editKnowledgeArticleTitle.Trim();
        article.EmbedUrl = NormalizeScribeEmbedUrl(editKnowledgeArticleEmbedUrl) ?? article.EmbedUrl;
        article.SecurityTagIds = editKnowledgeArticleTagIds.Distinct().ToList();
        article.AllowedGroupIds = editKnowledgeArticleAllowedGroupIds.Distinct(StringComparer.OrdinalIgnoreCase).ToList();

        if (sourceFolder.Id != targetFolder.Id)
        {
            sourceFolder.Articles.Remove(article);
            targetFolder.Articles.Add(article);
        }

        var userName = await GetCurrentUserNameAsync();
        await Logger.LogActivityAsync(userName, $"Edited Knowledge Base article {article.Title} in folder {targetFolder.Name}");

        await SaveKnowledgeBaseAndShowStatus("Knowledge base saved!");
        CancelEditKnowledgeArticle();
    }

    private async Task DeleteKnowledgeArticle(KnowledgeBaseFolderItem folder, KnowledgeBaseArticleItem article)
    {
        if (knowledgeBaseFolders == null)
            return;

        var articleTitle = article.Title;
        folder.Articles.Remove(article);

        if (editingKnowledgeArticleId == article.Id)
        {
            CancelEditKnowledgeArticle();
        }

        var userName = await GetCurrentUserNameAsync();
        await Logger.LogActivityAsync(userName, $"Deleted Knowledge Base article {articleTitle} from folder {folder.Name}");

        await SaveKnowledgeBaseAndShowStatus("Knowledge base saved!");
    }

    private async Task AddKnowledgeSecurityTag()
    {
        if (knowledgeBaseSecurityTags == null || string.IsNullOrWhiteSpace(newKnowledgeSecurityTagName))
        {
            return;
        }

        var tagName = newKnowledgeSecurityTagName.Trim();
        if (knowledgeBaseSecurityTags.Any(tag => string.Equals(tag.Name, tagName, StringComparison.OrdinalIgnoreCase)))
        {
            knowledgeBaseSecurityStatusMessage = "A security tag with that name already exists.";
            return;
        }

        knowledgeBaseSecurityTags.Add(new KnowledgeBaseSecurityTagItem
        {
            Id = Guid.NewGuid(),
            Name = tagName
        });

        newKnowledgeSecurityTagName = string.Empty;
        knowledgeBaseSecurityStatusMessage = "Security tag created.";
        await SaveKnowledgeBaseAndShowStatus("Knowledge base saved!");
    }

    private async Task DeleteKnowledgeSecurityTag(KnowledgeBaseSecurityTagItem tag)
    {
        if (knowledgeBaseSecurityTags == null || knowledgeBaseFolders == null)
        {
            return;
        }

        knowledgeBaseSecurityTags.Remove(tag);

        foreach (var folder in knowledgeBaseFolders)
        {
            folder.SecurityTagIds.RemoveAll(id => id == tag.Id);

            foreach (var article in folder.Articles)
            {
                article.SecurityTagIds.RemoveAll(id => id == tag.Id);
            }
        }

        knowledgeBaseSecurityStatusMessage = $"Removed security tag '{tag.Name}'.";
        await SaveKnowledgeBaseAndShowStatus("Knowledge base saved!");
    }

    private async Task ToggleTagGroup(KnowledgeBaseSecurityTagItem tag, string groupId, object? value)
    {
        var isChecked = value as bool? == true;

        if (isChecked)
        {
            if (!tag.AllowedGroupIds.Contains(groupId, StringComparer.OrdinalIgnoreCase))
            {
                tag.AllowedGroupIds.Add(groupId);
            }
        }
        else
        {
            tag.AllowedGroupIds.RemoveAll(id => string.Equals(id, groupId, StringComparison.OrdinalIgnoreCase));
        }

        await SaveKnowledgeBaseAndShowStatus("Knowledge base saved!");
    }

    private async Task ToggleFolderTag(KnowledgeBaseFolderItem folder, Guid tagId, object? value)
    {
        var isChecked = value as bool? == true;
        if (isChecked && !folder.SecurityTagIds.Contains(tagId))
        {
            folder.SecurityTagIds.Add(tagId);
        }
        else if (!isChecked)
        {
            folder.SecurityTagIds.RemoveAll(id => id == tagId);
        }

        await SaveKnowledgeBaseAndShowStatus("Knowledge base saved!");
    }

    private async Task ToggleFolderGroup(KnowledgeBaseFolderItem folder, string groupId, object? value)
    {
        var isChecked = value as bool? == true;
        if (isChecked)
        {
            if (!folder.AllowedGroupIds.Contains(groupId, StringComparer.OrdinalIgnoreCase))
            {
                folder.AllowedGroupIds.Add(groupId);
            }
        }
        else
        {
            folder.AllowedGroupIds.RemoveAll(id => string.Equals(id, groupId, StringComparison.OrdinalIgnoreCase));
        }

        await SaveKnowledgeBaseAndShowStatus("Knowledge base saved!");
    }

