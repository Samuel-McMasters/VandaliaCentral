    [JSInvokable]
    public async Task OnFlappyGameOver(int score)
    {
        lastFlappyScore = score;

        if (score > 0)
        {
            var currentTopScore = (await FlappyLeaderboardService.GetTopScoresAsync(1)).FirstOrDefault()?.Score ?? 0;
            var isNewHighScore = score > currentTopScore;

            await FlappyLeaderboardService.AddScoreAsync(currentUserName, score);
            flappyLeaderboards = await FlappyLeaderboardService.GetLeaderboardsAsync(5);

            if (isNewHighScore)
            {
                var fullUserName = await GetCurrentUserNameAsync();
                await Logger.LogActivityAsync(fullUserName, $"Set new Flappy Bird high score: {score}");
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private RenderFragment RenderLeaderboard(string title, List<FlappyScore> scores, bool addSpacing = true) => builder =>
    {
        var sequence = 0;

        builder.OpenElement(sequence++, "div");
        if (addSpacing)
        {
            builder.AddAttribute(sequence++, "class", "mb-3");
        }

        builder.OpenElement(sequence++, "h6");
        builder.AddAttribute(sequence++, "class", "mb-2");
        builder.AddContent(sequence++, title);
        builder.CloseElement();

        if (scores.Count == 0)
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "text-muted mb-0 small");
            builder.AddContent(sequence++, "No scores yet.");
            builder.CloseElement();
        }
        else
        {
            builder.OpenElement(sequence++, "ol");
            builder.AddAttribute(sequence++, "class", "mb-0 ps-3");

            foreach (var score in scores)
            {
                builder.OpenElement(sequence++, "li");
                builder.AddAttribute(sequence++, "class", "mb-1");

                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "fw-semibold");
                builder.AddContent(sequence++, score.UserName);
                builder.CloseElement();

                builder.AddContent(sequence++, $" — {score.Score}");
                builder.CloseElement();
            }

            builder.CloseElement();
        }

        builder.CloseElement();
    };

