    protected override async Task OnInitializedAsync()
    {
        try
        {
            var token = await TokenAcquisition.GetAccessTokenForUserAsync(new[] { "User.Read.All" });

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            signedInUserLogin = user?.Identity?.Name ?? "anonymous";
            currentUserName = GetLeaderboardDisplayName(signedInUserLogin);

            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst("http://schemas.microsoft.com/identity/claims/objectidentifier")?.Value;

                if (!string.IsNullOrEmpty(userId))
                {
                    isAuthorized = await GraphUserService.IsUserInGroupAsync(userId, adminGroupId);
                }
            }

            if (isAuthorized)
            {
                logFiles = await Logger.GetLogFileNamesAsync();
                itNewsItems = await ItNewsService.LoadNewsAsync();
                flappyLeaderboards = await FlappyLeaderboardService.GetLeaderboardsAsync(5);
                sowDocuments = await SowDocumentService.ListDocumentsAsync();
                itProjectItems = await ItProjectTrackerService.LoadItemsAsync(signedInUserLogin);
                await LoadKnowledgeBaseStateAsync();
                await LoadEntraGroupsAsync();
            }
        }
        catch (MsalUiRequiredException ex)
        {
            ConsentHandler.HandleException(ex);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Unexpected error during token acquisition or group check: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var width = await JS.InvokeAsync<int>("blazorGetWindowWidth");
            isMobile = width < 768;
            StateHasChanged();
        }

        if (activeTab == "flappybird" && !flappyInitialized)
        {
            await InitializeFlappyGameAsync();
        }

        if (activeTab != "flappybird" && flappyInitialized)
        {
            await JS.InvokeVoidAsync("adminFlappyBird.dispose");
            flappyInitialized = false;
        }
    }

    private async Task<bool> InitializeFlappyGameAsync(bool force = false)
    {
        if (flappyInitialized && !force)
        {
            return true;
        }

        flappyDotNetRef?.Dispose();
        flappyDotNetRef = DotNetObjectReference.Create(this);
        flappyInitialized = await JS.InvokeAsync<bool>("adminFlappyBird.init", "adminFlappyCanvas", flappyDotNetRef);
        return flappyInitialized;
    }

    private async Task StartFlappyGame()
    {
        flappyStatusMessage = null;

        try
        {
            var initialized = await InitializeFlappyGameAsync();
            if (!initialized)
            {
                await Task.Delay(50);
                initialized = await InitializeFlappyGameAsync(force: true);
            }

            if (!initialized)
            {
                flappyStatusMessage = "Game canvas was not ready. Please try again.";
                return;
            }

            var started = await JS.InvokeAsync<bool>("adminFlappyBird.start");
            if (!started)
            {
                flappyInitialized = false;
                flappyStatusMessage = "Unable to start game. Please click Start again.";
            }
        }
        catch
        {
            flappyInitialized = false;
            flappyStatusMessage = "Unable to start game due to a script error. Please refresh and try again.";
        }
    }

    [JSInvokable]
    public async Task OnFlappyGameOver(int score)
    {
        lastFlappyScore = score;

        if (score > 0)
        {
            var currentTopScore = (await FlappyLeaderboardService.GetTopScoresAsync(1)).FirstOrDefault()?.Score ?? 0;
            var isNewHighScore = score > currentTopScore;

            await FlappyLeaderboardService.AddScoreAsync(currentUserName, score);
            flappyLeaderboards = await FlappyLeaderboardService.GetLeaderboardsAsync(5);

            if (isNewHighScore)
            {
                var fullUserName = await GetCurrentUserNameAsync();
                await Logger.LogActivityAsync(fullUserName, $"Set new Flappy Bird high score: {score}");
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private RenderFragment RenderLeaderboard(string title, List<FlappyScore> scores, bool addSpacing = true) => builder =>
    {
        var sequence = 0;

        builder.OpenElement(sequence++, "div");
        if (addSpacing)
        {
            builder.AddAttribute(sequence++, "class", "mb-3");
        }

        builder.OpenElement(sequence++, "h6");
        builder.AddAttribute(sequence++, "class", "mb-2");
        builder.AddContent(sequence++, title);
        builder.CloseElement();

        if (scores.Count == 0)
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "text-muted mb-0 small");
            builder.AddContent(sequence++, "No scores yet.");
            builder.CloseElement();
        }
        else
        {
            builder.OpenElement(sequence++, "ol");
            builder.AddAttribute(sequence++, "class", "mb-0 ps-3");

            foreach (var score in scores)
            {
                builder.OpenElement(sequence++, "li");
                builder.AddAttribute(sequence++, "class", "mb-1");

                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "fw-semibold");
                builder.AddContent(sequence++, score.UserName);
                builder.CloseElement();

                builder.AddContent(sequence++, $" — {score.Score}");
                builder.CloseElement();
            }

            builder.CloseElement();
        }

        builder.CloseElement();
    };

