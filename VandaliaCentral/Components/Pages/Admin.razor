@page "/admin"
@using VandaliaCentral.Services
@using VandaliaCentral.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Identity.Client
@using Microsoft.Identity.Web
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject ItNewsService ItNewsService
@inject ItProjectTrackerService ItProjectTrackerService
@inject LoggingService Logger
@inject GraphUserService GraphUserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ITokenAcquisition TokenAcquisition
@inject MicrosoftIdentityConsentAndConditionalAccessHandler ConsentHandler
@inject IPasswordGeneratorService PasswordGenerator
@inject FlappyLeaderboardService FlappyLeaderboardService
@inject SowDocumentService SowDocumentService
@inject KnowledgeBaseService KnowledgeBaseService
@implements IAsyncDisposable


<div class="container-fluid border rounded bg-white shadow-sm col-md-12 py-4">
    <h3 class="pb-5">Admin Dashboard</h3>

    @if (!isAuthorized)
    {

        <p class="text-danger">Refresh the page, or please wait while we check your authorizations...</p>
    }
    else
    {
        <div class="ms-auto pb-5">
            <NavLink href="https://vandaliarental.targit.cloud/#vfs://global/Service/R%20Status%20Priority.xview" class="btn btn-dark" activeClass="active" target="_blank">

                @(isMobile ? "Targit Dashboard" : "My Targit Dashboard")
            </NavLink>
        </div>

        <!-- Tab Navigation -->
        <ul class="nav nav-tabs mb-4" id="adminTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("logs"))' @onclick='() => SetActiveTab("logs")' type='button'>
                    Logs
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("calendar"))' @onclick='() => SetActiveTab("calendar")' type='button'>
                    Company Calendar
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("itnews"))' @onclick='() => SetActiveTab("itnews")' type='button'>
                    IT News
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("sowdocs"))' @onclick='() => SetActiveTab("sowdocs")' type='button'>
                    SOW Documents
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("mondayminute"))' @onclick='() => SetActiveTab("mondayminute")' type='button'>
                    Monday Minute
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("passwords"))' @onclick='() => SetActiveTab("passwords")' type='button'>
                    Password Generator
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("projecttracker"))' @onclick='() => SetActiveTab("projecttracker")' type='button'>
                    IT Project Tracker
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("knowledgebase"))' @onclick='() => SetActiveTab("knowledgebase")' type='button'>
                    Knowledge Base
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class='nav-link @(IsActiveTab("flappybird"))' @onclick='() => SetActiveTab("flappybird")' type='button'>
                    Flappy Bird
                </button>
            </li>


        </ul>

        @if (activeTab == "logs")
        {
            <div>
                <h5>Log Viewer</h5>

                @if (logFiles == null)
                {
                    <p>Loading logs...</p>
                }
                else
                {
                    <select @onchange="OnLogSelected" class="form-select w-25 mb-3">
                        <option disabled selected value="">-- Select Log File --</option>
                        @foreach (var file in logFiles)
                        {
                            <option value="@file">@file</option>
                        }
                    </select>

                    @if (!string.IsNullOrEmpty(logContent))
                    {
                        <div style="max-height: 400px; overflow-y: auto;">
                            <pre class="bg-light p-3 border rounded" style="white-space: pre-wrap;">@logContent</pre>
                        </div>
                    }
                }
            </div>
        }

        @if (activeTab == "calendar")
        {
            <CompanyCalendarManager />
        }

        @if (activeTab == "itnews")
        {
            <div>
                <h5>IT News Manager</h5>

                <div class="border rounded p-3 mb-4" style="max-width: 700px;">
                    <h6>Add IT News Item</h6>
                    <label class="mt-2">Title:</label>
                    <InputText @bind-Value="newItNewsTitle" class="form-control" />

                    <label class="mt-2">News Content:</label>
                    <InputTextArea @bind-Value="newItNewsContent" rows="4" class="form-control" />

                    <label class="mt-2">Expiration Date (optional):</label>
                    <InputDate @bind-Value="newItNewsExpirationDate" TValue="DateTime?" class="form-control" />

                    <label class="mt-2 d-block">Archivable</label>
                    <InputCheckbox @bind-Value="newItNewsArchivable" class="form-check-input" />
                    <span class="ms-2">@(newItNewsArchivable ? "Yes" : "No")</span>

                    <button class="btn btn-success mt-3" @onclick="AddNewsItem">Add News Item</button>
                </div>

                @if (itNewsItems == null)
                {
                    <p>Loading IT news...</p>
                }
                else if (!itNewsItems.Any())
                {
                    <p class="text-muted">No IT news items yet.</p>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var item in itNewsItems)
                        {
                            <li class="list-group-item">
                                @if (editingItNewsId == item.Id)
                                {
                                    <label>Title:</label>
                                    <InputText @bind-Value="editItNewsTitle" class="form-control mb-2" />

                                    <label>News Content:</label>
                                    <InputTextArea @bind-Value="editItNewsContent" rows="4" class="form-control" />

                                    <label class="mt-2">Expiration Date (optional):</label>
                                    <InputDate @bind-Value="editItNewsExpirationDate" TValue="DateTime?" class="form-control" />

                                    <label class="mt-2 d-block">Archivable</label>
                                    <InputCheckbox @bind-Value="editItNewsArchivable" class="form-check-input" />
                                    <span class="ms-2">@(editItNewsArchivable ? "Yes" : "No")</span>

                                    <div class="d-flex gap-2 mt-3">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveEditedNewsItem">Save</button>
                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditNewsItem">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div>
                                            <strong>@item.Title</strong>
                                            <div class="text-muted small">@item.PostedOn.ToLocalTime().ToString("MMM d, yyyy")</div>
                                            @if (item.ExpirationDate.HasValue)
                                            {
                                                <div class="text-muted small">Expires: @item.ExpirationDate.Value.ToString("MMM d, yyyy")</div>
                                            }
                                            <div class="text-muted small">Archivable: @(item.Archivable ? "Yes" : "No")</div>
                                            <div style="white-space: pre-wrap;">@item.Content</div>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditNewsItem(item)">Edit</button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteNewsItem(item)">Delete</button>
                                        </div>
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }

                @if (showNewsSaveSuccess)
                {
                    <div class="text-success fw-bold mt-3">✓ IT news saved!</div>
                }
            </div>
        }

        @if (activeTab == "sowdocs")
        {
            <div>
                <h5>Scope of Work Documents</h5>

                <div class="pt-2 pb-3 d-flex flex-wrap gap-3 align-items-center">
                    <label class="btn btn-primary text-nowrap">
                        Upload SOW PDF
                        <InputFile OnChange="HandleSowFileUpload" accept=".pdf,application/pdf" class="d-none" />
                    </label>

                    @if (!string.IsNullOrWhiteSpace(sowUploadStatus))
                    {
                        <span class="badge bg-secondary fs-6">@sowUploadStatus</span>
                    }
                </div>

                @if (sowDocuments == null)
                {
                    <p>Loading SOW documents...</p>
                }
                else if (!sowDocuments.Any())
                {
                    <p class="text-muted">No SOW documents uploaded yet.</p>
                }
                else
                {
                    <ul class="list-group" style="max-width: 900px;">
                        @foreach (var document in sowDocuments)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center gap-3">
                                <div>
                                    <div class="fw-semibold">@document.Title</div>
                                    <div class="text-muted small">@document.FileName</div>
                                </div>
                                <div class="d-flex gap-2">
                                    <a class="btn btn-sm btn-outline-primary" href="@document.Url" target="_blank" rel="noopener noreferrer">View</a>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteSowDocument(document)">Delete</button>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        }

        @if (activeTab == "mondayminute")
        {
            <MondayMinuteManager />
        }

        @if (activeTab == "passwords")
        {
            <div>
                <h5>Password Generator</h5>
                <p class="text-muted mb-3">
                    2 words (≤ 5 chars each) + a number + a special character
                </p>

                <div class="d-flex align-items-center gap-2" style="max-width: 520px;">
                    <button class="btn btn-primary" @onclick="GeneratePassword">
                        Generate
                    </button>

                    <input class="form-control" value="@generatedPassword" readonly />

                    <button class="btn btn-outline-secondary"
                            @onclick="CopyPassword"
                            disabled="@string.IsNullOrWhiteSpace(generatedPassword)">
                        Copy
                    </button>
                </div>

                @if (showCopySuccess)
                {
                    <div class="text-success fw-bold mt-2">✓ Copied!</div>
                }
            </div>
        }

        @if (activeTab == "projecttracker")
        {
            <div>
                <h5>IT Project Tracker</h5>
                <p class="text-muted">Track your personal IT projects and contributions.</p>

                <div class="border rounded p-3 mb-4" style="max-width: 900px;">
                    <h6>Add Project Contribution</h6>
                    <label class="mt-2">Title:</label>
                    <InputText @bind-Value="newProjectTitle" class="form-control" />

                    <label class="mt-2">Notes:</label>
                    <InputTextArea @bind-Value="newProjectNotes" rows="4" class="form-control" />

                    <label class="mt-2">Completed Date:</label>
                    <InputDate @bind-Value="newProjectCompletedDate" class="form-control" />

                    <button class="btn btn-success mt-3" @onclick="AddProjectItem">Add Project</button>
                </div>

                @if (itProjectItems == null)
                {
                    <p>Loading your project entries...</p>
                }
                else
                {
                    <div class="mb-3">
                        <a class="btn btn-outline-primary"
                           href="/api/it-project-tracker/download"
                           download>
                            Download PDF
                        </a>
                    </div>

                    @if (!itProjectItems.Any())
                    {
                        <p class="text-muted">You do not have any project entries yet.</p>
                    }
                    else
                    {
                        <ul class="list-group" style="max-width: 900px;">
                        @foreach (var item in itProjectItems)
                        {
                            <li class="list-group-item">
                                @if (editingProjectId == item.Id)
                                {
                                    <label>Title:</label>
                                    <InputText @bind-Value="editProjectTitle" class="form-control mb-2" />

                                    <label>Notes:</label>
                                    <InputTextArea @bind-Value="editProjectNotes" rows="4" class="form-control mb-2" />

                                    <label>Completed Date:</label>
                                    <InputDate @bind-Value="editProjectCompletedDate" class="form-control" />

                                    <div class="d-flex gap-2 mt-3">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveEditedProjectItem">Save</button>
                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditProjectItem">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div>
                                            <strong>@item.Title</strong>
                                            <div class="text-muted small">Completed: @(item.CompletedDate.HasValue ? item.CompletedDate.Value.ToString("MMM d, yyyy") : "Not set")</div>
                                            <div style="white-space: pre-wrap;">@item.Notes</div>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditProjectItem(item)">Edit</button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteProjectItem(item)">Delete</button>
                                        </div>
                                    </div>
                                }
                            </li>
                        }
                        </ul>
                    }
                }

                @if (showProjectSaveSuccess)
                {
                    <div class="text-success fw-bold mt-3">✓ Project tracker saved!</div>
                }
            </div>
        }

        @if (activeTab == "knowledgebase")
        {
            <div>
                <h5>Knowledge Base Manager</h5>

                <div class="border rounded p-3 mb-4" style="max-width: 700px;">
                    <h6>Add Folder</h6>
                    <label class="mt-2">Folder Name:</label>
                    <InputText @bind-Value="newKnowledgeFolderName" class="form-control" />
                    <button class="btn btn-success mt-3" @onclick="AddKnowledgeFolder">Add Folder</button>
                </div>

                <div class="border rounded p-3 mb-4" style="max-width: 900px;">
                    <h6>Add Article</h6>
                    <label class="mt-2">Folder:</label>
                    <select @bind="selectedFolderForNewArticleId" class="form-select">
                        <option value="">-- Select Folder --</option>
                        @if (knowledgeBaseFolders != null)
                        {
                            @foreach (var folder in knowledgeBaseFolders)
                            {
                                <option value="@folder.Id.ToString()">@folder.Name</option>
                            }
                        }
                    </select>

                    <label class="mt-2">Article Title:</label>
                    <InputText @bind-Value="newKnowledgeArticleTitle" class="form-control" />

                    <label class="mt-2">Scribe Iframe Link:</label>
                    <InputText @bind-Value="newKnowledgeArticleEmbedUrl" class="form-control" />

                    <button class="btn btn-success mt-3" @onclick="AddKnowledgeArticle">Add Article</button>
                </div>

                @if (knowledgeBaseFolders == null)
                {
                    <p>Loading knowledge base...</p>
                }
                else if (!knowledgeBaseFolders.Any())
                {
                    <p class="text-muted">No folders have been created yet.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-3" style="max-width: 1000px;">
                        @foreach (var folder in knowledgeBaseFolders)
                        {
                            <div class="border rounded p-3">
                                @if (editingKnowledgeFolderId == folder.Id)
                                {
                                    <label>Folder Name:</label>
                                    <InputText @bind-Value="editKnowledgeFolderName" class="form-control" />
                                    <div class="d-flex gap-2 mt-3">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveEditedKnowledgeFolder">Save</button>
                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditKnowledgeFolder">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                        <h6 class="mb-0">@folder.Name</h6>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditKnowledgeFolder(folder)">Edit Folder</button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteKnowledgeFolder(folder)">Delete Folder</button>
                                        </div>
                                    </div>
                                }

                                @if (!folder.Articles.Any())
                                {
                                    <p class="text-muted mb-0">No articles in this folder.</p>
                                }
                                else
                                {
                                    <ul class="list-group">
                                        @foreach (var article in folder.Articles)
                                        {
                                            <li class="list-group-item">
                                                @if (editingKnowledgeArticleId == article.Id)
                                                {
                                                    <label>Article Title:</label>
                                                    <InputText @bind-Value="editKnowledgeArticleTitle" class="form-control mb-2" />

                                                    <label>Scribe Iframe Link:</label>
                                                    <InputText @bind-Value="editKnowledgeArticleEmbedUrl" class="form-control" />

                                                    <div class="d-flex gap-2 mt-3">
                                                        <button class="btn btn-sm btn-primary" @onclick="SaveEditedKnowledgeArticle">Save</button>
                                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditKnowledgeArticle">Cancel</button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                                        <div>
                                                            <strong>@article.Title</strong>
                                                            <div class="text-muted small" style="word-break: break-all;">@article.EmbedUrl</div>
                                                        </div>
                                                        <div class="d-flex gap-2">
                                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditKnowledgeArticle(folder, article)">Edit</button>
                                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteKnowledgeArticle(folder, article)">Delete</button>
                                                        </div>
                                                    </div>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(knowledgeBaseStatusMessage))
                {
                    <div class="text-success fw-bold mt-3">✓ @knowledgeBaseStatusMessage</div>
                }
            </div>
        }

        @if (activeTab == "flappybird")
        {
            <div>
                <h5>Flappy Bird Challenge</h5>
                <p class="text-muted mb-3">
                    Press <strong>Space</strong> to flap and fly through the pipe gaps. Tight gaps, one hit ends the run.
                </p>

                <div class="d-flex flex-wrap gap-4 align-items-start">
                    <div>
                        <canvas id="adminFlappyCanvas" width="520" height="600" class="border rounded bg-light"></canvas>
                        <div class="d-flex gap-2 mt-3">
                            <button class="btn btn-primary" @onclick="StartFlappyGame">Start / Restart</button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(flappyStatusMessage))
                        {
                            <div class="mt-2 text-danger small">@flappyStatusMessage</div>
                        }
                        <div class="mt-2 small text-muted">
                            Signed in as: <strong>@currentUserName</strong>
                        </div>
                        @if (lastFlappyScore > 0)
                        {
                            <div class="mt-2 fw-semibold">Last score: @lastFlappyScore</div>
                        }
                    </div>

                    <div class="border rounded p-3" style="min-width: 280px;">
                        <h6 class="mb-3">Leaderboards (Top 5)</h6>

                        @if (flappyLeaderboards == null)
                        {
                            <p class="text-muted mb-0">Loading scores...</p>
                        }
                        else
                        {
                            @RenderLeaderboard("Daily Leaderboard", flappyLeaderboards.Daily)
                            @RenderLeaderboard("Weekly Leaderboard", flappyLeaderboards.Weekly)
                            @RenderLeaderboard("Monthly Leaderboard", flappyLeaderboards.Monthly)
                            @RenderLeaderboard("All Time Leaderboard", flappyLeaderboards.AllTime, false)
                        }
                    </div>
                </div>
            </div>
        }

    }
</div>

@code {
    private List<string>? logFiles;
    private string? logContent;
    private bool isAuthorized = false;
    private bool isMobile = false;
    private string activeTab = "logs";
    private string adminGroupId = "1f7897c7-a5b7-437c-9697-626c1e758f04";
    private List<ItNewsItem>? itNewsItems;
    private string newItNewsTitle = string.Empty;
    private string newItNewsContent = string.Empty;
    private DateTime? newItNewsExpirationDate;
    private bool newItNewsArchivable;
    private Guid? editingItNewsId;
    private string editItNewsTitle = string.Empty;
    private string editItNewsContent = string.Empty;
    private DateTime? editItNewsExpirationDate;
    private bool editItNewsArchivable;
    private bool showNewsSaveSuccess = false;
    private string? generatedPassword;
    private bool showCopySuccess = false;
    private FlappyLeaderboardSnapshot? flappyLeaderboards;
    private string currentUserName = "anonymous";
    private int lastFlappyScore = 0;
    private DotNetObjectReference<Admin>? flappyDotNetRef;
    private bool flappyInitialized = false;
    private string? flappyStatusMessage;
    private string signedInUserLogin = "anonymous";
    private List<SowDocumentInfo>? sowDocuments;
    private string? sowUploadStatus;
    private List<ItProjectTrackerItem>? itProjectItems;
    private string newProjectTitle = string.Empty;
    private string newProjectNotes = string.Empty;
    private DateTime? newProjectCompletedDate;
    private Guid? editingProjectId;
    private string editProjectTitle = string.Empty;
    private string editProjectNotes = string.Empty;
    private DateTime? editProjectCompletedDate;
    private bool showProjectSaveSuccess = false;
    private List<KnowledgeBaseFolderItem>? knowledgeBaseFolders;
    private string newKnowledgeFolderName = string.Empty;
    private Guid? editingKnowledgeFolderId;
    private string editKnowledgeFolderName = string.Empty;
    private string selectedFolderForNewArticleId = string.Empty;
    private string newKnowledgeArticleTitle = string.Empty;
    private string newKnowledgeArticleEmbedUrl = string.Empty;
    private Guid? editingKnowledgeFolderForArticleId;
    private Guid? editingKnowledgeArticleId;
    private string editKnowledgeArticleTitle = string.Empty;
    private string editKnowledgeArticleEmbedUrl = string.Empty;
    private string? knowledgeBaseStatusMessage;

    private void SetActiveTab(string tab)
    {
        activeTab = tab;

        if (tab == "flappybird")
        {
            flappyInitialized = false;
            flappyStatusMessage = null;
        }
    }

    private string IsActiveTab(string tab) => activeTab == tab ? "active" : "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var token = await TokenAcquisition.GetAccessTokenForUserAsync(new[] { "User.Read.All" });

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            signedInUserLogin = user?.Identity?.Name ?? "anonymous";
            currentUserName = GetLeaderboardDisplayName(signedInUserLogin);

            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst("http://schemas.microsoft.com/identity/claims/objectidentifier")?.Value;

                if (!string.IsNullOrEmpty(userId))
                {
                    isAuthorized = await GraphUserService.IsUserInGroupAsync(userId, adminGroupId);
                }
            }

            if (isAuthorized)
            {
                logFiles = await Logger.GetLogFileNamesAsync();
                itNewsItems = await ItNewsService.LoadNewsAsync();
                flappyLeaderboards = await FlappyLeaderboardService.GetLeaderboardsAsync(5);
                sowDocuments = await SowDocumentService.ListDocumentsAsync();
                itProjectItems = await ItProjectTrackerService.LoadItemsAsync(signedInUserLogin);
                knowledgeBaseFolders = await KnowledgeBaseService.LoadFoldersAsync();
            }
        }
        catch (MsalUiRequiredException ex)
        {
            ConsentHandler.HandleException(ex);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Unexpected error during token acquisition or group check: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var width = await JS.InvokeAsync<int>("blazorGetWindowWidth");
            isMobile = width < 768;
            StateHasChanged();
        }

        if (activeTab == "flappybird" && !flappyInitialized)
        {
            await InitializeFlappyGameAsync();
        }

        if (activeTab != "flappybird" && flappyInitialized)
        {
            await JS.InvokeVoidAsync("adminFlappyBird.dispose");
            flappyInitialized = false;
        }
    }

    private async Task<bool> InitializeFlappyGameAsync(bool force = false)
    {
        if (flappyInitialized && !force)
        {
            return true;
        }

        flappyDotNetRef?.Dispose();
        flappyDotNetRef = DotNetObjectReference.Create(this);
        flappyInitialized = await JS.InvokeAsync<bool>("adminFlappyBird.init", "adminFlappyCanvas", flappyDotNetRef);
        return flappyInitialized;
    }

    private async Task StartFlappyGame()
    {
        flappyStatusMessage = null;

        try
        {
            var initialized = await InitializeFlappyGameAsync();
            if (!initialized)
            {
                await Task.Delay(50);
                initialized = await InitializeFlappyGameAsync(force: true);
            }

            if (!initialized)
            {
                flappyStatusMessage = "Game canvas was not ready. Please try again.";
                return;
            }

            var started = await JS.InvokeAsync<bool>("adminFlappyBird.start");
            if (!started)
            {
                flappyInitialized = false;
                flappyStatusMessage = "Unable to start game. Please click Start again.";
            }
        }
        catch
