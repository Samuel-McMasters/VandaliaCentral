    private async Task HandleSowFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file is null)
        {
            return;
        }

        if (!file.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) ||
            !string.Equals(file.ContentType, "application/pdf", StringComparison.OrdinalIgnoreCase))
        {
            sowUploadStatus = "Only PDF uploads are allowed.";
            return;
        }

        try
        {
            sowUploadStatus = "Uploading...";
            await SowDocumentService.UploadDocumentAsync(file);

            var userName = await GetCurrentUserNameAsync();
            await Logger.LogActivityAsync(userName, $"Uploaded SOW document {file.Name}");

            sowDocuments = await SowDocumentService.ListDocumentsAsync();
            sowUploadStatus = "Upload successful!";

            await Task.Delay(2000);
            sowUploadStatus = null;
