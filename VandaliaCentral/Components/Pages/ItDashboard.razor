@page "/it-dashboard"
@using Microsoft.AspNetCore.Authorization
@using VandaliaCentral.Authorization
@using VandaliaCentral.Models
@using VandaliaCentral.Services
@inject ItNewsService ItNewsService
@inject SowDocumentService SowDocumentService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthenticationStateProvider

@attribute [Authorize]

<PageTitle>IT Dashboard</PageTitle>

<div class="container py-4 it-dashboard-page">
    <section class="it-hero border rounded-3 shadow-sm p-4 p-lg-5 mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start gap-4">
            <div>
                <h3 class="mb-2">IT Dashboard</h3>
                <p class="text-muted mb-0">Quick access to support, recent updates, and Scope of Work documents.</p>
            </div>

            <div class="d-grid gap-2 hero-actions">
                <a class="btn btn-primary" href="https://support.vandaliarental.com/support/home" target="_blank" rel="noopener noreferrer">
                    View Support Tickets
                </a>
                <a class="btn btn-outline-primary" href="/supportticket">
                    Submit a Ticket
                </a>
            </div>
        </div>
    </section>

    <div class="row g-4 align-items-stretch">
        <div class="col-12 col-xl-7">
            <section class="dashboard-card border rounded-3 shadow-sm p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">IT News</h5>
                </div>

                @if (itNewsItems == null)
                {
                    <p class="text-muted mb-0">Loading IT news...</p>
                }
                else if (!itNewsItems.Any())
                {
                    <div class="empty-state">
                        <p class="text-muted mb-0">No IT news has been posted yet.</p>
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var item in itNewsItems)
                        {
                            <li class="list-group-item px-0 py-3">
                                <div class="d-flex flex-column flex-md-row justify-content-between gap-1 mb-2">
                                    <strong class="me-3">@item.Title</strong>
                                    <span class="text-muted small flex-shrink-0">@item.PostedOn.ToLocalTime().ToString("MMM d, yyyy")</span>
                                </div>
                                <p class="mb-0 text-muted" style="white-space: pre-wrap;">@item.Content</p>
                            </li>
                        }
                    </ul>
                }
            </section>
        </div>

        @if (CanViewSowSection)
        {
            <div class="col-12 col-xl-5">
                <section class="dashboard-card border rounded-3 shadow-sm p-4 h-100">
                    <h5 class="mb-2">Scope of Work Documents</h5>
                    <p class="text-muted small mb-3">View documents in your browser or download a copy.</p>

                    @if (sowDocuments == null)
                    {
                        <p class="text-muted mb-0">Loading SOW documents...</p>
                    }
                    else if (!sowDocuments.Any())
                    {
                        <div class="empty-state">
                            <p class="text-muted mb-0">No SOW documents are available right now.</p>
                        </div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush sow-list">
                            @foreach (var doc in sowDocuments)
                            {
                                <li class="list-group-item px-0 py-3">
                                    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
                                        <div class="fw-semibold text-break">@doc.Title</div>
                                        <div class="d-flex gap-2 flex-shrink-0">
                                            <a class="btn btn-sm btn-outline-primary" href="@doc.Url" target="_blank" rel="noopener noreferrer">View</a>
                                            <a class="btn btn-sm btn-primary" href="@($"/api/sow-documents/download?fileName={Uri.EscapeDataString(doc.FileName)}")">Download</a>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </section>
            </div>
        }
    </div>
</div>

<style>
    .it-dashboard-page .it-hero,
    .it-dashboard-page .dashboard-card {
        background: #fff;
    }

    .it-dashboard-page .hero-actions {
        min-width: 240px;
    }

    .it-dashboard-page .hero-actions .btn {
        width: 220px;
    }

    .it-dashboard-page .empty-state {
        border: 1px dashed #dee2e6;
        border-radius: .5rem;
        padding: 1rem;
        background: #f8f9fa;
    }

    .it-dashboard-page .sow-list .list-group-item:last-child,
    .it-dashboard-page .list-group-item:last-child {
        border-bottom: 0;
    }
</style>

@code {
    private List<ItNewsItem>? itNewsItems;
    private List<SowDocumentInfo>? sowDocuments;
    private bool CanViewSowSection;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        CanViewSowSection = authState.User.Claims
            .Where(c => c.Type == "groups")
            .Any(c => AuthorizationPolicies.AmAccountChangeAllowedGroups.Contains(c.Value));

        itNewsItems = await ItNewsService.LoadNewsAsync();
        if (CanViewSowSection)
        {
            sowDocuments = await SowDocumentService.ListDocumentsAsync();
        }
    }
}
