@page "/it-dashboard"
@using Microsoft.AspNetCore.Authorization
@using VandaliaCentral.Models
@using VandaliaCentral.Services
@inject ItNewsService ItNewsService

@attribute [Authorize]

<PageTitle>IT Dashboard</PageTitle>

<div class="container py-4">
    <div class="p-4 border rounded bg-white shadow-sm mb-4">
        <h3 class="mb-2">IT Dashboard</h3>
        <p class="text-muted mb-0">Your one-stop spot for IT updates, support links, and announcements.</p>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-7">
            <div class="p-4 border rounded bg-white shadow-sm h-100">
                <h5 class="mb-3">IT News</h5>

                @if (itNewsItems == null)
                {
                    <p class="text-muted mb-0">Loading IT news...</p>
                }
                else if (!itNewsItems.Any())
                {
                    <p class="text-muted mb-0">No IT news has been posted yet.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var item in itNewsItems)
                        {
                            <li class="list-group-item px-0">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong>@item.Title</strong>
                                    <span class="text-muted small">@item.PostedOn.ToLocalTime().ToString("MMM d, yyyy")</span>
                                </div>
                                <p class="mb-0 text-muted" style="white-space: pre-wrap;">@item.Content</p>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="col-12 col-lg-5">
            <div class="p-4 border rounded bg-white shadow-sm h-100 d-flex flex-column">
                <h5 class="mb-3">Support Actions</h5>
                <p class="text-muted">Need help? Choose an option below.</p>
                <div class="d-grid gap-2 mt-2">
                    <a class="btn btn-primary w-100" href="https://support.vandaliarental.com/support/home" target="_blank" rel="noopener noreferrer">
                        View Your Support Tickets
                    </a>
                    <a class="btn btn-outline-primary w-100" href="/supportticket">
                        Submit A Ticket
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ItNewsItem>? itNewsItems;

    protected override async Task OnInitializedAsync()
    {
        itNewsItems = await ItNewsService.LoadNewsAsync();
    }
}
