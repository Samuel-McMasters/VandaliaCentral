@page "/employeechange"

@using VandaliaCentral.Models
@using VandaliaCentral.Services
@using Microsoft.Identity.Web
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Options
@using Microsoft.Graph

@inject GraphEmailService EmailService
@inject GraphUserService UserService
@inject LoggingService Logger
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ITokenAcquisition TokenAcquisition
@inject MicrosoftIdentityConsentAndConditionalAccessHandler ConsentHandler
@inject IOptions<EmployeeChangeEmailOptions> EmailOptions
@inject IOptions<BranchLocationsOptions> BranchLocations

@attribute [Authorize]
@attribute [AuthorizeForScopes(Scopes = new[] { "User.Read.All", "Mail.Send" })]

<div class="container d-flex flex-column border rounded bg-white shadow-sm col-md-7 py-4">
    <h3>Employee Change Form</h3>

    @if (success)
    {
        <p class="text-success mt-2">Form submission was successful!</p>
        <p class="text-success mt-2">Redirecting to home page...</p>
    }
    else if (failure)
    {
        <h4 class="text-danger mt-2">There was an error submitting your employee change form:</h4>
        <p>Please refresh the webpage, or contact the intranet administrator for assistance.</p>

        @if (!string.IsNullOrWhiteSpace(errorDetails))
        {
            <div class="alert alert-danger mt-3">
                <strong>Error:</strong> @errorDetails
            </div>
        }
    }
    else if (!isAuthorized)
    {
        <p>Checking sign-in status...</p>
    }
    else
    {
        <EditForm Model="@formModel" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <!-- Employee Information Block -->
            <div class="row py-5">
                <div class="row">
                    <div class="col-12 col-md-12 d-flex flex-column mb-2">
                        <label><strong>Employee Name:</strong></label>
                        <div class="position-relative">
                            <button type="button"
                                    class="form-control text-start"
                                    @onclick="ToggleEmployeeDropdown"
                                    disabled="@isEmployeeListLoading">
                                @GetEmployeeSelectionText()
                            </button>

                            @if (showEmployeeDropdown)
                            {
                                <div class="position-fixed top-0 start-0 w-100 h-100"
                                     style="z-index: 1040;"
                                     @onclick="CloseEmployeeDropdown"></div>
                                <div class="position-absolute w-100 mt-1 border rounded bg-white shadow p-2"
                                     style="z-index: 1050;"
                                     @onclick:stopPropagation="true">
                                    <input class="form-control mb-2"
                                           placeholder="Search employees..."
                                           @bind="employeeSearchTerm"
                                           @bind:event="oninput" />
                                    <div style="max-height: 240px; overflow-y: auto;">
                                        @if (!FilteredEmployees.Any())
                                        {
                                            <div class="text-muted small px-2 py-1">No employees found.</div>
                                        }
                                        else
                                        {
                                            @foreach (var employee in FilteredEmployees)
                                            {
                                                <button type="button"
                                                        class="btn btn-link text-decoration-none text-start w-100 px-2 py-1"
                                                        @onclick="() => SelectEmployee(employee)">
                                                    @employee.DisplayName
                                                </button>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <ValidationMessage For="@(() => formModel.FirstName)" />
                        <ValidationMessage For="@(() => formModel.LastName)" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-12 mb-2">
                        <label><strong>Previous Job Title:</strong></label>
                        <p>(i.e. Inside Sales, Rental Coordinator, Mechanic, Road Tech, etc.)</p>
                        <InputText @bind-Value="formModel.PreviousJobTitle" class="form-control" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-6 mb-2">
                        <label><strong>Branch #:</strong></label>
                        <InputSelect class="form-select" Value="selectedCurrentBranch" ValueChanged="HandleCurrentBranchChanged" ValueExpression="() => selectedCurrentBranch">
                            <option value="">-- Select --</option>
                            @foreach (var branch in BranchLocations.Value.Items)
                            {
                                <option value="@GetBranchSelectionValue(branch)">@GetBranchDisplay(branch)</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-12 col-md-6 mb-2">
                        <label><strong>Branch Name:</strong></label>
                        <InputText @bind-Value="formModel.BranchName" class="form-control" readonly />
                    </div>
                    <div class="col-12 col-md-6 mb-2">
                        <label><strong>Manager Name:</strong></label>
                        <InputText @bind-Value="formModel.ManagerName" class="form-control" />
                    </div>
                </div>
            </div>

            <!-- Change Employee Position To Block -->
            <div class="row py-5">
                <h5 class="pb-3">Change Employee Position To</h5>
                <div class="row">
                    <div class="col-12 col-md-3 d-flex flex-column mb-2">
                        <label><strong>Effective Date:</strong></label>
                        <InputDate @bind-Value="formModel.EffectiveDate" class="form-control" />
                    </div>
                    <div class="col-12 col-md-9 mb-2">
                        <label><strong>New Position:</strong></label>
                        <InputText @bind-Value="formModel.NewPosition" class="form-control" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-12 mb-2">
                        <label><strong>Job Title:</strong></label>
                        <InputText @bind-Value="formModel.JobTitle" class="form-control" />
                    </div>
                </div>
                <div class="row pt-4">
                    <div class="col-12 col-md-2 mb-2">
                        <InputCheckbox @bind-Value="formModel.FullTime" class="form-check-input" />
                        <label class="form-check-label">Full Time</label>
                    </div>
                    <div class="col-12 col-md-2 mb-2">
                        <InputCheckbox @bind-Value="formModel.PartTime" class="form-check-input" />
                        <label class="form-check-label">Part Time</label>
                    </div>
                    <div class="col-12 col-md-2 mb-2">
                        <InputCheckbox @bind-Value="formModel.Hourly" class="form-check-input" />
                        <label class="form-check-label">Hourly</label>
                    </div>
                    <div class="col-12 col-md-2 mb-2">
                        <InputCheckbox @bind-Value="formModel.Salary" class="form-check-input" />
                        <label class="form-check-label">Salary</label>
                    </div>
                </div>
            </div>

            <!-- Change Employee Branch Location To Block -->
            <div class="row py-5">
                <h5 class="pt-3">Change Employee Branch Location To</h5>
                <p class="pb-3">(If No Branch Change DO NOT Complete)</p>
                <div class="row">
                    <div class="col-12 col-md-6 d-flex flex-column mb-2">
                        <label><strong>Branch Number:</strong></label>
                        <InputSelect class="form-select" Value="selectedNewLocationBranch" ValueChanged="HandleNewLocationBranchChanged" ValueExpression="() => selectedNewLocationBranch">
                            <option value="">-- Select --</option>
                            @foreach (var branch in BranchLocations.Value.Items)
                            {
                                <option value="@GetBranchSelectionValue(branch)">@GetBranchDisplay(branch)</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-12 col-md-6 mb-2">
                        <label><strong>Branch Name:</strong></label>
                        <InputText @bind-Value="formModel.NewLocBranchName" class="form-control" readonly />
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-6 mb-2">
                        <label><strong>Manager Name:</strong></label>
                        <InputText @bind-Value="formModel.NewLocManagerName" class="form-control" />
                    </div>
                </div>
                <div class="row pt-4">
                    <h5 class="pt-3">Cross Training</h5>
                    <div class="col-12 col-md-6 d-flex flex-column mb-2">
                        <label><strong>Current Position:</strong></label>
                        <InputText @bind-Value="formModel.CrossTrainingCurrentPosition" class="form-control" />
                    </div>
                    <div class="col-12 col-md-6 mb-2">
                        <label><strong>Position to Be Cross-Trained In:</strong></label>
                        <InputText @bind-Value="formModel.CrossTrainingTargetPosition" class="form-control" />
                    </div>
                </div>
                <div class="row pt-4">
                    <div class="col-12 col-md-6 mb-2">
                        <label class="form-check-label pb-1">Additional Notes</label>
                        <InputTextArea @bind-Value="formModel.AdditionalNotes"
                                       class="form-control"
                                       rows="5"
                                       style="resize: none;" />
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary mt-2" disabled="@isSubmitting">
                @(isSubmitting ? "Submitting..." : "Submit")
            </button>
        </EditForm>
    }
</div>

@code {
    private ChangeFormModel formModel = new();
    private bool success = false;
    private bool failure = false;
    private bool isAuthorized = false;
    private bool isSubmitting = false;
    private bool isEmployeeListLoading = true;
    private bool showEmployeeDropdown = false;
    private string? errorDetails;
    private string employeeSearchTerm = string.Empty;
    private string selectedCurrentBranch = string.Empty;
    private string selectedNewLocationBranch = string.Empty;
    private List<User> employees = new();

    protected override async Task OnInitializedAsync()
    {
        // Minimal fix: default Effective Date to "today" so the date picker doesn't start at 01/01/0001
        formModel.EffectiveDate = DateTime.Today;

        try
        {
            _ = await TokenAcquisition.GetAccessTokenForUserAsync(new[] { "Mail.Send" });
            isAuthorized = true;

            var users = await UserService.GetUsersAsync();
            employees = users
                .Where(u => !string.IsNullOrWhiteSpace(u.DisplayName))
                .OrderBy(u => u.DisplayName, StringComparer.OrdinalIgnoreCase)
                .ToList();
            isEmployeeListLoading = false;
        }
        catch (Exception ex)
        {
            ConsentHandler.HandleException(ex);
            isEmployeeListLoading = false;
        }
    }

    private IEnumerable<User> FilteredEmployees =>
        employees.Where(u =>
            string.IsNullOrWhiteSpace(employeeSearchTerm) ||
            (u.DisplayName?.Contains(employeeSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    private string GetEmployeeSelectionText()
    {
        if (isEmployeeListLoading)
        {
            return "Loading employees...";
        }

        var fullName = GetEmployeeFullName();
        return string.IsNullOrWhiteSpace(fullName)
            ? "Select employee"
            : fullName;
    }

    private static string GetBranchDisplay(BranchLocationItem branch)
    {
        return $"{FormatBranchCode(branch.Code)} - {branch.Name}";
    }

    private static string GetBranchSelectionValue(BranchLocationItem branch)
    {
        return $"{branch.Code}|{branch.Name}";
    }

    private static string FormatBranchCode(string? branchCode)
    {
        return (branchCode ?? string.Empty).PadLeft(4, '0');
    }

    private static (string Number, string Name) ParseBranchSelection(string? branchSelection)
    {
        if (string.IsNullOrWhiteSpace(branchSelection))
        {
            return (string.Empty, string.Empty);
        }

        var parts = branchSelection.Split('|', 2, StringSplitOptions.TrimEntries);
        var number = parts.Length > 0 ? FormatBranchCode(parts[0]) : string.Empty;
        var name = parts.Length > 1 ? parts[1] : string.Empty;

        return (number, name);
    }

    private string GetEmployeeFullName()
    {
        return $"{formModel.FirstName} {formModel.LastName}".Trim();
    }

    private void ToggleEmployeeDropdown()
    {
        showEmployeeDropdown = !showEmployeeDropdown;
    }

    private void CloseEmployeeDropdown()
    {
        showEmployeeDropdown = false;
    }

    private void SelectEmployee(User employee)
    {
        var (firstName, lastName) = ParseEmployeeName(employee.DisplayName);
        formModel.FirstName = firstName;
        formModel.LastName = lastName;

        showEmployeeDropdown = false;
        employeeSearchTerm = string.Empty;
    }

    private static (string FirstName, string LastName) ParseEmployeeName(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return (string.Empty, string.Empty);
        }

        var nameParts = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (nameParts.Length == 1)
        {
            return (nameParts[0], string.Empty);
        }

        return (nameParts[0], string.Join(' ', nameParts.Skip(1)));
    }

    private Task HandleCurrentBranchChanged(string branchSelection)
    {
        selectedCurrentBranch = branchSelection;
        var (number, name) = ParseBranchSelection(branchSelection);
        formModel.BranchNumber = number;
        formModel.BranchName = name;
        return Task.CompletedTask;
    }

    private Task HandleNewLocationBranchChanged(string branchSelection)
    {
        selectedNewLocationBranch = branchSelection;
        var (number, name) = ParseBranchSelection(branchSelection);
        formModel.NewLocBranchNumber = number;
        formModel.NewLocBranchName = name;
        return Task.CompletedTask;
    }

    private async Task HandleValidSubmit()
    {
        success = false;
        failure = false;
        errorDetails = null;
        isSubmitting = true;

        var fullName = GetEmployeeFullName();
        var userName = "anonymous";

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            userName = authState.User?.Identity?.Name ?? "anonymous";

            var opts = EmailOptions.Value;

            // Fail loud until configured (same vibe as AM change form)
            if (string.IsNullOrWhiteSpace(opts.To))
                throw new InvalidOperationException("TODO: Configure EmployeeChangeEmail:To in appsettings / Azure App Settings.");

            var pdfBytes = PDFTemplateFiller.FillChange(formModel);

            var fileSafeName = fullName.Replace(" ", "_");

            await EmailService.SendEmailWithAttachmentAsyncStrict(
                toEmail: opts.To,
                subject: $"Employee Change Form: {fullName}",
                bodyText: $"Attached is the employee change form for {fullName}.",
                fileBytes: pdfBytes,
                fileName: $"{fileSafeName}_employee_change.pdf",
                ccEmail: string.IsNullOrWhiteSpace(opts.Cc) ? null : opts.Cc);

            await Logger.LogActivityAsync(userName, $"Submitted Employee Change Form For: '{fullName}'");

            success = true;
            StateHasChanged();
            await Task.Delay(4000);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            errorDetails = ex.Message;
            failure = true;

            // Log full exception text
            try
            {
                await Logger.LogActivityAsync(userName, $"Employee Change Form FAILED for '{fullName}'. Exception: {ex}");
            }
            catch { }
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
