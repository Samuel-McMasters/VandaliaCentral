@page "/employeetermination"
@using VandaliaCentral.Models
@using VandaliaCentral.Services
@using Microsoft.Identity.Web
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Options
@using Microsoft.Graph
@inject GraphEmailService EmailService
@inject GraphUserService UserService
@inject LoggingService Logger
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject IOptions<BranchLocationsOptions> BranchLocations
@inject IOptions<EmployeeTerminationEmailOptions> EmailOptions

@attribute [Authorize]
@attribute [AuthorizeForScopes(Scopes = new[] { "User.Read.All", "GroupMember.Read.All", "Mail.Send" })]

<div class="container d-flex flex-column border rounded bg-white shadow-sm col-md-7 py-4">
    <h3>Employee Termination Form</h3>
    @if (success)
    {
        <p class="text-success mt-2">Form submission was successful!</p>
        <p class="text-success mt-2">Redirecting to home page...</p>
    }
    else if (failure)
    {
        <h4 class="text-danger mt-2">There was an error submitting your employee termination form:</h4>
        <p>Please refresh the webpage, or contact the intranet administrator for assistance.</p>
    }
    else if (!isAuthorized)
    {
        <p>Checking sign-in status...</p>
    }
    else
    {
        <EditForm Model="@formModel" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <!-- Employee Information Block -->
            <div class="row py-5">
                <div class="row">
                    <div class="col-12 col-md-4 d-flex flex-column mb-2">
                        <label>Employee Name:</label>
                        <div class="position-relative">
                            <button type="button"
                                    class="form-control text-start"
                                    @onclick="ToggleEmployeeDropdown"
                                    disabled="@isEmployeeListLoading">
                                @GetEmployeeSelectionText()
                            </button>

                            @if (showEmployeeDropdown)
                            {
                                <div class="position-fixed top-0 start-0 w-100 h-100"
                                     style="z-index: 1040;"
                                     @onclick="CloseEmployeeDropdown"></div>
                                <div class="position-absolute w-100 mt-1 border rounded bg-white shadow p-2"
                                     style="z-index: 1050;"
                                     @onclick:stopPropagation="true">
                                    <input class="form-control mb-2"
                                           placeholder="Search employees..."
                                           @bind="employeeSearchTerm"
                                           @bind:event="oninput" />
                                    <div style="max-height: 240px; overflow-y: auto;">
                                        @if (!FilteredEmployees.Any())
                                        {
                                            <div class="text-muted small px-2 py-1">No employees found.</div>
                                        }
                                        else
                                        {
                                            @foreach (var employee in FilteredEmployees)
                                            {
                                                <button type="button"
                                                        class="btn btn-link text-decoration-none text-start w-100 px-2 py-1"
                                                        @onclick="() => SelectEmployee(employee)">
                                                    @employee.DisplayName
                                                </button>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <ValidationMessage For="@(() => formModel.EmployeeName)" />
                    </div>
                    <div class="col-12 col-md-4 mb-2">
                        <label>Employee #:</label>
                        <InputText @bind-Value="formModel.EmployeeNumber" class="form-control" readonly="@isEmployeeNumberReadOnly" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-4 mb-2">
                        <label>Location:</label>
                        <InputSelect @bind-Value="formModel.Location" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var loc in BranchLocations.Value.Items)
                            {
                                var display = $"{loc.Code} - {loc.Name}";
                                <option value="@display">@display</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-12 col-md-4 mb-2">
                        <label>Last Date of Employment:</label>
                        <InputDate @bind-Value="formModel.LastDateOfEmployment" class="form-control" />
                    </div>
                </div>
            </div>

            <!-- Items To Be Collected Block -->
            <div class="py-5">
                <h5>Items to be collected (please mark items returned; leave BLANK if not applicable)</h5>

                <div class="row">
                    <div class="col-12 col-lg-4">
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Cellphone" class="form-check-input" />
                            <label class="form-check-label">Cellphone</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Notepad" class="form-check-input" />
                            <label class="form-check-label">Notepad</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.DeviceAccounts" class="form-check-input" />
                            <label class="form-check-label">All Device Accounts Logged Out</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Uniforms" class="form-check-input" />
                            <label class="form-check-label">Uniforms</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.CompanyVehicle" class="form-check-input" />
                            <label class="form-check-label">Company Vehicle</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.CreditCard" class="form-check-input" />
                            <label class="form-check-label">Credit Card</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Laptop" class="form-check-input" />
                            <label class="form-check-label">Laptop</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Hotspot" class="form-check-input" />
                            <label class="form-check-label">Mobile Hotspot</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.DeviceLock" class="form-check-input" />
                            <label class="form-check-label">Device Lock Passwords Removed</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Keys" class="form-check-input" />
                            <label class="form-check-label">Keys (i.e. Building/Vehicle)</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.PromotionalItems" class="form-check-input" />
                            <label class="form-check-label">Promotional Items</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Access To Be Terminated Block -->
            <div class="py-5">
                <h5>Access to be Terminated (leave BLANK if not applicable)</h5>
                <div class="row">
                    <div class="col-12 col-lg-4">
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Microsoft365" class="form-check-input" />
                            <label class="form-check-label">Microsoft 365</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Vizion" class="form-check-input" />
                            <label class="form-check-label">Vizion /Targit</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Salesforce" class="form-check-input" />
                            <label class="form-check-label">Salesforce</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Certify" class="form-check-input" />
                            <label class="form-check-label">Certify</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.RentalMan" class="form-check-input" />
                            <label class="form-check-label">RentalMan</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Telematics" class="form-check-input" />
                            <label class="form-check-label">Telematics</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Paylocity" class="form-check-input" />
                            <label class="form-check-label">Paylocity</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Ninety" class="form-check-input" />
                            <label class="form-check-label">90.i.o</label>
                        </div>
                        <div class="form-check-wrapper">
                            <InputCheckbox @bind-Value="formModel.Other" class="form-check-input" />
                            <label class="form-check-label pb-1">Other</label>

                        </div>
                        <div class="col-lg-12 col-md-5 col-sm-5 mb-2">

                            <InputTextArea @bind-Value="formModel.OtherText"
                                            class="form-control"
                                            rows="5"
                                            style="resize: none;" />
                        </div>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-primary mt-2">Submit</button>
        </EditForm>
    }
</div>



@code {
    private TerminationFormModel formModel = new();
    private bool success = false;
    private bool failure = false;
    private bool isAuthorized = false;
    private bool isEmployeeListLoading = true;
    private bool showEmployeeDropdown = false;
    private bool isEmployeeNumberReadOnly = false;
    private string employeeSearchTerm = string.Empty;
    private List<User> employees = new();

    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ITokenAcquisition TokenAcquisition { get; set; } = default!;
    [Inject] private MicrosoftIdentityConsentAndConditionalAccessHandler ConsentHandler { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Attempt to get token when page loads
            var token = await TokenAcquisition.GetAccessTokenForUserAsync(new[] { "Mail.Send" });
            isAuthorized = true;

            var users = await UserService.GetUsersAsync();
            employees = users
                .Where(u => !string.IsNullOrWhiteSpace(u.DisplayName))
                .OrderBy(u => u.DisplayName, StringComparer.OrdinalIgnoreCase)
                .ToList();
            isEmployeeListLoading = false;
        }
        catch (Exception ex)
        {
            ConsentHandler.HandleException(ex);
            isEmployeeListLoading = false;
        }
    }

    private IEnumerable<User> FilteredEmployees =>
        employees.Where(u =>
            string.IsNullOrWhiteSpace(employeeSearchTerm) ||
            (u.DisplayName?.Contains(employeeSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    private string GetEmployeeSelectionText()
    {
        if (isEmployeeListLoading)
        {
            return "Loading employees...";
        }

        return string.IsNullOrWhiteSpace(formModel.EmployeeName)
            ? "Select employee"
            : formModel.EmployeeName;
    }

    private void ToggleEmployeeDropdown()
    {
        showEmployeeDropdown = !showEmployeeDropdown;
    }

    private void CloseEmployeeDropdown()
    {
        showEmployeeDropdown = false;
    }

    private void SelectEmployee(User employee)
    {
        formModel.EmployeeName = employee.DisplayName ?? string.Empty;

        var employeeNumber = employee.OnPremisesExtensionAttributes?.ExtensionAttribute2;
        if (string.IsNullOrWhiteSpace(employeeNumber))
        {
            formModel.EmployeeNumber = string.Empty;
            isEmployeeNumberReadOnly = false;
        }
        else
        {
            formModel.EmployeeNumber = employeeNumber;
            isEmployeeNumberReadOnly = true;
        }

        showEmployeeDropdown = false;
        employeeSearchTerm = string.Empty;
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(EmailOptions.Value.To))
                throw new InvalidOperationException("TODO: Configure EmployeeTerminationEmail:To in appsettings / Azure App Settings.");

            var pdfBytes = PDFTemplateFiller.FillTermination(formModel);

            await EmailService.SendEmailWithAttachmentAsyncStrict(
                toEmail: EmailOptions.Value.To,
                subject: $"Termination Form: {formModel.EmployeeName}",
                bodyText: $"Attached is the termination form for {formModel.EmployeeName}.",
                fileBytes: pdfBytes,
                fileName: $"{formModel.EmployeeName}_termination.pdf",
                ccEmail: string.IsNullOrWhiteSpace(EmailOptions.Value.Cc) ? null : EmailOptions.Value.Cc
            );

            // Get current user identity
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userName = authState.User?.Identity?.Name ?? "anonymous";

            // Log the activity
            var activity = $"Submitted Employee Termination Form For: '{formModel.EmployeeName}'";
            await Logger.LogActivityAsync(userName, activity);

            success = true;
            StateHasChanged();
            await Task.Delay(4000);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"PDF or Email Error: {ex.Message}");
            if (ex.InnerException != null)
                Console.WriteLine($"Inner Exception: {ex.InnerException.Message}");
            failure = true;
        }
    }
}
