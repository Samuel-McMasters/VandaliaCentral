@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<div class="vc-shell">
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top bg-vandalia-secondary ps-4 pe-4 vc-topbar" style="height: 80px; overflow: hidden;">
        <div class="d-flex w-100 align-items-center">
            <div class="mx-lg-0 ps-4 ps-lg-0 d-flex align-items-center">
                <a class="navbar-brand me-2" href="/">
                    <img src=".\VR_black.png" width="151" height="47" class="align-top mb-2 mt-1" />
                </a>

                <div class="navbar-divider d-none d-lg-block"></div>

                <a class="d-none d-lg-block nav-link p-0 icon-button" href="/" tabindex="-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" fill="black" class="bi bi-house"
                         viewBox="0 0 16 16">
                        <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293zM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5z" />
                    </svg>
                </a>
            </div>
        </div>
    </nav>

    <main class="topbar-layout-content vc-page-surface" style="padding-top: 100px; background: #E5E5E5; min-height: 100vh;">
        @Body
    </main>
</div>
