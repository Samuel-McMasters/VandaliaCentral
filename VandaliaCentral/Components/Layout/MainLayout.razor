@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@namespace VandaliaCentral.Components.Layout
@using VandaliaCentral.Services
@inject PdfService PdfService
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Identity.Web
@inject LoggingService Logger
@inject NavigationManager Navigation
@inject UserLocationWeatherService UserLocationWeatherService
@inject GraphUserService GraphUserService

@attribute [Authorize]
@attribute [AuthorizeForScopes(Scopes = new[] { "User.Read.All", "Mail.Send" })]
@implements IDisposable

<div class="app-shell">
    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top bg-vandalia-secondary ps-3 ps-md-4 pe-3 pe-md-4 app-topbar">

        <div class="d-flex w-100 align-items-center position-relative gap-2">

            <!-- Hamburger toggle (left side, mobile only) -->
            <div class="d-lg-none">
                <button class="btn btn-light me-2 app-hamburger" @onclick="ToggleSidebar" aria-label="Toggle menu">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                         class="bi bi-list" viewBox="0 0 16 16">
                        <path fill-rule="evenodd"
                              d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5" />
                    </svg>
                </button>
            </div>

            <!-- Logo: left-aligned on lg+, centered on <lg -->
            <div class="mx-lg-0 ps-2 ps-lg-0 d-flex align-items-center app-brand-wrap">
                <a class="navbar-brand me-2" href="/">
                    <img src=".\VR_black.png" width="151" height="47" class="align-top" />
                </a>

                <div class="navbar-divider d-none d-lg-block"></div>

                <a class="d-none d-lg-block nav-link p-0 icon-button" href="/" tabindex="-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" fill="black" class="bi bi-house"
                         viewBox="0 0 16 16">
                        <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293zM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5z" />
                    </svg>
                </a>
            </div>

            <div class="navbar-center-weather d-none d-md-flex" aria-live="polite">
                @if (IsWeatherLoading)
                {
                    <span>Loading local weather...</span>
                }
                else if (!string.IsNullOrWhiteSpace(NavbarWeatherText))
                {
                    <span>@NavbarWeatherText</span>
                }
            </div>

            <!-- Editor button (right side) -->
            @if (IsUploader && !IsOnEditorPage && !IsAdmin)
            {
                <div class="ms-auto">
                    <button class="btn btn-primary mmbtn custom-upload-button text-nowrap top-nav-image-button"
                            @onclick='(e) => NavigateToEditor("Monday Minute Manager")'>
                        <img src="/top-nav-action-button.svg" alt="Resource Hub" class="top-nav-action-image" />
                    </button>
                </div>
            }
            else if (IsAdmin)
            {
                <div class="ms-auto">
                    <NavLink href="/admin" @onclick='(e) => NavigateToAdmin("Admin Dashboard")' class="btn btn-danger top-nav-image-button" activeClass="active">
                        <img src="/top-nav-action-button.svg" alt="Admin Dashboard" class="top-nav-action-image" />
                    </NavLink>
                </div>
            }
            else if (!IsOnEditorPage)
            {
                <div class="ms-auto">
                    <NavLink href="https://vandaliarental.targit.cloud/#vfs://global/Service/R%20Status%20Priority.xview" class="btn btn-dark" activeClass="active" target="_blank">
                        @(isMobile ? "Dashboards" : "My Dashboard")
                    </NavLink>
                </div>
            }

        </div>
    </nav>

    <!-- Main Content Area -->
    <div class="main-content-wrapper d-flex vc-main-shell">
        <div class="@SidebarCssClass vc-sidebar-shell" id="sidebarMenu">
            <CascadingValue Value="(Action)CloseSidebar">
                <NavMenu></NavMenu>
            </CascadingValue>
        </div>

        <div class="main-content flex-grow-1 page-enter" @ref="mainContentRef">
            <div class="content-surface">
            @Body
            </div>
        </div>
    </div>
</div>

@code {
    private string SidebarCssClass => showSidebar ? "vandalia-sidebar show d-lg-block" : "vandalia-sidebar d-lg-block";

    private bool showSidebar = false;
    private bool IsUploader = true;
    private bool isMobile = false;
    private bool hasLoggedLogin = false;
    private bool IsAdmin = false;
    private string? NavbarWeatherText;
    private bool IsWeatherLoading = true;
    private PeriodicTimer? _timeTimer;
    private TimeZoneInfo? _userTimeZone;
    private string? _weatherDetails;
    private string? _weatherLocationName;

    private bool IsOnEditorPage => Navigation.Uri.Contains("/mondayminuteeditor", StringComparison.OrdinalIgnoreCase);

    private void ToggleSidebar() => showSidebar = !showSidebar;

    private void CloseSidebar() => showSidebar = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var width = await JS.InvokeAsync<int>("blazorGetWindowWidth");
            isMobile = width < 768;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true && !hasLoggedLogin)
        {
            hasLoggedLogin = true;
            var userName = user.Identity.Name ?? "unknown";
            await Logger.LogActivityAsync(userName, "User logged in");
        }

        IsUploader = user.Claims.Any(c =>
            c.Type == "groups" && c.Value == "b3a0f732-a5f2-4c28-a005-61c901b21096");

        IsAdmin = user.Claims.Any(c =>
            c.Type == "groups" && c.Value == "1f7897c7-a5b7-437c-9697-626c1e758f04");

        await InitializeNavbarWeatherAsync(user);

        currentUri = Navigation.Uri;
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private async Task InitializeNavbarWeatherAsync(System.Security.Claims.ClaimsPrincipal user)
    {
        try
        {
            var officeLocation = user.FindFirst("office_location")?.Value
                ?? user.FindFirst("officeLocation")?.Value
                ?? user.FindFirst("extension_officeLocation")?.Value
                ?? await GraphUserService.GetCurrentUserOfficeLocationAsync();

            var snapshot = await UserLocationWeatherService.GetWeatherSnapshotAsync(officeLocation);
            if (snapshot is null)
            {
                NavbarWeatherText = "Local time and weather unavailable";
                return;
            }

            _weatherLocationName = snapshot.LocationName;
            _weatherDetails = $"{Math.Round(snapshot.TemperatureF)}°F • {snapshot.Conditions}";

            if (UserLocationWeatherService.TryResolveTimeZone(snapshot.TimezoneId, out var zone))
            {
                _userTimeZone = zone;
                UpdateNavbarWeatherText();
                _ = StartClockTickerAsync();
            }
            else
            {
                NavbarWeatherText = $"{_weatherLocationName} • {_weatherDetails}";
            }
        }
        catch
        {
            NavbarWeatherText = "Local time and weather unavailable";
        }
        finally
        {
            IsWeatherLoading = false;
        }
    }

    private async Task StartClockTickerAsync()
    {
        _timeTimer?.Dispose();
        _timeTimer = new PeriodicTimer(TimeSpan.FromMinutes(1));

        while (await _timeTimer.WaitForNextTickAsync())
        {
            await InvokeAsync(() =>
            {
                UpdateNavbarWeatherText();
                StateHasChanged();
            });
        }
    }

    private void UpdateNavbarWeatherText()
    {
        if (_userTimeZone is null || string.IsNullOrWhiteSpace(_weatherDetails) || string.IsNullOrWhiteSpace(_weatherLocationName))
        {
            return;
        }

        var localTime = TimeZoneInfo.ConvertTime(DateTimeOffset.UtcNow, _userTimeZone);
        NavbarWeatherText = $"{_weatherLocationName} • {localTime:hh:mm tt} • {_weatherDetails}";
    }

    private async Task NavigateToEditor(string linkName)
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userName = authState.User?.Identity?.Name ?? "anonymous";
        var activity = $"Clicked sidebar link: '{linkName}'";
        await Logger.LogActivityAsync(userName, activity);
        Navigation.NavigateTo("/mondayminuteeditor");
    }

    private async Task NavigateToAdmin(string linkName)
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userName = authState.User?.Identity?.Name ?? "anonymous";
        var activity = $"Clicked sidebar link: '{linkName}'";
        await Logger.LogActivityAsync(userName, activity);
        Navigation.NavigateTo("/admin");
    }

    private ElementReference mainContentRef;
    private string? currentUri;

    private async void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (e.Location != currentUri)
        {
            currentUri = e.Location;
            await JS.InvokeVoidAsync("removeAnimationClass", mainContentRef, "page-enter");
            await Task.Delay(50);
            await JS.InvokeVoidAsync("addAnimationClass", mainContentRef, "page-enter");
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
        _timeTimer?.Dispose();
    }
}
