@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using VandaliaCentral.Models.Tanks
@using VandaliaCentral.Services
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject LoggingService Logger
@implements IAsyncDisposable

<div class="tanks-shell">
    <div class="tanks-controls">
        <div class="input-group">
            <span class="input-group-text">Name</span>
            <input class="form-control" @bind="playerName" maxlength="24" />
            <button class="btn btn-primary" @onclick="JoinAsync" disabled="@joined">Join</button>
            <button class="btn btn-outline-secondary" @onclick="LeaveAsync" disabled="@(!joined)">Leave</button>
        </div>
        <div class="small text-muted mt-2">W/S move, A/D rotate body, mouse aims turret, left click fires.</div>
        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="text-danger small mt-2">@statusMessage</div>
        }
    </div>

    <div class="tanks-main">
        <canvas id="@CanvasId" width="1000" height="640" class="tanks-canvas"></canvas>

        <div class="tanks-lobby">
            <h6>Lobby (@lobbyCount/@lobbyMax)</h6>
            <ul>
                @foreach (var p in lobbyPlayers)
                {
                    <li>@p.Name — K:@p.Kills D:@p.Deaths</li>
                }
            </ul>
        </div>
    </div>
</div>

@code {
    [Parameter] public string CanvasId { get; set; } = "tanksCanvas";

    private DotNetObjectReference<TanksArena>? _dotNetRef;
    private HubConnection? _hub;
    private string? _connectionId;
    private bool joined;
    private string playerName = string.Empty;
    private string? statusMessage;
    private int lobbyCount;
    private int lobbyMax;
    private List<LobbyPlayerDto> lobbyPlayers = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        playerName = auth.User.Identity?.Name?.Split('@').FirstOrDefault() ?? "Tank";

        _dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("tanksClient.init", CanvasId, _dotNetRef);
        await EnsureHubConnectedAsync();
        StateHasChanged();
    }

    private async Task<bool> EnsureHubConnectedAsync()
    {
        if (_hub is not null && _hub.State == HubConnectionState.Connected)
        {
            return true;
        }

        if (_hub is null)
        {
            _hub = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/tanks"))
                .WithAutomaticReconnect()
                .Build();

            _hub.On<string>("ReceiveJoined", async connectionId =>
            {
                _connectionId = connectionId;
                joined = true;
                statusMessage = null;
                await JS.InvokeVoidAsync("tanksClient.setJoined", true, _connectionId);
                await InvokeAsync(StateHasChanged);
            });

            _hub.On<string>("ReceiveJoinError", async message =>
            {
                joined = false;
                statusMessage = message;
                await JS.InvokeVoidAsync("tanksClient.setJoined", false, null);
                await InvokeAsync(StateHasChanged);
            });

            _hub.On<SnapshotDto>("ReceiveSnapshot", async snapshot =>
            {
                await JS.InvokeVoidAsync("tanksClient.setSnapshot", snapshot);
            });

            _hub.On<LobbyStateDto>("ReceiveLobbyState", async lobby =>
            {
                lobbyMax = lobby.MaxPlayers;
                lobbyPlayers = lobby.Players
                    .OrderByDescending(p => p.Kills)
                    .ThenBy(p => p.Deaths)
                    .ToList();
                lobbyCount = lobbyPlayers.Count;
                await InvokeAsync(StateHasChanged);
            });

            _hub.Closed += async _ =>
            {
                joined = false;
                statusMessage = "Disconnected from Tanks hub. Rejoin to continue.";
                await JS.InvokeVoidAsync("tanksClient.setJoined", false, null);
                await InvokeAsync(StateHasChanged);
            };
        }

        try
        {
            await _hub.StartAsync();
            return true;
        }
        catch (Exception ex)
        {
            statusMessage = $"Unable to connect to /hubs/tanks: {ex.Message}";
            return false;
        }
    }

    private async Task JoinAsync()
    {
        statusMessage = null;

        if (!await EnsureHubConnectedAsync() || _hub is null)
        {
            return;
        }

        try
        {
            await _hub.InvokeAsync("JoinGame", playerName);

            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            await Logger.LogActivityAsync(auth.User.Identity?.Name ?? "anonymous", "Joined Tanks game");
        }
        catch (Exception ex)
        {
            joined = false;
            statusMessage = ex.Message;
            await JS.InvokeVoidAsync("tanksClient.setJoined", false, null);
        }
    }

    private async Task LeaveAsync()
    {
        try
        {
            if (_hub is not null && _hub.State == HubConnectionState.Connected)
            {
                await _hub.InvokeAsync("LeaveGame");
            }
        }
        catch
        {
            // no-op
        }

        joined = false;
        _connectionId = null;
        statusMessage = null;
        await JS.InvokeVoidAsync("tanksClient.leaveGame");
    }

    [JSInvokable]
    public async Task OnInputFrame(InputDto input)
    {
        if (!joined || _hub is null || _hub.State != HubConnectionState.Connected)
        {
            return;
        }

        try
        {
            await _hub.InvokeAsync("SendInput", input);
        }
        catch
        {
            // no-op
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("tanksClient.dispose");
        }
        catch
        {
            // ignore JS dispose errors
        }

        if (_hub is not null)
        {
            try
            {
                await _hub.DisposeAsync();
            }
            catch
            {
                // ignore hub dispose errors
            }
        }

        _dotNetRef?.Dispose();
    }
}
