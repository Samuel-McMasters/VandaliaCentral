@using Microsoft.AspNetCore.Components.Authorization
@using VandaliaCentral.Game.Tanks
@using VandaliaCentral.Models.Tanks
@using VandaliaCentral.Services
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject LoggingService Logger
@inject TanksGameEngine TanksEngine
@implements IAsyncDisposable

<div class="tanks-shell">
    <div class="tanks-controls">
        <div class="input-group">
            <span class="input-group-text">Name</span>
            <input class="form-control" @bind="playerName" maxlength="24" />
            <button class="btn btn-primary" @onclick="JoinAsync" disabled="@joined">Join</button>
            <button class="btn btn-outline-secondary" @onclick="LeaveAsync" disabled="@(!joined)">Leave</button>
        </div>
        <div class="small text-muted mt-2">W/S move, A/D rotate body, mouse aims turret, left click fires.</div>
        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="text-danger small mt-2">@statusMessage</div>
        }
    </div>

    <div class="tanks-main">
        <canvas id="@CanvasId" width="1000" height="640" class="tanks-canvas"></canvas>

        <div class="tanks-lobby">
            <h6>Lobby (@lobbyCount/@lobbyMax)</h6>
            <ul>
                @foreach (var p in lobbyPlayers)
                {
                    <li>@p.Name — K:@p.Kills D:@p.Deaths</li>
                }
            </ul>
        </div>
    </div>
</div>

@code {
    [Parameter] public string CanvasId { get; set; } = "tanksCanvas";

    private readonly string _playerId = Guid.NewGuid().ToString("N");
    private DotNetObjectReference<TanksArena>? _dotNetRef;
    private CancellationTokenSource? _loopCts;
    private Task? _snapshotLoopTask;
    private bool joined;
    private string playerName = string.Empty;
    private string? statusMessage;
    private int lobbyCount;
    private int lobbyMax;
    private List<LobbyPlayerDto> lobbyPlayers = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        playerName = auth.User.Identity?.Name?.Split('@').FirstOrDefault() ?? "Tank";

        _dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("tanksClient.init", CanvasId, _dotNetRef);

        _loopCts = new CancellationTokenSource();
        _snapshotLoopTask = RunSnapshotLoopAsync(_loopCts.Token);

        StateHasChanged();
    }

    private async Task RunSnapshotLoopAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                var snapshot = TanksEngine.CreateSnapshot();
                var lobby = TanksEngine.CreateLobbyState();

                lobbyMax = lobby.MaxPlayers;
                lobbyPlayers = lobby.Players
                    .OrderByDescending(p => p.Kills)
                    .ThenBy(p => p.Deaths)
                    .ToList();
                lobbyCount = lobbyPlayers.Count;

                await JS.InvokeVoidAsync("tanksClient.setSnapshot", snapshot);
                await InvokeAsync(StateHasChanged);

                await Task.Delay(66, cancellationToken);
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch
            {
                await Task.Delay(250, cancellationToken);
            }
        }
    }

    private async Task JoinAsync()
    {
        statusMessage = null;

        if (TanksEngine.JoinGame(_playerId, playerName, out var error))
        {
            joined = true;
            await JS.InvokeVoidAsync("tanksClient.setJoined", true, _playerId);

            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            await Logger.LogActivityAsync(auth.User.Identity?.Name ?? "anonymous", "Joined Tanks game");
            return;
        }

        joined = false;
        statusMessage = error ?? "Unable to join game.";
        await JS.InvokeVoidAsync("tanksClient.setJoined", false, null);
    }

    private async Task LeaveAsync()
    {
        TanksEngine.LeaveGame(_playerId);
        joined = false;
        statusMessage = null;
        await JS.InvokeVoidAsync("tanksClient.leaveGame");
    }

    [JSInvokable]
    public Task OnInputFrame(InputDto input)
    {
        if (!joined)
        {
            return Task.CompletedTask;
        }

        TanksEngine.ApplyInput(_playerId, input);
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        TanksEngine.LeaveGame(_playerId);

        if (_loopCts is not null)
        {
            _loopCts.Cancel();
        }

        if (_snapshotLoopTask is not null)
        {
            try
            {
                await _snapshotLoopTask;
            }
            catch
            {
                // ignore loop shutdown errors
            }
        }

        try
        {
            await JS.InvokeVoidAsync("tanksClient.dispose");
        }
        catch
        {
            // ignore JS dispose errors
        }

        _loopCts?.Dispose();
        _dotNetRef?.Dispose();
    }
}
